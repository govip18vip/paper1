---
/**
 * SEO Head 组件 — 完整的移动端 + 多语言 SEO meta
 * 放置路径: src/components/SEOHead.astro
 * 
 * 使用方式 (在 Layout.astro 或 Base.astro 的 <head> 中):
 * ---
 * import SEOHead from "../components/SEOHead.astro";
 * ---
 * <head>
 *   <SEOHead
 *     title={title}
 *     description={description}
 *     ogImage={heroImage}
 *     canonicalURL={canonical}
 *     pubDatetime={pubDatetime}
 *     modDatetime={modDatetime}
 *     author={author}
 *     lang={lang}
 *     translationKey={translationKey}
 *     hreflangData={hreflang}
 *     faqs={faqs}
 *     tags={tags}
 *     articleType={type}
 *   />
 * </head>
 */

interface FAQ {
  q: string;
  a: string;
}

interface HreflangItem {
  lang: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: string;
  modDatetime?: string;
  author?: string;
  lang?: string;
  translationKey?: string;
  hreflangData?: HreflangItem[];
  faqs?: FAQ[];
  tags?: string[];
  articleType?: string;
}

const {
  title,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  author = "bitaigen",
  lang = "zh-CN",
  translationKey,
  hreflangData = [],
  faqs = [],
  tags = [],
  articleType = "article",
} = Astro.props;

const siteURL = "https://bitaigen.com";
const resolvedOgImage = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : `${siteURL}${ogImage}`
  : `${siteURL}/og-default.png`;

const resolvedCanonical = canonicalURL || Astro.url.href;

// JSON-LD: Article
const articleLD = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: title,
  description: description,
  image: resolvedOgImage,
  datePublished: pubDatetime || new Date().toISOString(),
  dateModified: modDatetime || pubDatetime || new Date().toISOString(),
  author: {
    "@type": "Organization",
    name: author,
  },
  publisher: {
    "@type": "Organization",
    name: "bitaigen",
    url: siteURL,
    logo: {
      "@type": "ImageObject",
      url: `${siteURL}/favicon.svg`,
    },
  },
  mainEntityOfPage: resolvedCanonical,
  inLanguage: lang,
  isAccessibleForFree: true,
  ...(tags.length > 0 && { keywords: tags.join(", ") }),
};

// JSON-LD: FAQ
const faqLD =
  faqs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((faq) => ({
          "@type": "Question",
          name: faq.q,
          acceptedAnswer: {
            "@type": "Answer",
            text: faq.a,
          },
        })),
      }
    : null;

// JSON-LD: BreadcrumbList
const pathParts = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteURL,
    },
    ...pathParts.map((part, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: decodeURIComponent(part),
      item: `${siteURL}/${pathParts.slice(0, i + 1).join("/")}`,
    })),
  ],
};
---

<!-- 基础 Meta -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#1a1a2e" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="color-scheme" content="light dark" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="format-detection" content="telephone=no" />

<!-- SEO Meta -->
<title>{title} | bitaigen</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={author} />
{tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="canonical" href={resolvedCanonical} />

<!-- Hreflang -->
{hreflangData.map((item) => (
  <link rel="alternate" hreflang={item.lang} href={item.url} />
))}

<!-- Open Graph -->
<meta property="og:type" content={articleType === "article" ? "article" : "website"} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="bitaigen" />
<meta property="og:locale" content={lang.replace("-", "_")} />
{pubDatetime && <meta property="article:published_time" content={pubDatetime} />}
{modDatetime && <meta property="article:modified_time" content={modDatetime} />}
{tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={resolvedCanonical} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />

<!-- JSON-LD: Article -->
<script type="application/ld+json" set:html={JSON.stringify(articleLD)} />

<!-- JSON-LD: FAQ (if available) -->
{faqLD && <script type="application/ld+json" set:html={JSON.stringify(faqLD)} />}

<!-- JSON-LD: Breadcrumb -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />

<!-- 预连接优化 -->
<link rel="dns-prefetch" href="https://basebiance.com" />
<link rel="preconnect" href="https://basebiance.com" crossorigin />
