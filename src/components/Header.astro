---
// src/components/Header.astro
// Top dark utility bar — service links, search, lang switcher, login
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE } from "@/config";
import { getLang, useTranslations, languages, type Lang } from "@/i18n/ui";

const lang = getLang(Astro.url);
const t = useTranslations(lang);

const serviceLinks = [
  { key: "topbar.enterprise" as const, href: "/about" },
  { key: "topbar.investor" as const,   href: "/about" },
  { key: "topbar.startup" as const,    href: "/about" },
  { key: "topbar.platform" as const,   href: "/about" },
];
---

<!-- Top Utility Bar -->
<div class="topbar">
  <div
    style="max-width:1400px;margin:0 auto;padding:0 16px;display:flex;align-items:center;justify-content:space-between;height:40px;gap:16px;"
  >
    <!-- Left: service links -->
    <div style="display:flex;align-items:center;gap:16px;overflow:hidden;">
      {serviceLinks.map(l => (
        <a href={l.href} style="white-space:nowrap;font-size:12.5px;">
          {t(l.key)}
        </a>
      ))}
      <a href="/about" class="topbar-hl" style="white-space:nowrap;">
        🔥 {t("topbar.tools")}
      </a>
    </div>

    <!-- Right: search + theme + login -->
    <div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">
      <a
        href="/search"
        style="display:flex;align-items:center;gap:4px;font-size:12.5px;color:#9a9baa;text-decoration:none;white-space:nowrap;"
        aria-label={t("topbar.search")}
      >
        <IconSearch style="width:13px;height:13px;" />
        {t("topbar.search")}
      </a>

      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          style="position:relative;width:28px;height:28px;display:flex;align-items:center;justify-content:center;border:none;background:transparent;color:#9a9baa;cursor:pointer;"
          title="Toggle theme"
          aria-label="auto"
          aria-live="polite"
        >
          <IconMoon style="position:absolute;width:13px;height:13px;transition:all 0.2s;" class="dark:scale-0 dark:-rotate-90 scale-100 rotate-0" />
          <IconSunHigh style="position:absolute;width:13px;height:13px;transition:all 0.2s;" class="dark:scale-100 dark:rotate-0 scale-0 rotate-90" />
        </button>
      )}

      <a
        href="/about"
        style="font-size:12.5px;color:#9a9baa;text-decoration:none;white-space:nowrap;padding:3px 10px;border:1px solid rgba(255,255,255,0.15);border-radius:3px;transition:border-color 0.15s,color 0.15s;"
        onmouseover="this.style.borderColor='#f7931a';this.style.color='#f7931a';"
        onmouseout="this.style.borderColor='rgba(255,255,255,0.15)';this.style.color='#9a9baa';"
      >
        {t("topbar.login")}
      </a>
    </div>
  </div>
</div>

<!-- Live Price Ticker -->
<div class="ticker-wrap" style="height:28px;overflow:hidden;" aria-label="Live prices" role="marquee">
  <div class="ticker-inner" style="height:28px;line-height:28px;padding:0 20px;" id="price-ticker">
    <span style="margin:0 20px;opacity:0.9;">⚡ <strong>BTC</strong> <span id="btc-p">$—</span></span>
    <span style="margin:0 20px;">ETH <span id="eth-p">$—</span></span>
    <span style="margin:0 20px;">BNB <span id="bnb-p">$—</span></span>
    <span style="margin:0 20px;">SOL <span id="sol-p">$—</span></span>
    <span style="margin:0 20px;">XRP <span id="xrp-p">$—</span></span>
    <span style="margin:0 20px;opacity:0.7;">区块链资讯 · Bitcoin News · Noticias Blockchain · Notícias Cripto</span>
    <!-- duplicate for seamless loop -->
    <span style="margin:0 20px;opacity:0.9;">⚡ <strong>BTC</strong> <span>$—</span></span>
    <span style="margin:0 20px;">ETH <span>$—</span></span>
    <span style="margin:0 20px;">BNB <span>$—</span></span>
    <span style="margin:0 20px;">SOL <span>$—</span></span>
    <span style="margin:0 20px;">XRP <span>$—</span></span>
    <span style="margin:0 20px;opacity:0.7;">区块链资讯 · Bitcoin News · Noticias Blockchain · Notícias Cripto</span>
  </div>
</div>

<script>
  // Live crypto prices via CoinGecko free API
  async function loadPrices() {
    try {
      const r = await fetch(
        "https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum,binancecoin,solana,ripple&vs_currencies=usd&include_24hr_change=true",
        { signal: AbortSignal.timeout(6000) }
      );
      if (!r.ok) return;
      const d = await r.json();
      const fmt = (n: number) => n >= 1000
        ? "$" + n.toLocaleString("en-US", { maximumFractionDigits: 0 })
        : "$" + n.toFixed(3);
      const pairs: [string, any][] = [
        ["btc-p", d.bitcoin],
        ["eth-p", d.ethereum],
        ["bnb-p", d.binancecoin],
        ["sol-p", d.solana],
        ["xrp-p", d.ripple],
      ];
      for (const [id, coin] of pairs) {
        const el = document.getElementById(id);
        if (el) {
          const chg = coin.usd_24h_change;
          el.textContent = fmt(coin.usd) + " " + (chg >= 0 ? "▲" : "▼") + Math.abs(chg).toFixed(2) + "%";
          el.style.color = chg >= 0 ? "rgba(255,255,255,0.95)" : "rgba(255,180,180,0.9)";
        }
      }
    } catch { /* silently ignore */ }
  }

  loadPrices();
  document.addEventListener("astro:after-swap", loadPrices);
</script>
