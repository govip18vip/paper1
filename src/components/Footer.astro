---
// src/components/Footer.astro
import type { HTMLAttributes } from "astro/types";
import { SITE } from "@/config";
import { getLang, useTranslations, LANG_TO_PATH } from "@/i18n/ui";
import SubscribeForm from "@/components/SubscribeForm.astro";

const lang = getLang(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();

type Props = { noMarginTop?: boolean } & HTMLAttributes<"footer">;
const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const siteDesc = t("site.desc");

// 语言基础路径：zh-CN → ""，en → "/en"，zh-tw → "/zh-tw" …
const langSeg = LANG_TO_PATH[lang];
const base = langSeg ? `/${langSeg}` : "";

// Tag 页目前无多语言版本，保持绝对路径
const footerCols = [
  {
    heading: t("footer.col.news"),
    links: [
      { label: t("footer.link.btc"),    href: "/tags/btc" },
      { label: t("footer.link.eth"),    href: "/tags/eth" },
      { label: t("footer.link.defi"),   href: "/tags/defi" },
      { label: t("footer.link.nft"),    href: "/tags/nft" },
      { label: t("footer.link.market"), href: "/tags/market" },
    ],
  },
  {
    heading: t("footer.col.guide"),
    links: [
      { label: t("footer.link.beginner"),  href: "/tags/beginner" },
      { label: t("footer.link.exchange"),  href: "/tags/docs" },
      { label: t("footer.link.wallet"),    href: "/tags/wallet" },
      { label: t("footer.link.prices"),    href: base + "/price" },
      { label: t("footer.link.btc_price"), href: base + "/price/btc" },
    ],
  },
  {
    heading: t("footer.col.links"),
    links: [
      { label: t("footer.link.all"),      href: base + "/posts" },
      { label: t("footer.link.tags"),     href: base + "/tags" },
      { label: t("footer.link.archives"), href: "/archives" },
      { label: t("nav.search"),           href: base + "/search" },
      { label: t("nav.about"),            href: base ? base + "/about" : "/about" },
    ],
  },
  {
    heading: t("footer.col.social"),
    links: [
      { label: "Telegram",    href: SITE.telegram, external: true },
      { label: "X / Twitter", href: SITE.twitter,  external: true },
      { label: "RSS Feed",    href: "/rss.xml",     external: true },
    ],
  },
];
---

<footer
  class:list={[{ "mt-auto": !noMarginTop }, className]}
  {...attrs}
  itemscope
  itemtype="https://schema.org/WPFooter"
>
  <!-- ── Subscribe Banner ── -->
  <div class="footer-subscribe">
    <div class="footer-subscribe-inner">
      <div class="footer-subscribe-copy">
        <strong>{t("subscribe.title")}</strong>
        <span>{t("subscribe.desc")}</span>
      </div>
      <div class="footer-subscribe-form">
        <SubscribeForm variant="compact" lang={lang} />
      </div>
    </div>
  </div>

  <div class="footer-grid">

    <!-- Brand column -->
    <div>
      <a href="/" class="footer-brand">
        <div class="footer-brand-icon">₿</div>
        <span class="footer-brand-text">{SITE.title}</span>
      </a>
      <p class="footer-desc">{siteDesc}</p>

      <!-- Social buttons -->
      <div class="footer-social">
        <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="footer-social-btn" aria-label="Telegram" title="Telegram">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </a>
        <a href={SITE.twitter} target="_blank" rel="noopener noreferrer" class="footer-social-btn" aria-label="X / Twitter" title="X / Twitter">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="footer-social-btn" aria-label="RSS" title="RSS Feed">
          📡
        </a>
      </div>
    </div>

    <!-- Link columns -->
    {footerCols.map(col => (
      <div>
        <h3 class="footer-col-heading">{col.heading}</h3>
        <ul class="footer-col-list">
          {col.links.map(link => (
            <li>
              <a href={link.href}
                class="footer-col-link"
                {...((link as any).external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Disclaimer -->
  <div class="footer-disclaimer">
    <p>{t("footer.disclaimer")}</p>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div>© {currentYear} {SITE.title}. {t("footer.rights")}.</div>
    <div class="footer-bottom-links">
      <a href="/about">{t("footer.about")}</a>
      <a href={SITE.telegram} target="_blank" rel="noopener noreferrer">Telegram</a>
      <a href={SITE.twitter} target="_blank" rel="noopener noreferrer">X</a>
      <a href="/rss.xml" target="_blank" rel="noopener noreferrer">RSS</a>
      <span class="footer-slogan">⚡ {t("footer.slogan")}</span>
    </div>
  </div>

  <!-- Hidden machine-readable organization data -->
  <div style="display:none;" aria-hidden="true" itemscope itemtype="https://schema.org/Organization">
    <span itemprop="name">{SITE.title}</span>
    <span itemprop="description">{siteDesc}</span>
    <link itemprop="url" href={SITE.website} />
    <meta itemprop="foundingDate" content="2024" />
    <link itemprop="sameAs" href={SITE.telegram} />
    <link itemprop="sameAs" href={SITE.twitter} />
  </div>
</footer>

<style>
  footer {
    background: var(--bg-sidebar);
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  /* ── Subscribe banner ─── */
  .footer-subscribe {
    border-bottom: 1px solid var(--border);
    background: var(--bg-elevated);
  }
  .footer-subscribe-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .footer-subscribe-copy {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .footer-subscribe-copy strong {
    font-size: 14px;
    font-weight: 700;
    color: var(--fg);
  }
  .footer-subscribe-copy span {
    font-size: 12.5px;
    color: var(--fg-muted);
  }
  .footer-subscribe-form {
    flex: 0 0 380px;
    max-width: 100%;
  }
  @media (max-width: 700px) {
    .footer-subscribe-form { flex: 1 1 100%; }
  }

  .footer-grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 36px 24px 0;
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    gap: 28px;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }
  .footer-brand-icon {
    width: 34px;
    height: 34px;
    background: var(--accent);
    color: #fff;
    font-size: 18px;
    font-weight: 900;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .footer-brand-text {
    font-size: 18px;
    font-weight: 900;
    color: var(--fg);
    letter-spacing: -0.02em;
  }
  .footer-desc {
    font-size: 12.5px;
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 260px;
    margin-bottom: 14px;
  }

  .footer-social {
    display: flex;
    gap: 8px;
  }
  .footer-social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 14px;
    transition: border-color 0.12s, color 0.12s, background 0.12s;
  }
  .footer-social-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--tag-orange-bg);
  }

  .footer-col-heading {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-light);
    margin-bottom: 12px;
  }
  .footer-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-col-link {
    font-size: 13px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.12s;
  }
  .footer-col-link:hover { color: var(--accent); }

  .footer-disclaimer {
    max-width: 1400px;
    margin: 20px auto 0;
    padding: 0 24px;
  }
  .footer-disclaimer p {
    font-size: 11px;
    color: var(--fg-light);
    line-height: 1.6;
    opacity: 0.7;
    border-top: 1px solid var(--border-subtle);
    padding-top: 14px;
  }

  .footer-bottom {
    max-width: 1400px;
    margin: 0 auto;
    padding: 16px 24px;
    margin-top: 12px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 12px;
    color: var(--fg-light);
  }
  .footer-bottom-links {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .footer-bottom-links a {
    color: var(--fg-light);
    text-decoration: none;
    transition: color 0.12s;
  }
  .footer-bottom-links a:hover { color: var(--accent); }
  .footer-slogan { opacity: 0.5; }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 6px;
    }
    .footer-bottom-links {
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>
