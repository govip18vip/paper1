---
// src/components/Footer.astro
import type { HTMLAttributes } from "astro/types";
import { SITE } from "@/config";
import { getLang, useTranslations } from "@/i18n/ui";

const lang = getLang(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();

type Props = { noMarginTop?: boolean } & HTMLAttributes<"footer">;
const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const siteDesc = t("site.desc");

const footerCols = [
  {
    heading: t("footer.col.news"),
    links: [
      { label: "BTC 行情", href: "/tags/btc" },
      { label: "ETH 资讯", href: "/tags/eth" },
      { label: "DeFi 动态", href: "/tags/defi" },
      { label: "NFT 资讯", href: "/tags/nft" },
      { label: "市场分析", href: "/tags/market" },
    ],
  },
  {
    heading: t("footer.col.guide"),
    links: [
      { label: "新手入门", href: "/tags/beginner" },
      { label: "交易所教程", href: "/tags/docs" },
      { label: "钱包安全", href: "/tags/wallet" },
      { label: "合约交易", href: "/tags/docs" },
      { label: "空投教程", href: "/tags/docs" },
    ],
  },
  {
    heading: t("footer.col.links"),
    links: [
      { label: "全部文章", href: "/posts" },
      { label: "标签索引", href: "/tags" },
      { label: "归档",     href: "/archives" },
      { label: "搜索",     href: "/search" },
      { label: "关于",     href: "/about" },
    ],
  },
];
---

<footer
  class:list={[{ "mt-auto": !noMarginTop }, className]}
  {...attrs}
  itemscope
  itemtype="https://schema.org/WPFooter"
>
  <!-- Grid container: uses a dedicated class for CSS targeting -->
  <div class="footer-grid">

    <!-- Brand column -->
    <div>
      <a href="/" class="footer-brand">
        <div class="footer-brand-icon">₿</div>
        <span class="footer-brand-text">{SITE.title}</span>
      </a>
      <p class="footer-desc">{siteDesc}</p>
      <div class="footer-actions">
        <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="footer-action-btn">
          📡 RSS
        </a>
        <a href="/about" class="footer-action-btn">
          ✉ {t("footer.about")}
        </a>
      </div>
    </div>

    <!-- Link columns -->
    {footerCols.map(col => (
      <div>
        <h3 class="footer-col-heading">{col.heading}</h3>
        <ul class="footer-col-list">
          {col.links.map(link => (
            <li>
              <a href={link.href} class="footer-col-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div>© {currentYear} {SITE.title}. {t("footer.rights")}.</div>
    <div class="footer-bottom-links">
      <a href="/about">{t("footer.about")}</a>
      <a href="/rss.xml" target="_blank" rel="noopener noreferrer">RSS</a>
      <span class="footer-slogan">⚡ {t("footer.slogan")}</span>
    </div>
  </div>

  <!-- Hidden machine-readable organization data -->
  <div style="display:none;" aria-hidden="true" itemscope itemtype="https://schema.org/Organization">
    <span itemprop="name">{SITE.title}</span>
    <span itemprop="description">{siteDesc}</span>
    <link itemprop="url" href={SITE.website} />
    <meta itemprop="foundingDate" content="2024" />
  </div>
</footer>

<style>
  footer {
    background: var(--bg-sidebar);
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  /* ── Grid layout ─────────────────────────────────────────── */
  .footer-grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 36px 24px 0;
    display: grid;
    grid-template-columns: 1fr repeat(3, 140px);
    gap: 32px;
    align-items: start;
  }

  /* ── Brand ───────────────────────────────────────────────── */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }
  .footer-brand-icon {
    width: 34px;
    height: 34px;
    background: var(--accent);
    color: #fff;
    font-size: 18px;
    font-weight: 900;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .footer-brand-text {
    font-size: 18px;
    font-weight: 900;
    color: var(--fg);
    letter-spacing: -0.02em;
  }
  .footer-desc {
    font-size: 12.5px;
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 240px;
    margin-bottom: 14px;
  }
  .footer-actions {
    display: flex;
    gap: 8px;
  }
  .footer-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 12px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: border-color 0.12s, color 0.12s;
  }
  .footer-action-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Columns ─────────────────────────────────────────────── */
  .footer-col-heading {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-light);
    margin-bottom: 12px;
  }
  .footer-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-col-link {
    font-size: 13px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.12s;
  }
  .footer-col-link:hover { color: var(--accent); }

  /* ── Bottom bar ──────────────────────────────────────────── */
  .footer-bottom {
    max-width: 1400px;
    margin: 0 auto;
    padding: 16px 24px;
    margin-top: 28px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 12px;
    color: var(--fg-light);
  }
  .footer-bottom-links {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .footer-bottom-links a {
    color: var(--fg-light);
    text-decoration: none;
    transition: color 0.12s;
  }
  .footer-bottom-links a:hover { color: var(--accent); }
  .footer-slogan { opacity: 0.5; }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 6px;
    }
    .footer-bottom-links {
      justify-content: center;
    }
  }
</style>
