---
// src/components/LeftSidebar.astro
import IconSearch from "@/assets/icons/IconSearch.svg";
import { SITE } from "@/config";
import {
  TAXONOMY, DEFAULT_LANG,
  getLang, LANG_TO_PATH, stripLangPrefix,
  useTranslations, type Lang,
} from "@/i18n/ui";

type Props = { currentLang?: Lang };
const { currentLang } = Astro.props;

const lang: Lang = currentLang ?? getLang(Astro.url);
const t = useTranslations(lang);
const langSeg = LANG_TO_PATH[lang];
const cleanPath = stripLangPrefix(Astro.url.pathname);

const base = langSeg ? `/${langSeg}` : "";

const isActive = (p: string) => {
  if (p === "/") return cleanPath === "/" || cleanPath === "";
  return cleanPath.startsWith(p);
};

// Build nav groups with translated labels
const catLabelMap: Record<string, string> = {
  prices: "nav.prices",
  learn: "nav.learn",
  tools: "nav.tools",
  defi: "cat.defi",
};
const catIconMap: Record<string, string> = { prices: "📊", learn: "🎓", tools: "🛠", defi: "💎" };

const navGroups = TAXONOMY.slice(2).map(cat => {
  const translatedSubs = cat.sub.map(s => ({ ...s, label: t(s.labelKey) }));
  // Group is "active" if the group's own path OR any sub-item's path matches current URL
  const groupActive = isActive(cat.href) || translatedSubs.some(s => isActive(s.href));
  return {
    ...cat,
    label: t(catLabelMap[cat.key] ?? `cat.${cat.key}`),
    icon: catIconMap[cat.key] ?? "",
    translatedSubs,
    groupActive,
  };
});

---

<aside class="lsidebar" role="navigation" aria-label="主导航">

  <!-- Logo -->
  <a href={base || "/"} class="lsidebar-logo" aria-label={SITE.title}>
    <div class="lsidebar-logo-icon" aria-hidden="true">₿</div>
    <span class="lsidebar-logo-text" data-i18n="site.name">{SITE.title}</span>
  </a>

  <!-- Mobile hamburger -->
  <button id="mobile-nav-btn" class="mobile-ham-btn"
    aria-label="Toggle menu" aria-expanded="false" aria-controls="lnav">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <!-- ── Navigation ── -->
  <nav class="lnav" id="lnav">

    <a href={base || "/"}
      class:list={["lnav-item", {
        active: isActive("/") && !isActive("/posts") && !isActive("/tags")
                && !isActive("/search") && !isActive("/about") && !isActive("/archives")
                && !isActive("/price"),
      }]}>
      <span data-i18n="nav.home">{t("nav.home")}</span>
    </a>

    <a href={base + "/flash"} class:list={["lnav-item", { active: isActive("/flash") }]}>
      <span data-i18n="nav.flash">{t("nav.flash")}</span>
    </a>

    <a href={base + "/posts"}
      class:list={["lnav-item", { active: isActive("/posts") }]}>
      <span data-i18n="nav.news">{t("nav.news")}</span>
    </a>

    <a href={base + "/news"}
      class:list={["lnav-item", { active: isActive("/news") }]}>
      <span data-i18n="nav.newsCenter">{t("nav.newsCenter")}</span>
    </a>

    <a href="/archives"
      class:list={["lnav-item", { active: isActive("/archives") }]}>
      <span data-i18n="footer.link.archives">{t("footer.link.archives")}</span>
    </a>

    <!-- Taxonomy groups: prices, learn, tools, defi -->
    {navGroups.map(g => (
      <div class="lnav-group" id={`group-${g.key}`}>
        {g.translatedSubs.length > 0 ? (
          <button
            class:list={["lnav-item lnav-toggle", { active: g.groupActive }]}
            aria-expanded={g.groupActive ? "true" : "false"}
            data-group={g.key}
          >
            <span style="display:flex;align-items:center;gap:6px;">
              {g.icon && <span style="font-size:12px;">{g.icon}</span>}
              <span>{g.label}</span>
            </span>
            <svg class="arrow" width="11" height="11" viewBox="0 0 12 12" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 2l4 4-4 4"/>
            </svg>
          </button>
        ) : (
          <a href={g.href} class:list={["lnav-item", { active: g.groupActive }]}>
            <span style="display:flex;align-items:center;gap:6px;">
              {g.icon && <span style="font-size:12px;">{g.icon}</span>}
              <span>{g.label}</span>
            </span>
          </a>
        )}
        {g.translatedSubs.length > 0 && (
          <div class:list={["lnav-sub", { open: g.groupActive }]} id={`sub-${g.key}`}>
            {g.translatedSubs.map(sub => (
              <a href={sub.href}
                class:list={["lnav-sub-link", { active: isActive(sub.href) }]}>
                {sub.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}

    <div class="lnav-divider" />

    <a href={base + "/search"} class:list={["lnav-item", { active: isActive("/search") }]}>
      <span style="display:flex;align-items:center;gap:6px;">
        <IconSearch style="width:14px;height:14px;flex-shrink:0;" />
        <span data-i18n="nav.search">{t("nav.search")}</span>
      </span>
    </a>

    <a href="/about" class:list={["lnav-item", { active: isActive("/about") }]}>
      <span data-i18n="nav.about">{t("nav.about")}</span>
    </a>

  </nav>

  <!-- ── Action buttons: Telegram + Partner ── -->
  <div class="lnav-actions">
    <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="lnav-btn lnav-btn-primary">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      <span data-i18n="btn.telegram">{t("btn.telegram")}</span>
    </a>
    <a href="/about" class="lnav-btn">
      <span>🤝</span>
      <span data-i18n="btn.partner">{t("btn.partner")}</span>
    </a>
  </div>


</aside>

<style>
.mobile-ham-btn {
  display: none;
  margin-left: auto;
  margin-right: 12px;
  padding: 6px;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--fg-muted);
  border-radius: 4px;
  transition: background 0.12s;
}
.mobile-ham-btn:hover { background: var(--bg-elevated); }

.lnav-sub-link.active {
  color: var(--accent);
  background: var(--nav-active-bg);
}
.lnav-toggle[aria-expanded="true"] .arrow { transform: rotate(90deg); }
.arrow { transition: transform 0.2s; flex-shrink: 0; }
.lnav-toggle { justify-content: space-between; }

/* Primary action button (Telegram) */
.lnav-btn-primary {
  background: var(--tag-blue-bg) !important;
  border-color: var(--accent-blue) !important;
  color: var(--accent-blue) !important;
}
.lnav-btn-primary:hover {
  background: var(--accent-blue) !important;
  color: #fff !important;
}

@media (max-width: 768px) {
  .mobile-ham-btn { display: flex; }
}
</style>

<script>
function initToggles() {
  document.querySelectorAll<HTMLButtonElement>(".lnav-toggle").forEach(btn => {
    btn.addEventListener("click", () => {
      const key = btn.getAttribute("data-group");
      const sub = document.getElementById(`sub-${key}`);
      if (!sub) return;
      const open = sub.classList.toggle("open");
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    });
  });
}

function initMobileNav() {
  const btn = document.getElementById("mobile-nav-btn");
  const nav = document.getElementById("lnav");
  if (!btn || !nav) return;

  // Hamburger toggle
  btn.addEventListener("click", (e) => {
    e.stopPropagation();
    const open = nav.classList.toggle("mobile-open");
    btn.setAttribute("aria-expanded", open ? "true" : "false");
  });

  // Close when any nav link is clicked (user navigated away)
  nav.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", () => {
      nav.classList.remove("mobile-open");
      btn.setAttribute("aria-expanded", "false");
    });
  });

  // Close when clicking outside the sidebar
  document.addEventListener("click", (e) => {
    const sidebar = btn.closest(".lsidebar");
    if (sidebar && !sidebar.contains(e.target as Node)) {
      nav.classList.remove("mobile-open");
      btn.setAttribute("aria-expanded", "false");
    }
  });
}

initToggles();
initMobileNav();
document.addEventListener("astro:after-swap", () => {
  initToggles();
  initMobileNav();
});
</script>
