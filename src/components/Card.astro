---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
  size?: "hero" | "thumb" | "large" | "medium" | "small" | "list" | "news";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", size = "medium", id, data, filePath } = Astro.props;
const { title, description, tags, pubDatetime, modDatetime, ogImage } = data;
// ✅ Pull lang from frontmatter for client-side language filtering
const cardLang = (data as any).lang ?? "";
const postPath = getPath(id, filePath);

const primaryTag = tags?.[0] ?? "加密货币";
const readingTime = (() => {
  const body = (Astro.props as any).body ?? "";
  if (!body) return 0;
  const isCJK = /[\u4e00-\u9fff\u3400-\u4dbf]/.test(body);
  const wc = isCJK ? body.replace(/\s+/g, "").length : body.split(/\s+/).length;
  return Math.max(1, Math.round(wc / (isCJK ? 400 : 250)));
})();

const tagColorMap: Record<string, string> = {
  btc: "ctag", bitcoin: "ctag",
  eth: "ctag-blue", ethereum: "ctag-blue",
  defi: "ctag-green", wallet: "ctag-green", 钱包: "ctag-green",
  market: "ctag-red", 行情: "ctag-red",
  教程: "ctag-blue", docs: "ctag-blue",
};
const tagClass = tagColorMap[primaryTag.toLowerCase()] ?? "ctag";

const grads = [
  "from-orange-900/40 to-amber-900/20",
  "from-blue-900/40 to-cyan-900/20",
  "from-purple-900/40 to-violet-900/20",
  "from-green-900/40 to-emerald-900/20",
];
const placeholderGrad = grads[title.length % grads.length];
const imgSrc = typeof ogImage === "string" ? ogImage : (ogImage as any)?.src ?? "";

const dotClass =
  primaryTag.toLowerCase() === "eth" || primaryTag.toLowerCase() === "defi" ? "blue" :
  primaryTag.toLowerCase() === "wallet" || primaryTag.toLowerCase() === "新手入门" ? "green" : "";
---

{size === "hero" && (
  <a href={postPath}
    class="hero-img-wrap block group focus-outline"
    aria-label={title}
    data-card-lang={cardLang}
  >
    {imgSrc ? (
      <img src={imgSrc} alt={title} loading="eager" fetchpriority="high"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" />
    ) : (
      <div class={`w-full h-full bg-gradient-to-br ${placeholderGrad} flex items-center justify-center`}>
        <span class="text-5xl opacity-30">₿</span>
      </div>
    )}
    <div class="hero-overlay" />
    <div class="hero-content">
      <div class="mb-2"><span class={tagClass}>{primaryTag}</span></div>
      <Heading
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
        class="text-white text-xl sm:text-2xl font-bold leading-snug mb-2 group-hover:text-amber-200 transition-colors"
      >{title}</Heading>
      <p class="text-white/70 text-sm line-clamp-2 hidden sm:block">{description}</p>
      <div class="mt-2">
        <Datetime {pubDatetime} {modDatetime} class="text-white/50 text-xs" />
      </div>
    </div>
  </a>
)}

{size === "thumb" && (
  <a href={postPath} class="hero-thumb" aria-label={title} data-card-lang={cardLang}>
    {imgSrc ? (
      <img src={imgSrc} alt={title} loading="lazy"
        style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.3s ease;" />
    ) : (
      <div class={`w-full h-full bg-gradient-to-br ${placeholderGrad} flex items-center justify-center`}>
        <span class="text-3xl opacity-20">₿</span>
      </div>
    )}
    <div class="hero-thumb-overlay" aria-hidden="true" />
    <div class="hero-thumb-title">{title}</div>
  </a>
)}

{size === "large" && (
  <article class="c-card group" data-card-lang={cardLang}>
    <a href={postPath} class="c-card-img block focus-outline" tabindex="-1" aria-hidden="true">
      {imgSrc ? (
        <img src={imgSrc} alt={title} loading="lazy" class="w-full h-full object-cover" />
      ) : (
        <div class={`w-full h-full bg-gradient-to-br ${placeholderGrad} flex items-center justify-center`}>
          <span class="text-4xl opacity-25">₿</span>
        </div>
      )}
    </a>
    <div class="p-4">
      <div class="mb-2"><span class={tagClass}>{primaryTag}</span></div>
      <a href={postPath} class="focus-outline">
        <Heading
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
          class="text-foreground font-bold text-base leading-snug mb-2 group-hover:text-accent transition-colors line-clamp-2"
        >{title}</Heading>
      </a>
      <p class="text-sm mt-1.5 line-clamp-2" style="color:var(--fg-muted);">{description}</p>
      <div class="mt-3 flex items-center gap-2">
        <Datetime {pubDatetime} {modDatetime} class="text-xs" />
        {readingTime > 0 && <span class="text-xs" style="color:var(--fg-light);">{readingTime} min</span>}
      </div>
    </div>
  </article>
)}

{size === "medium" && (
  <article class="c-card group" data-card-lang={cardLang}>
    <a href={postPath} class="c-card-img block focus-outline" tabindex="-1" aria-hidden="true">
      {imgSrc ? (
        <img src={imgSrc} alt={title} loading="lazy" class="w-full h-full object-cover" />
      ) : (
        <div class={`w-full h-full bg-gradient-to-br ${placeholderGrad} flex items-center justify-center`}>
          <span class="text-3xl opacity-20">₿</span>
        </div>
      )}
    </a>
    <div class="p-3.5">
      <div class="mb-1.5"><span class={tagClass}>{primaryTag}</span></div>
      <a href={postPath} class="focus-outline">
        <Heading
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
          class="text-foreground font-semibold text-sm leading-snug group-hover:text-accent transition-colors line-clamp-2"
        >{title}</Heading>
      </a>
      <div class="mt-2 flex items-center gap-2">
        <Datetime {pubDatetime} {modDatetime} class="text-xs" />
        {readingTime > 0 && <span class="text-xs" style="color:var(--fg-light);">{readingTime} min</span>}
      </div>
    </div>
  </article>
)}

{size === "small" && (
  <article class="c-card group flex gap-0 overflow-hidden" data-card-lang={cardLang}>
    <a href={postPath} class="shrink-0 block focus-outline"
      style="width:100px;height:70px;overflow:hidden;" tabindex="-1" aria-hidden="true">
      {imgSrc ? (
        <img src={imgSrc} alt={title} loading="lazy"
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
      ) : (
        <div class={`w-full h-full bg-gradient-to-br ${placeholderGrad} flex items-center justify-center`}>
          <span class="text-lg opacity-20">₿</span>
        </div>
      )}
    </a>
    <div class="p-2.5 flex flex-col justify-between min-w-0">
      <a href={postPath} class="focus-outline">
        <Heading
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
          class="text-foreground font-medium text-xs leading-snug group-hover:text-accent transition-colors line-clamp-3"
        >{title}</Heading>
      </a>
      <Datetime {pubDatetime} {modDatetime} class="text-[10px] mt-1" />
    </div>
  </article>
)}

{size === "list" && (
  <article class="alist-item group" itemscope itemtype="https://schema.org/Article" data-card-lang={cardLang}>
    <a href={postPath} class="shrink-0 block focus-outline rounded overflow-hidden"
      style="width:80px;height:56px;background:var(--bg-elevated);" tabindex="-1">
      {imgSrc ? (
        <img src={imgSrc} alt={title} loading="lazy" class="w-full h-full object-cover" itemprop="image" />
      ) : (
        <div class={`w-full h-full bg-gradient-to-br ${placeholderGrad} flex items-center justify-center`}>
          <span class="text-base opacity-20">₿</span>
        </div>
      )}
    </a>
    <div class="flex-1 min-w-0">
      <div class="mb-1"><span class={tagClass}>{primaryTag}</span></div>
      <a href={postPath} class="focus-outline" itemprop="url">
        <Heading
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
          class="alist-title text-foreground font-medium text-sm leading-snug transition-colors line-clamp-2"
          itemprop="name"
        >{title}</Heading>
      </a>
      <div class="mt-1">
        <Datetime {pubDatetime} {modDatetime} class="text-[11px]" />
      </div>
    </div>
  </article>
)}

{size === "news" && (
  <div class="qnews-item" data-card-lang={cardLang}>
    <div class:list={["qnews-dot", { blue: dotClass === "blue", green: dotClass === "green" }]}
      aria-hidden="true" />
    <div class="qnews-body">
      <a href={postPath} class="qnews-title" aria-label={title}>{title}</a>
      <Datetime {pubDatetime} {modDatetime} class="qnews-time" />
    </div>
  </div>
)}
