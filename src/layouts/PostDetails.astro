---
// src/layouts/PostDetails.astro
// ─────────────────────────────────────────────────────────────
// Production-quality article detail layout.
// Renders article content via <slot />, includes full site chrome
// (Header, LeftSidebar, right sidebar TOC, Footer), responsive,
// and integrates BinanceBanner, TranslationLinks, BackToTop.
// ─────────────────────────────────────────────────────────────

import type { CollectionEntry } from "astro:content";
import type { TranslationEntry } from "@/utils/getTranslations";

import Layout from "./Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import TranslationLinks from "@/components/TranslationLinks.astro";
import MobileTOC from "@/components/MobileTOC.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import BinanceFloating from "@/components/BinanceFloating.astro";
import EditPost from "@/components/EditPost.astro";
import SubscribeForm from "@/components/SubscribeForm.astro";
import RelatedPosts from "@/components/RelatedPosts.astro";
import ScrollSubscribe from "@/components/ScrollSubscribe.astro";
import ExchangeCTA from "@/components/ExchangeCTA.astro";

import { SITE } from "@/config";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { getLang, useTranslations, type Lang } from "@/i18n/ui";
import { getAuthor } from "@/utils/authors";

// ── Props ────────────────────────────────────────────────────

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<"blog">;
  headings: Heading[];
  translations?: TranslationEntry[];
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
  allPosts?: CollectionEntry<"blog">[];
}

const {
  post,
  headings,
  translations = [],
  prevPost = null,
  nextPost = null,
  allPosts = [],
} = Astro.props;

// ── Extract data ─────────────────────────────────────────────

const {
  title,
  author,
  description,
  ogImage,
  heroImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags = [],
  hideEditPost,
  timezone: postTimezone,
  faqs = [],
  type: articleType = "article",
} = post.data;

const keyTakeaways: string[] = (post.data as any).keyTakeaways ?? [];
const postKeywords: string | undefined = (post.data as any).keywords;

// Language
const postLang = ((post.data as any).lang as Lang) ?? "zh-CN";
const t = useTranslations(postLang);

// Author data
const authorData = getAuthor(author ?? SITE.author);

// Resolve OG image: heroImage > ogImage > auto-generated
const resolvedOgImage = (() => {
  const img = heroImage ?? ogImage;
  if (!img) return undefined;
  if (typeof img === "string") return img;
  return (img as any)?.src ?? undefined;
})();

// Reading time estimate
const body = post.body ?? "";
const isCJK = /[\u4e00-\u9fff\u3400-\u4dbf]/.test(body);
const wordCount = isCJK ? body.replace(/\s+/g, "").length : body.split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / (isCJK ? 400 : 250)));

// Filtered headings for TOC (h2 + h3)
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);

// Page title
const pageTitle = `${title} | ${SITE.title}`;

// Schema.org Article structured data
const authorSlug = (author ?? SITE.author).toLowerCase().replace(/\s+/g, "-");
const articleSchema = {
  "@context": "https://schema.org",
  "@type": articleType === "news" ? "NewsArticle" : "Article",
  "@id": `${canonicalURL ?? Astro.url.href}#article`,
  headline: title,
  description,
  ...(resolvedOgImage && {
    image: {
      "@type": "ImageObject",
      url: resolvedOgImage.startsWith("http") ? resolvedOgImage : `${Astro.url.origin}${resolvedOgImage}`,
      width: 1200,
      height: 630,
    },
  }),
  datePublished: pubDatetime.toISOString(),
  dateModified: (modDatetime ?? pubDatetime).toISOString(),
  author: {
    "@type": "Person",
    "@id": `${Astro.url.origin}/author/${authorSlug}/#person`,
    name: author ?? SITE.author,
    url: `${Astro.url.origin}/author/${authorSlug}/`,
    description: authorData.bio[postLang] ?? authorData.bio["zh-CN"] ?? "",
    jobTitle: authorData.title[postLang] ?? authorData.title["zh-CN"] ?? "",
    ...(authorData.twitter || authorData.telegram ? {
      sameAs: [authorData.twitter, authorData.telegram].filter(Boolean),
    } : {}),
  },
  publisher: {
    "@type": "Organization",
    "@id": `${Astro.url.origin}/#organization`,
    name: SITE.title,
    url: SITE.website,
    logo: {
      "@type": "ImageObject",
      url: `${Astro.url.origin}/favicon.svg`,
      width: 64,
      height: 64,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${canonicalURL ?? Astro.url.href}#webpage`,
  },
  isPartOf: { "@id": `${Astro.url.origin}/#website` },
  inLanguage: postLang,
  ...(tags.length > 0 && { keywords: tags.join(", ") }),
};

// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: postLang === "en" ? "Home" : postLang === "es" ? "Inicio" : postLang === "pt" ? "Início" : "首页",
      item: postLang === "zh-CN" ? `${Astro.url.origin}/` : `${Astro.url.origin}/${postLang.toLowerCase()}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: postLang === "en" ? "News" : postLang === "es" ? "Noticias" : postLang === "pt" ? "Notícias" : "资讯",
      item: postLang === "zh-CN"
        ? `${Astro.url.origin}/posts/`
        : `${Astro.url.origin}/${postLang.toLowerCase()}/posts/`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: canonicalURL ?? Astro.url.href,
    },
  ],
};

// FAQ schema
const faqSchema = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(f => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
} : null;

// HowTo schema（仅当 type === "howto" 时生成）
// 优先使用 frontmatter 中的 steps，否则从 h2 标题自动提取
const howToSchema = (articleType === "howto" || articleType === "guide") ? (() => {
  const postSteps = (post.data as any).steps as { name: string; text: string; url?: string }[] | undefined;
  const stepItems = postSteps && postSteps.length > 0
    ? postSteps.map((s, i) => ({
        "@type": "HowToStep",
        position: i + 1,
        name: s.name,
        text: s.text,
        ...(s.url && { url: s.url }),
      }))
    : headings
        .filter(h => h.depth === 2)
        .map((h, i) => ({
          "@type": "HowToStep",
          position: i + 1,
          name: h.text,
          text: h.text,
        }));

  return stepItems.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "@id": `${canonicalURL ?? Astro.url.href}#howto`,
    name: title,
    description,
    inLanguage: postLang,
    datePublished: pubDatetime.toISOString(),
    dateModified: (modDatetime ?? pubDatetime).toISOString(),
    author: {
      "@type": "Person",
      "@id": `${Astro.url.origin}/author/${authorSlug}/#person`,
      name: author ?? SITE.title,
    },
    step: stepItems,
  } : null;
})() : null;
---

<Layout
  title={pageTitle}
  author={author}
  description={description}
  keywords={postKeywords ?? tags.join(", ")}
  ogImage={resolvedOgImage}
  ogType="article"
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
  scrollSmooth
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
    {howToSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    )}
  </Fragment>

  <!-- ★ 阅读进度条 — 文章专属，固定在顶部 -->
  <div id="reading-progress" aria-hidden="true"></div>

  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={postLang} />

    <!-- ══ MAIN CONTENT COLUMN ══ -->
    <main class="main-col post-detail-col" id="main-content">

      <!-- Breadcrumb -->
      <nav class="pd-breadcrumb" aria-label="breadcrumb">
        <a href={postLang === "zh-CN" ? "/" : `/${postLang.toLowerCase()}/`}>
          {t("nav.home")}
        </a>
        <span aria-hidden="true">›</span>
        <a href={postLang === "zh-CN" ? "/posts/" : `/${postLang.toLowerCase()}/posts/`}>
          {t("nav.news")}
        </a>
        <span aria-hidden="true">›</span>
        <span class="pd-breadcrumb-current">{title.length > 30 ? title.slice(0, 30) + "…" : title}</span>
      </nav>

      <!-- Article wrapper (content + sidebar TOC) -->
      <div class="pd-layout">

        <!-- Left: article content -->
        <div class="pd-article-col">

          <!-- Hero image -->
          {resolvedOgImage && (
            <div class="pd-hero-img">
              <img
                src={resolvedOgImage}
                alt={title}
                width="800"
                height="450"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
          )}

          <!-- Tags -->
          {tags.length > 0 && (
            <div class="pd-tags">
              {tags.map(tag => (
                <a href={`/tags/${slugifyStr(tag)}/`} class="pd-tag">{tag}</a>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1
            class="pd-title"
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
            itemprop="headline"
          >
            {title}
          </h1>

          <!-- Translation links -->
          {translations.length > 1 && (
            <TranslationLinks translations={translations} />
          )}

          <!-- Freshness banner — shows if updated within 30 days -->
          {modDatetime && (Date.now() - new Date(modDatetime).getTime()) < 30 * 86400000 && (
            <div style="display:inline-flex;align-items:center;gap:6px;padding:4px 12px;background:var(--tag-green-bg);border-radius:4px;font-size:11px;font-weight:600;color:var(--accent-green);margin-bottom:8px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              {postLang === "en" ? "Updated" : postLang === "es" ? "Actualizado" : postLang === "pt" ? "Atualizado" : "已更新"} {new Date(modDatetime).toLocaleDateString(postLang === "en" ? "en-US" : postLang === "es" ? "es-ES" : postLang === "pt" ? "pt-BR" : "zh-CN", { year: "numeric", month: "short" })}
            </div>
          )}

          <!-- Meta row: author + date -->
          <div class="pd-meta">
            <a href={`/author/${authorData.slug}/`} class="pd-author-link" itemprop="author" itemscope itemtype="https://schema.org/Person">
              <img src={authorData.avatar} alt={authorData.name}
                width="24" height="24" class="pd-author-avatar"
                onerror="this.style.display='none'" />
              <span itemprop="name">{author ?? SITE.author}</span>
            </a>
            <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} timezone={postTimezone} size="sm" />
            <span class="pd-readtime">{readingTime} min read</span>
            <EditPost hideEditPost={hideEditPost} post={post} class="pd-edit-link" />
            <button
              id="bookmark-btn"
              class="pd-bookmark-btn"
              data-href={Astro.url.pathname}
              data-title={title}
              data-img={resolvedOgImage ?? ""}
              data-tag={tags[0] ?? ""}
              aria-label="Bookmark"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            </button>
          </div>

          <!-- Description -->
          <p class="pd-description">{description}</p>

          <!-- Key Takeaways (GEO optimization — AI search engines prefer structured summaries) -->
          {keyTakeaways && keyTakeaways.length > 0 && (
            <div class="pd-takeaways">
              <h2 class="pd-takeaways-title">
                {postLang === "en" ? "Key Takeaways" : postLang === "es" ? "Puntos Clave" : postLang === "pt" ? "Pontos-Chave" : "要点速览"}
              </h2>
              <ul class="pd-takeaways-list">
                {keyTakeaways.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )}

          <!-- Mobile TOC (visible only on small screens) -->
          <MobileTOC headings={headings} />

          <!-- ★ Article Content — rendered exactly ONCE via <slot /> ★ -->
          <article
            id="article"
            class="app-prose pd-prose"
            itemprop="articleBody"
            data-pagefind-body
          >
            <slot />
          </article>

          <!-- Mid banner (after article content) -->
          <div class="pd-banner-mid">
            <BinanceBanner variant="mid" lang={postLang} />
          </div>

          <!-- FAQ section -->
          {faqs && faqs.length > 0 && (
            <section class="pd-faq" itemscope itemtype="https://schema.org/FAQPage">
              <h2 class="pd-faq-title">{t("nav.about") === "About" ? "FAQ" : "常见问题"}</h2>
              {faqs.map(faq => (
                <details itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                  <summary itemprop="name">{faq.q}</summary>
                  <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                    <p itemprop="text">{faq.a}</p>
                  </div>
                </details>
              ))}
            </section>
          )}

          <!-- Author bio card (E-E-A-T signal) -->
          <div class="pd-author-bio">
            <img src={authorData.avatar} alt={authorData.name} width="48" height="48" class="pd-author-bio-avatar" />
            <div class="pd-author-bio-info">
              <a href={`/author/${authorData.slug}/`} class="pd-author-bio-name">{authorData.name}</a>
              <p class="pd-author-bio-title">{authorData.title[postLang] ?? authorData.title["zh-CN"]}</p>
              <p class="pd-author-bio-text">{authorData.bio[postLang] ?? authorData.bio["zh-CN"]}</p>
              <div class="pd-author-bio-social">
                {authorData.twitter && (
                  <a href={authorData.twitter} target="_blank" rel="noopener noreferrer" aria-label="X/Twitter">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                )}
                {authorData.telegram && (
                  <a href={authorData.telegram} target="_blank" rel="noopener noreferrer" aria-label="Telegram">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                  </a>
                )}
              </div>
            </div>
          </div>

          <!-- Community CTA -->
          <div class="pd-community-cta">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;color:var(--accent)"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            <div>
              <strong>{postLang === "en" ? "Join Our Community" : postLang === "es" ? "Unete a la comunidad" : postLang === "pt" ? "Junte-se a comunidade" : "加入社区"}</strong>
              <span>{postLang === "en" ? "Discuss this article" : postLang === "es" ? "Discute este articulo" : postLang === "pt" ? "Discuta este artigo" : "讨论本文"}</span>
            </div>
            <a href="https://t.me/AllenAmbrose" target="_blank" rel="noopener noreferrer" class="pd-community-btn">
              Telegram →
            </a>
          </div>

          <!-- Article banner -->
          <div class="pd-banner-article">
            <BinanceBanner variant="article" lang={postLang} />
          </div>

          <!-- 邮件订阅卡片 -->
          <div class="pd-subscribe-card">
            <SubscribeForm variant="full" lang={postLang} />
          </div>

          <hr class="pd-divider" />

          <!-- Bottom tags + share -->
          <div class="pd-bottom">
            <div class="pd-bottom-tags">
              <ul class="flex flex-wrap gap-2">
                {tags.map(tag => (
                  <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
                ))}
              </ul>
            </div>
            <div class="pd-share-row">
              <ShareLinks />
              <button id="copy-link-btn" class="pd-copy-link" title="Copy link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span>Copy link</span>
              </button>
            </div>
          </div>

          <!-- Related Articles -->
          <RelatedPosts currentPost={post} allPosts={allPosts} lang={postLang} />

          <!-- Prev / Next navigation -->
          {(prevPost || nextPost) && (
            <nav class="pd-prevnext" aria-label="Article navigation">
              {prevPost ? (
                <a href={getPath(prevPost.id, prevPost.filePath)} class="pd-prevnext-link pd-prev">
                  <span class="pd-prevnext-label">← {t("post.prev")}</span>
                  <span class="pd-prevnext-title">{prevPost.data.title}</span>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={getPath(nextPost.id, nextPost.filePath)} class="pd-prevnext-link pd-next">
                  <span class="pd-prevnext-label">{t("post.next")} →</span>
                  <span class="pd-prevnext-title">{nextPost.data.title}</span>
                </a>
              ) : <div />}
            </nav>
          )}
        </div>

        <!-- Right: desktop TOC sidebar -->
        {tocHeadings.length > 2 && (
          <aside class="pd-toc-sidebar" aria-label={t("post.toc")}>
            <div class="pd-toc-sticky">
              <div class="pd-toc-head">
                <span>{t("post.toc")}</span>
              </div>
              <nav>
                <ul class="pd-toc-list">
                  {tocHeadings.map(h => (
                    <li class:list={["pd-toc-item", { "pd-toc-h3": h.depth === 3 }]}>
                      <a href={`#${h.slug}`} class="pd-toc-link">{h.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>

              <!-- Exchange CTA in sidebar -->
              <div class="pd-toc-banner">
                <ExchangeCTA variant="sidebar" />
              </div>
            </div>
          </aside>
        )}
      </div>

    </main>

    <!-- Right sidebar (site-level, visible on wide screens when no TOC) -->
    {tocHeadings.length <= 2 && (
      <aside class="rsidebar pd-rsidebar-fallback">
        <div class="rsidebar-section">
          <BinanceBanner variant="compact" lang={postLang} />
        </div>
      </aside>
    )}
  </div>

  <!-- CoinOrbit hooks: auto-inject live price badges for crypto names in article text -->
  <script is:inline src="https://orbit.biyijia.com/widget.js"
    data-mode="hooks"
    data-sidebar="true">
  </script>

  <ScrollSubscribe />
  <BinanceFloating />
  <BackToTopButton />
  <Footer />
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════
     POST DETAIL STYLES
     ═══════════════════════════════════════════════════════════ */

  .post-detail-col {
    padding-bottom: 40px;
  }

  /* ── Breadcrumb ─────────────────────────────────────────── */
  .pd-breadcrumb {
    padding: 12px 20px 0;
    font-size: 13px;
    color: var(--fg-muted);
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }
  .pd-breadcrumb::-webkit-scrollbar { display: none; }
  .pd-breadcrumb a {
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.12s;
  }
  .pd-breadcrumb a:hover { color: var(--accent); }
  .pd-breadcrumb span { margin: 0 6px; opacity: 0.5; }
  .pd-breadcrumb-current { color: var(--fg); }

  /* ── Layout: article + TOC sidebar ─────────────────────── */
  .pd-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 32px;
    padding: 0 20px;
    align-items: start;
  }

  .pd-article-col {
    min-width: 0; /* prevent overflow */
  }

  /* ── Hero image ─────────────────────────────────────────── */
  .pd-hero-img {
    margin: 16px 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .pd-hero-img img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

