<script>
  function initTocSpy() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".pd-toc-link");
    if (!tocLinks.length) return;

    const headingIds = Array.from(tocLinks).map(a => a.getAttribute("href")?.slice(1)).filter(Boolean) as string[];
    const headingEls = headingIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    if (!headingEls.length) return;

    let ticking = false;

    function updateActive() {
      const scrollY = window.scrollY;
      let activeIdx = 0;

      for (let i = 0; i < headingEls.length; i++) {
        if (headingEls[i].offsetTop <= scrollY + 100) {
          activeIdx = i;
        }
      }

      tocLinks.forEach((link, i) => {
        link.classList.toggle("active", i === activeIdx);
      });

      // Scroll active link into view within the sticky container
      const activeLink = tocLinks[activeIdx];
      const container = activeLink?.closest(".pd-toc-sticky");
      if (activeLink && container) {
        const linkRect = activeLink.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        if (linkRect.top < containerRect.top || linkRect.bottom > containerRect.bottom) {
          activeLink.scrollIntoView({ block: "nearest", behavior: "smooth" });
        }
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateActive);
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    updateActive();
  }

  initTocSpy();
  document.addEventListener("astro:after-swap", initTocSpy);
</script>

<script>
  // ── 阅读进度条 ────────────────────────────────────────────
  function initReadingProgress() {
    const bar = document.getElementById("reading-progress") as HTMLElement | null;
    if (!bar) return;

    // Only active on post detail pages
    const article = document.getElementById("article") as HTMLElement | null;
    if (!article) {
      bar.style.width = "0%";
      return;
    }

    let ticking = false;

    function updateProgress() {
      if (!bar || !article) return;
      const articleTop    = (article as HTMLElement).offsetTop;
      const articleHeight = (article as HTMLElement).offsetHeight;
      const scrollY       = window.scrollY;
      const viewH         = window.innerHeight;

      // Progress: 0 when article starts entering view → 1 when article bottom exits view
      const start    = articleTop - viewH * 0.2;
      const end      = articleTop + articleHeight - viewH * 0.8;
      const progress = Math.min(1, Math.max(0, (scrollY - start) / (end - start)));

      bar.style.width = `${(progress * 100).toFixed(1)}%`;
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateProgress);
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    updateProgress(); // initial render
  }

  initReadingProgress();
  document.addEventListener("astro:after-swap", initReadingProgress);
</script>

<script>
  // ── 记录阅读历史 ──────────────────────────────────────────
  import { recordVisit } from "@/scripts/reading-history";

  function recordCurrentArticle() {
    const article = document.getElementById("article");
    if (!article) return;
    const h1 = document.querySelector<HTMLElement>(".pd-title");
    const heroImg = document.querySelector<HTMLImageElement>(".pd-hero-img img");
    if (!h1) return;
    recordVisit({
      title: h1.textContent?.trim() ?? "",
      href: window.location.pathname,
      img: heroImg?.src ?? "",
    });
  }

  recordCurrentArticle();
  document.addEventListener("astro:after-swap", recordCurrentArticle);
</script>

<script>
  // ── Bookmark button ──
  import { showToast as bmToast } from "@/scripts/toast";
  import { isBookmarked, toggle as bmToggle } from "@/scripts/bookmarks";

  function initBookmark() {
    const btn = document.getElementById("bookmark-btn") as HTMLButtonElement | null;
    if (!btn) return;
    const href = btn.dataset.href ?? "";

    function updateUI() {
      const active = isBookmarked(href);
      btn!.classList.toggle("active", active);
      btn!.setAttribute("aria-label", active ? "Remove bookmark" : "Add bookmark");
    }

    updateUI();
    btn.addEventListener("click", () => {
      const added = bmToggle({
        title: btn.dataset.title ?? "",
        href,
        img: btn.dataset.img ?? "",
        tag: btn.dataset.tag ?? "",
      });
      updateUI();
      bmToast(added ? "Bookmarked!" : "Bookmark removed");
    });
  }

  initBookmark();
  document.addEventListener("astro:after-swap", initBookmark);
</script>

<script>
  // ── Copy link button ──
  import { showToast } from "@/scripts/toast";

  function initCopyLink() {
    const btn = document.getElementById("copy-link-btn");
    if (!btn) return;

    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        showToast("Link copied!");
      } catch {}
    });
  }

  initCopyLink();
  document.addEventListener("astro:after-swap", initCopyLink);
</script>

<script>
  // ── Image lightbox for article images ──
  function initLightbox() {
    const article = document.getElementById("article");
    if (!article) return;

    article.querySelectorAll<HTMLImageElement>("img").forEach(img => {
      if (img.closest("a")) return; // already linked
      img.style.cursor = "zoom-in";
      img.addEventListener("click", () => {
        const overlay = document.createElement("div");
        overlay.style.cssText = "position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,0.85);display:flex;align-items:center;justify-content:center;cursor:zoom-out;padding:20px;";
        const clone = document.createElement("img");
        clone.src = img.src;
        clone.alt = img.alt;
        clone.style.cssText = "max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px;box-shadow:0 8px 32px rgba(0,0,0,0.5);";
        overlay.appendChild(clone);
        overlay.addEventListener("click", () => overlay.remove());
        document.addEventListener("keydown", function esc(e) {
          if (e.key === "Escape") { overlay.remove(); document.removeEventListener("keydown", esc); }
        });
        document.body.appendChild(overlay);
      });
    });
  }

  initLightbox();
  document.addEventListener("astro:after-swap", initLightbox);
</script>

