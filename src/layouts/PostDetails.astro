---
/**
 * ⚠️ PostDetails.astro 修复补丁
 * 
 * 放置路径: src/layouts/PostDetails.astro  (替换原文件)
 * 
 * ★★★ 关键修复: 文章内容只渲染一次 ★★★
 * 你的原始文件中 <Content /> 或 <slot /> 出现了两次，
 * 导致整篇文章在页面上重复显示两遍。
 * 
 * 如何使用:
 * 方案A (推荐): 直接在原 PostDetails.astro 中搜索并删除第二个 <Content /> 或 <slot />
 * 方案B: 用此文件整体替换 (需要根据你的实际组件做微调)
 * 
 * ============================================================
 * 下面是一个标准的 PostDetails 布局模板，你需要根据你的
 * 实际项目组件(Header, Footer等)做对应调整
 * ============================================================
 */

import type { CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";
import SEOHead from "../components/SEOHead.astro";
import MobileTOC from "../components/MobileTOC.astro";

interface Props {
  post: CollectionEntry<"blog">;
  headings: { depth: number; slug: string; text: string }[];
}

const { post, headings } = Astro.props;
const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
  heroImage,
  lang,
  translationKey,
  hreflang,
  faqs,
  focusKeyword,
  readingTime: rt,
  slug,
} = post.data;

// 构建 hreflang 数据
const hreflangData = (hreflang || []).map((h: any) => ({
  lang: h.lang,
  url: h.url,
}));

const langConfig: Record<string, string> = {
  "zh-CN": "简体中文",
  "zh-TW": "繁體中文",
  en: "English",
  es: "Español",
  pt: "Português",
};
---

<Layout>
  {/* ★ SEO Head 放在 <head> slot 中 */}
  <Fragment slot="head">
    <SEOHead
      title={title}
      description={description}
      ogImage={heroImage || ogImage}
      canonicalURL={canonicalURL}
      pubDatetime={pubDatetime?.toISOString()}
      modDatetime={modDatetime?.toISOString()}
      author={author}
      lang={lang || "zh-CN"}
      translationKey={translationKey}
      hreflangData={hreflangData}
      faqs={faqs || []}
      tags={tags || []}
    />
  </Fragment>

  <main class="post-detail">
    {/* 面包屑 */}
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href={lang === "zh-CN" ? "/" : `/${lang?.toLowerCase()}/`}>首页</a>
      <span>/</span>
      <span>{title}</span>
    </nav>

    {/* Hero 图片 */}
    {heroImage && (
      <div class="hero-image">
        <img
          src={heroImage}
          alt={title}
          width="800"
          height="450"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    )}

    {/* 标签 */}
    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag: string) => (
          <a href={`/tags/${tag}`} class="tag">
            {tag}
          </a>
        ))}
      </div>
    )}

    {/* 标题 */}
    <h1 class="post-title">{title}</h1>

    {/* 多语言版本 */}
    {hreflangData.length > 0 && (
      <div class="translation-links">
        {hreflangData.map((h: any) => {
          const isCurrentLang = h.lang === lang || h.lang.replace("-", "_") === lang?.replace("-", "_");
          return isCurrentLang ? (
            <span class="current-lang">
              {langConfig[h.lang] || h.lang}
            </span>
          ) : (
            <a href={h.url}>
              {langConfig[h.lang] || h.lang}
            </a>
          );
        })}
      </div>
    )}

    {/* 描述 */}
    <p class="post-description">{description}</p>

    {/* 作者 + 日期 */}
    <div class="post-meta">
      <span class="author">{author}</span>
      <time datetime={pubDatetime?.toISOString()}>
        {pubDatetime?.toLocaleDateString("zh-CN", {
          year: "numeric",
          month: "short",
          day: "numeric",
        })}
      </time>
      {rt && <span class="reading-time">{rt} min read</span>}
    </div>

    {/* 布局: 正文 + 侧边栏 */}
    <div class="article-layout">
      <div class="article-main">
        {/* ★ 手机端折叠目录 */}
        <MobileTOC headings={headings} />

        {/* ★★★ 关键: 文章内容只渲染一次 ★★★ */}
        <article class="prose">
          <slot />
        </article>

        {/* FAQ */}
        {faqs && faqs.length > 0 && (
          <section class="faq-section">
            <h2>常见问题</h2>
            {faqs.map((faq: any) => (
              <details>
                <summary>{faq.q}</summary>
                <div>
                  <p>{faq.a}</p>
                </div>
              </details>
            ))}
          </section>
        )}

        {/* 标签 + 分享 */}
        <div class="post-footer-tags">
          {tags?.map((tag: string) => (
            <a href={`/tags/${tag}`}>{tag}</a>
          ))}
        </div>
      </div>

      {/* 桌面端侧边栏 (手机端被 CSS 隐藏) */}
      <aside class="sidebar toc-sidebar">
        <div class="sticky-toc">
          <h3>目录</h3>
          <nav>
            <ul>
              {headings
                .filter((h) => h.depth >= 2 && h.depth <= 3)
                .map((h) => (
                  <li style={h.depth === 3 ? "padding-left:1rem" : ""}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
            </ul>
          </nav>
        </div>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .post-detail {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .breadcrumb {
    font-size: 13px;
    padding: 12px 0;
    opacity: 0.7;
    overflow-x: auto;
    white-space: nowrap;
  }

  .breadcrumb a {
    text-decoration: none;
    color: inherit;
  }

  .breadcrumb span {
    margin: 0 4px;
  }

  .hero-image {
    margin: 0 0 1.5rem;
    border-radius: 12px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .post-tags .tag {
    font-size: 12px;
    padding: 3px 10px;
    border-radius: 4px;
    text-decoration: none;
    opacity: 0.8;
  }

  .post-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.3;
    margin: 0 0 16px;
    word-break: break-word;
  }

  .translation-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .translation-links a,
  .translation-links .current-lang {
    font-size: 13px;
    padding: 4px 10px;
    border-radius: 4px;
    text-decoration: none;
  }

  .translation-links .current-lang {
    font-weight: 600;
    opacity: 0.5;
  }

  .post-description {
    font-size: 15px;
    line-height: 1.6;
    opacity: 0.8;
    margin-bottom: 16px;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    font-size: 13px;
    opacity: 0.7;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(128, 128, 128, 0.15);
  }

  /* 两栏布局 */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .toc-sidebar {
      display: none;
    }
  }

  .sticky-toc {
    position: sticky;
    top: 80px;
  }

  .sticky-toc h3 {
    font-size: 14px;
    margin-bottom: 12px;
    opacity: 0.6;
  }

  .sticky-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sticky-toc a {
    display: block;
    padding: 4px 0;
    font-size: 13px;
    line-height: 1.5;
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 0.15s;
  }

  .sticky-toc a:hover {
    opacity: 1;
  }

  /* FAQ */
  .faq-section {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(128, 128, 128, 0.15);
  }

  .faq-section h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .faq-section details {
    margin-bottom: 8px;
    border: 1px solid rgba(128, 128, 128, 0.12);
    border-radius: 8px;
    overflow: hidden;
  }

  .faq-section summary {
    padding: 14px 16px;
    padding-right: 40px;
    cursor: pointer;
    font-weight: 500;
    font-size: 14px;
    line-height: 1.5;
    min-height: 48px;
    display: flex;
    align-items: center;
    -webkit-tap-highlight-color: transparent;
  }

  .faq-section details > div {
    padding: 0 16px 14px;
    font-size: 14px;
    line-height: 1.7;
    opacity: 0.85;
  }

  .post-footer-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(128, 128, 128, 0.12);
  }

  .post-footer-tags a {
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 4px;
    text-decoration: none;
    opacity: 0.7;
  }

  .post-footer-tags a:hover {
    opacity: 1;
  }

  /* 手机端 */
  @media (max-width: 640px) {
    .post-detail {
      padding: 0 14px;
    }

    .post-title {
      font-size: clamp(1.2rem, 5vw, 1.6rem);
    }

    .hero-image {
      margin: 0 -14px 1rem;
      border-radius: 0;
    }

    .post-meta {
      font-size: 12px;
      gap: 8px;
    }
  }
</style>
