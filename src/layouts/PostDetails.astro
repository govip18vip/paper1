---
// src/layouts/PostDetails.astro
// ─────────────────────────────────────────────────────────────
// Production-quality article detail layout.
// Renders article content via <slot />, includes full site chrome
// (Header, LeftSidebar, right sidebar TOC, Footer), responsive,
// and integrates BinanceBanner, TranslationLinks, BackToTop.
// ─────────────────────────────────────────────────────────────

import type { CollectionEntry } from "astro:content";
import type { TranslationEntry } from "@/utils/getTranslations";

import Layout from "./Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import TranslationLinks from "@/components/TranslationLinks.astro";
import MobileTOC from "@/components/MobileTOC.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import BinanceFloating from "@/components/BinanceFloating.astro";
import EditPost from "@/components/EditPost.astro";

import { SITE } from "@/config";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { getLang, useTranslations, type Lang } from "@/i18n/ui";

// ── Props ────────────────────────────────────────────────────

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<"blog">;
  headings: Heading[];
  translations?: TranslationEntry[];
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const {
  post,
  headings,
  translations = [],
  prevPost = null,
  nextPost = null,
} = Astro.props;

// ── Extract data ─────────────────────────────────────────────

const {
  title,
  author,
  description,
  ogImage,
  heroImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags = [],
  hideEditPost,
  timezone: postTimezone,
  faqs = [],
  type: articleType = "article",
} = post.data;

// Language
const postLang = ((post.data as any).lang as Lang) ?? "zh-CN";
const t = useTranslations(postLang);

// Resolve OG image: heroImage > ogImage > auto-generated
const resolvedOgImage = (() => {
  const img = heroImage ?? ogImage;
  if (!img) return undefined;
  if (typeof img === "string") return img;
  return (img as any)?.src ?? undefined;
})();

// Filtered headings for TOC (h2 + h3)
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);

// Page title
const pageTitle = `${title} | ${SITE.title}`;

// Schema.org Article structured data
const articleSchema = {
  "@context": "https://schema.org",
  "@type": articleType === "news" ? "NewsArticle" : "Article",
  headline: title,
  description,
  image: resolvedOgImage,
  datePublished: pubDatetime.toISOString(),
  dateModified: (modDatetime ?? pubDatetime).toISOString(),
  author: { "@type": "Person", name: author },
  publisher: {
    "@type": "Organization",
    name: SITE.title,
    url: SITE.website,
  },
  mainEntityOfPage: canonicalURL ?? Astro.url.href,
  inLanguage: postLang,
  ...(tags.length > 0 && { keywords: tags.join(", ") }),
};

// FAQ schema
const faqSchema = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(f => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
} : null;
---

<Layout
  title={pageTitle}
  author={author}
  description={description}
  ogImage={resolvedOgImage}
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
  scrollSmooth
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={postLang} />

    <!-- ══ MAIN CONTENT COLUMN ══ -->
    <main class="main-col post-detail-col" id="main-content">

      <!-- Breadcrumb -->
      <nav class="pd-breadcrumb" aria-label="breadcrumb">
        <a href={postLang === "zh-CN" ? "/" : `/${postLang.toLowerCase()}/`}>
          {t("nav.home")}
        </a>
        <span aria-hidden="true">›</span>
        <a href={postLang === "zh-CN" ? "/posts/" : `/${postLang.toLowerCase()}/posts/`}>
          {t("nav.news")}
        </a>
        <span aria-hidden="true">›</span>
        <span class="pd-breadcrumb-current">{title.length > 30 ? title.slice(0, 30) + "…" : title}</span>
      </nav>

      <!-- Article wrapper (content + sidebar TOC) -->
      <div class="pd-layout">

        <!-- Left: article content -->
        <div class="pd-article-col">

          <!-- Hero image -->
          {resolvedOgImage && (
            <div class="pd-hero-img">
              <img
                src={resolvedOgImage}
                alt={title}
                width="800"
                height="450"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
          )}

          <!-- Tags -->
          {tags.length > 0 && (
            <div class="pd-tags">
              {tags.map(tag => (
                <a href={`/tags/${slugifyStr(tag)}/`} class="pd-tag">{tag}</a>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1
            class="pd-title"
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
            itemprop="headline"
          >
            {title}
          </h1>

          <!-- Translation links -->
          {translations.length > 1 && (
            <TranslationLinks translations={translations} />
          )}

          <!-- Meta row: author + date -->
          <div class="pd-meta">
            <span class="pd-author" itemprop="author">{author}</span>
            <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} timezone={postTimezone} size="sm" />
            <EditPost hideEditPost={hideEditPost} post={post} class="pd-edit-link" />
          </div>

          <!-- Description -->
          <p class="pd-description">{description}</p>

          <!-- Mobile TOC (visible only on small screens) -->
          <MobileTOC headings={headings} />

          <!-- ★ Article Content — rendered exactly ONCE via <slot /> ★ -->
          <article
            id="article"
            class="app-prose pd-prose"
            itemprop="articleBody"
            data-pagefind-body
          >
            <slot />
          </article>

          <!-- Mid banner (after article content) -->
          <div class="pd-banner-mid">
            <BinanceBanner variant="mid" lang={postLang} />
          </div>

          <!-- FAQ section -->
          {faqs && faqs.length > 0 && (
            <section class="pd-faq" itemscope itemtype="https://schema.org/FAQPage">
              <h2 class="pd-faq-title">{t("nav.about") === "About" ? "FAQ" : "常见问题"}</h2>
              {faqs.map(faq => (
                <details itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                  <summary itemprop="name">{faq.q}</summary>
                  <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                    <p itemprop="text">{faq.a}</p>
                  </div>
                </details>
              ))}
            </section>
          )}

          <!-- Article banner -->
          <div class="pd-banner-article">
            <BinanceBanner variant="article" lang={postLang} />
          </div>

          <hr class="pd-divider" />

          <!-- Bottom tags + share -->
          <div class="pd-bottom">
            <div class="pd-bottom-tags">
              <ul class="flex flex-wrap gap-2">
                {tags.map(tag => (
                  <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
                ))}
              </ul>
            </div>
            <ShareLinks />
          </div>

          <!-- Prev / Next navigation -->
          {(prevPost || nextPost) && (
            <nav class="pd-prevnext" aria-label="Article navigation">
              {prevPost ? (
                <a href={getPath(prevPost.id, prevPost.filePath)} class="pd-prevnext-link pd-prev">
                  <span class="pd-prevnext-label">← {t("post.prev")}</span>
                  <span class="pd-prevnext-title">{prevPost.data.title}</span>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={getPath(nextPost.id, nextPost.filePath)} class="pd-prevnext-link pd-next">
                  <span class="pd-prevnext-label">{t("post.next")} →</span>
                  <span class="pd-prevnext-title">{nextPost.data.title}</span>
                </a>
              ) : <div />}
            </nav>
          )}
        </div>

        <!-- Right: desktop TOC sidebar -->
        {tocHeadings.length > 2 && (
          <aside class="pd-toc-sidebar" aria-label={t("post.toc")}>
            <div class="pd-toc-sticky">
              <div class="pd-toc-head">
                <span>{t("post.toc")}</span>
              </div>
              <nav>
                <ul class="pd-toc-list">
                  {tocHeadings.map(h => (
                    <li class:list={["pd-toc-item", { "pd-toc-h3": h.depth === 3 }]}>
                      <a href={`#${h.slug}`} class="pd-toc-link">{h.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>

              <!-- Compact Binance banner in sidebar -->
              <div class="pd-toc-banner">
                <BinanceBanner variant="compact" lang={postLang} />
              </div>
            </div>
          </aside>
        )}
      </div>

    </main>

    <!-- Right sidebar (site-level, visible on wide screens when no TOC) -->
    {tocHeadings.length <= 2 && (
      <aside class="rsidebar pd-rsidebar-fallback">
        <div class="rsidebar-section">
          <BinanceBanner variant="compact" lang={postLang} />
        </div>
      </aside>
    )}
  </div>

  <BinanceFloating />
  <BackToTopButton />
  <Footer />
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════
     POST DETAIL STYLES
     ═══════════════════════════════════════════════════════════ */

  .post-detail-col {
    padding-bottom: 40px;
  }

  /* ── Breadcrumb ─────────────────────────────────────────── */
  .pd-breadcrumb {
    padding: 12px 20px 0;
    font-size: 13px;
    color: var(--fg-muted);
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }
  .pd-breadcrumb::-webkit-scrollbar { display: none; }
  .pd-breadcrumb a {
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.12s;
  }
  .pd-breadcrumb a:hover { color: var(--accent); }
  .pd-breadcrumb span { margin: 0 6px; opacity: 0.5; }
  .pd-breadcrumb-current { color: var(--fg); }

  /* ── Layout: article + TOC sidebar ─────────────────────── */
  .pd-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 32px;
    padding: 0 20px;
    align-items: start;
  }

  .pd-article-col {
    min-width: 0; /* prevent overflow */
  }

  /* ── Hero image ─────────────────────────────────────────── */
  .pd-hero-img {
    margin: 16px 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .pd-hero-img img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  /* ── Tags row ───────────────────────────────────────────── */
  .pd-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }
  .pd-tag {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    background: var(--tag-orange-bg);
    color: var(--tag-orange);
    transition: opacity 0.12s;
  }
  .pd-tag:hover { opacity: 0.8; }

  /* ── Title ──────────────────────────────────────────────── */
  .pd-title {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.3;
    color: var(--fg);
    margin: 0 0 12px;
    word-break: break-word;
    letter-spacing: -0.01em;
  }

  /* ── Meta row ───────────────────────────────────────────── */
  .pd-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: var(--fg-muted);
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }
  .pd-author {
    font-weight: 600;
    color: var(--fg);
  }
  .pd-edit-link { font-size: 12px; }

  /* ── Description ────────────────────────────────────────── */
  .pd-description {
    font-size: 15px;
    line-height: 1.65;
    color: var(--fg-muted);
    margin: 0 0 18px;
    padding: 12px 16px;
    background: var(--bg-elevated);
    border-radius: 6px;
    border-left: 3px solid var(--accent);
  }

  /* ── Prose overrides ────────────────────────────────────── */
  .pd-prose {
    max-width: none;
    padding: 0;
  }

  /* ── Banners ────────────────────────────────────────────── */
  .pd-banner-mid { margin: 24px 0 8px; }
  .pd-banner-article { margin: 8px 0 16px; }

  /* ── Divider ────────────────────────────────────────────── */
  .pd-divider {
    border: none;
    border-top: 1px dashed var(--border);
    margin: 16px 0;
  }

  /* ── FAQ ─────────────────────────────────────────────────── */
  .pd-faq {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .pd-faq-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pd-faq-title::before {
    content: '';
    display: block;
    width: 3px;
    height: 18px;
    background: var(--accent);
    border-radius: 2px;
  }
  .pd-faq details {
    margin-bottom: 8px;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-card);
  }
  .pd-faq summary {
    padding: 14px 16px;
    padding-right: 40px;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.5;
    min-height: 48px;
    display: flex;
    align-items: center;
    list-style: none;
    -webkit-tap-highlight-color: transparent;
    color: var(--fg);
  }
  .pd-faq summary::-webkit-details-marker { display: none; }
  .pd-faq summary::after {
    content: '+';
    position: absolute;
    right: 16px;
    font-size: 18px;
    color: var(--fg-muted);
    transition: transform 0.2s;
  }
  .pd-faq details[open] summary::after {
    content: '−';
  }
  .pd-faq details > div {
    padding: 0 16px 14px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--fg-muted);
  }

  /* ── Bottom tags + share ────────────────────────────────── */
  .pd-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    padding-top: 16px;
  }
  .pd-bottom-tags ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Prev / Next ────────────────────────────────────────── */
  .pd-prevnext {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .pd-prevnext-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.12s, background 0.12s;
    min-height: 60px;
  }
  .pd-prevnext-link:hover {
    border-color: var(--accent);
    background: var(--bg-elevated);
  }
  .pd-prevnext-label {
    font-size: 12px;
    color: var(--fg-muted);
    font-weight: 500;
  }
  .pd-prevnext-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pd-next { text-align: right; }

  /* ── TOC Sidebar (desktop) ──────────────────────────────── */
  .pd-toc-sidebar {
    display: block;
  }
  .pd-toc-sticky {
    position: sticky;
    top: 20px;
  }
  .pd-toc-head {
    font-size: 13px;
    font-weight: 700;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 10px;
  }
  .pd-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pd-toc-item {
    margin: 0;
  }
  .pd-toc-h3 {
    padding-left: 14px;
  }
  .pd-toc-link {
    display: block;
    padding: 5px 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.12s;
    border-left: 2px solid transparent;
    padding-left: 10px;
  }
  .pd-toc-link:hover {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  .pd-toc-banner {
    margin-top: 20px;
  }

  /* ── Fallback right sidebar (when TOC is hidden) ────────── */
  .pd-rsidebar-fallback {
    /* Uses global .rsidebar styles */
  }

  /* ═══════════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════════ */

  @media (max-width: 1100px) {
    .pd-toc-sidebar {
      display: none;
    }
    .pd-rsidebar-fallback {
      display: none;
    }
    .pd-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  @media (max-width: 768px) {
    .pd-layout {
      padding: 0 14px;
    }
    .pd-breadcrumb {
      padding: 10px 14px 0;
    }
    .pd-title {
      font-size: clamp(1.2rem, 5vw, 1.6rem);
    }
    .pd-hero-img {
      margin: 12px -14px;
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .pd-description {
      font-size: 14px;
      padding: 10px 14px;
    }
    .pd-meta {
      font-size: 12px;
      gap: 8px;
    }
    .pd-prevnext {
      grid-template-columns: 1fr;
    }
    .pd-bottom {
      flex-direction: column;
    }
  }

  @media (max-width: 500px) {
    .pd-layout { padding: 0 10px; }
    .pd-breadcrumb { padding: 8px 10px 0; }
  }
</style>
