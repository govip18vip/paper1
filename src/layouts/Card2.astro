---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import Card from "@/components/Card.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if ((initOgImage as any)?.src) {
  ogImageUrl = (initOgImage as any).src;
}
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}
const ogImage = ogImageUrl ? new URL(ogImageUrl, Astro.url.origin).href : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

// Prev / Next
const allPosts = posts.map(({ data: { title }, id, filePath }) => ({ id, title, filePath }));
const currentPostIndex = allPosts.findIndex(a => a.id === post.id);
const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost = currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;

// Related posts (same tag)
const relatedPosts = posts
  .filter(p => p.id !== post.id && p.data.tags?.some(t => tags?.includes(t)))
  .slice(0, 3);

// GEO: Article structured data
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImage,
  "datePublished": pubDatetime?.toISOString(),
  "dateModified": modDatetime?.toISOString() ?? pubDatetime?.toISOString(),
  "author": {
    "@type": "Person",
    "name": author ?? SITE.author,
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE.title,
    "url": SITE.website,
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL ?? `${SITE.website}${getPath(post.id, post.filePath)}`,
  },
  "keywords": tags?.join(", "),
  "inLanguage": "zh-CN",
  "about": tags?.map(t => ({
    "@type": "Thing",
    "name": t,
  })),
};

// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": SITE.website },
    { "@type": "ListItem", "position": 2, "name": "文章", "item": `${SITE.website}posts` },
    { "@type": "ListItem", "position": 3, "name": title, "item": `${SITE.website}${getPath(post.id, post.filePath)}` },
  ],
};
---

<Layout {...layoutProps}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <Header />
  <BackButton />

  <div class="app-layout">
    <div class="py-4 lg:grid lg:grid-cols-[1fr_300px] lg:gap-8 lg:items-start">

      <!-- ===== Main Article ===== -->
      <main
        id="main-content"
        class:list={["pb-12", { "mt-6": !SITE.showBackButton }]}
        data-pagefind-body
        itemscope
        itemtype="https://schema.org/Article"
      >

        <!-- Article header -->
        <div
          class="mb-6 pb-6 rounded-xl overflow-hidden"
          style="background:var(--background-card);border:1px solid var(--border);"
        >
          <!-- Hero image -->
          {ogImage && (
            <div class="aspect-video overflow-hidden">
              <img
                src={ogImage}
                alt={title}
                class="w-full h-full object-cover"
                loading="eager"
                fetchpriority="high"
                itemprop="image"
              />
            </div>
          )}

          <div class="px-5 pt-5 pb-2">
            <!-- Tags -->
            {tags && tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-3">
                {tags.map(tag => (
                  <a
                    href={`/tags/${slugifyStr(tag)}`}
                    class="ctag hover:opacity-80 transition-opacity focus-outline"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            )}

            <!-- Title -->
            <h1
              transition:name={slugifyStr(title.replaceAll(".", "-"))}
              class="text-xl sm:text-2xl md:text-3xl font-bold leading-tight mb-3"
              style="color:var(--foreground);"
              itemprop="name"
            >
              {title}
            </h1>

            <!-- Description -->
            {description && (
              <p
                class="text-sm leading-relaxed mb-4"
                style="color:var(--foreground-muted);"
                itemprop="description"
              >
                {description}
              </p>
            )}

            <!-- Meta row -->
            <div
              class="flex flex-wrap items-center gap-3 pt-3 border-t text-xs"
              style="border-color:var(--border);color:var(--foreground-muted);"
            >
              <span class="flex items-center gap-1" itemprop="author" itemscope itemtype="https://schema.org/Person">
                <span class="inline-flex h-5 w-5 items-center justify-center rounded-full text-background text-[9px] font-bold" style="background:var(--accent);">
                  {(author ?? SITE.author).slice(0, 1).toUpperCase()}
                </span>
                <span itemprop="name">{author ?? SITE.author}</span>
              </span>
              <Datetime {pubDatetime} {modDatetime} {timezone} size="sm" />
              <span class="ml-auto flex items-center gap-2">
                <EditPost {hideEditPost} {post} class="text-xs opacity-60 hover:opacity-100" />
              </span>
            </div>
          </div>
        </div>

        <!-- Article body -->
        <article
          id="article"
          class="app-prose mt-0 w-full max-w-none prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg) rounded-xl p-5 sm:p-6"
          style="background:var(--background-card);border:1px solid var(--border);"
          itemprop="articleBody"
        >
          <Content />
        </article>

        <hr class="my-8 border-dashed" style="border-color:var(--border);" />

        <!-- Tags & Share -->
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">
          <ul class="flex flex-wrap gap-2" aria-label="文章标签">
            {tags?.map(tag => (
              <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
            ))}
          </ul>
          <ShareLinks />
        </div>

        <!-- Back to top -->
        <BackToTopButton />

        <!-- Prev/Next navigation -->
        <nav
          class="grid grid-cols-1 sm:grid-cols-2 gap-4 rounded-xl p-4"
          style="background:var(--background-card);border:1px solid var(--border);"
          aria-label="文章前后导航"
        >
          {prevPost && (
            <a
              href={getPath(prevPost.id, prevPost.filePath)}
              class="flex items-start gap-2 group hover:text-accent focus-outline rounded-lg p-2 -m-2 transition-colors"
              rel="prev"
            >
              <IconChevronLeft class="shrink-0 mt-0.5 w-4 h-4 rtl:rotate-180" />
              <div>
                <div class="text-xs mb-1" style="color:var(--foreground-muted);">上一篇</div>
                <div class="text-sm font-medium leading-snug group-hover:text-accent transition-colors line-clamp-2">
                  {prevPost.title}
                </div>
              </div>
            </a>
          )}
          {nextPost && (
            <a
              href={getPath(nextPost.id, nextPost.filePath)}
              class="flex items-start gap-2 group hover:text-accent sm:col-start-2 sm:flex-row-reverse sm:text-right focus-outline rounded-lg p-2 -m-2 transition-colors"
              rel="next"
            >
              <IconChevronRight class="shrink-0 mt-0.5 w-4 h-4 rtl:rotate-180" />
              <div>
                <div class="text-xs mb-1" style="color:var(--foreground-muted);">下一篇</div>
                <div class="text-sm font-medium leading-snug group-hover:text-accent transition-colors line-clamp-2">
                  {nextPost.title}
                </div>
              </div>
            </a>
          )}
        </nav>

        <!-- Related posts -->
        {relatedPosts.length > 0 && (
          <section class="mt-8" aria-label="相关文章">
            <div class="sec-hd mb-4">
              <span class="text-sm font-bold text-foreground">相关文章</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {relatedPosts.map(p => (
                <Card {...p} size="medium" variant="h3" />
              ))}
            </div>
          </section>
        )}
      </main>

      <!-- ===== Sidebar (desktop only) ===== -->
      <aside class="hidden lg:block sticky top-[120px] space-y-5" aria-label="侧边栏">

        <!-- Table of contents (rendered via JS) -->
        <div
          id="toc-sidebar"
          class="rounded-xl p-4"
          style="background:var(--background-card);border:1px solid var(--border);"
        >
          <div class="sec-hd mb-3">
            <span class="text-sm font-bold text-foreground">目录</span>
          </div>
          <nav id="toc-nav" aria-label="文章目录" class="text-xs space-y-1">
            <!-- Filled by JS -->
            <p style="color:var(--foreground-muted);" class="text-xs">加载中...</p>
          </nav>
        </div>

        <!-- Share block -->
        <div
          class="rounded-xl p-4"
          style="background:var(--background-card);border:1px solid var(--border);"
        >
          <div class="sec-hd mb-3">
            <span class="text-sm font-bold text-foreground">分享本文</span>
          </div>
          <ShareLinks />
        </div>

        <!-- Quick nav -->
        <div
          class="rounded-xl p-4 text-xs"
          style="background:var(--background-card);border:1px solid var(--border);"
        >
          <div class="sec-hd mb-3">
            <span class="text-sm font-bold text-foreground">相关专题</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {tags?.map(tag => (
              <a
                href={`/tags/${slugifyStr(tag)}`}
                class="ctag hover:opacity-80 focus-outline"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>

  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /* ===== Reading progress bar ===== */
  (function() {
    const bar = document.createElement("div");
    bar.id = "read-progress";
    bar.style.cssText = "position:fixed;top:0;left:0;z-index:100;height:2px;width:0;background:var(--accent);transition:width 0.1s linear;pointer-events:none;";
    document.body.appendChild(bar);

    document.addEventListener("scroll", () => {
      const el = document.documentElement;
      const scrolled = (el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100;
      bar.style.width = Math.min(scrolled, 100) + "%";
    });
  })();

  /* ===== Table of contents generator ===== */
  (function() {
    const tocNav = document.getElementById("toc-nav");
    if (!tocNav) return;

    const headings = Array.from(document.querySelectorAll("#article h2, #article h3"));
    if (headings.length === 0) {
      tocNav.innerHTML = '<p style="color:var(--foreground-muted);" class="text-xs">本文暂无目录</p>';
      return;
    }

    tocNav.innerHTML = "";
    headings.forEach((h, i) => {
      if (!h.id) h.id = `heading-${i}`;
      const link = document.createElement("a");
      link.href = `#${h.id}`;
      link.textContent = h.textContent?.replace(/#$/, "") ?? "";
      link.className = [
        "block py-0.5 transition-colors hover:text-accent focus-outline rounded",
        h.tagName === "H3" ? "pl-3 text-[11px] opacity-80" : "font-medium",
      ].join(" ");
      link.style.color = "var(--foreground-muted)";
      link.addEventListener("click", e => {
        e.preventDefault();
        document.getElementById(h.id)?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
      tocNav.appendChild(link);
    });

    // Highlight active heading on scroll
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          const link = tocNav.querySelector(`a[href="#${entry.target.id}"]`) as HTMLAnchorElement;
          if (!link) return;
          if (entry.isIntersecting) {
            tocNav.querySelectorAll("a").forEach(a => { (a as HTMLAnchorElement).style.color = "var(--foreground-muted)"; });
            link.style.color = "var(--accent)";
          }
        });
      },
      { rootMargin: "-20% 0px -70% 0px" }
    );

    headings.forEach(h => observer.observe(h));
  })();

  /* ===== Heading anchor links ===== */
  (function() {
    const headings = Array.from(document.querySelectorAll("#article h2, #article h3, #article h4"));
    headings.forEach(h => {
      h.classList.add("group");
      const a = document.createElement("a");
      a.className = "ml-2 opacity-0 group-hover:opacity-60 no-underline transition-opacity text-accent";
      a.href = "#" + h.id;
      a.innerHTML = "#";
      a.setAttribute("aria-hidden", "true");
      h.appendChild(a);
    });
  })();

  /* ===== Copy code button ===== */
  (function() {
    document.querySelectorAll("pre").forEach(pre => {
      const btn = document.createElement("button");
      btn.textContent = "复制";
      btn.className = "copy-code absolute end-3 -top-3 rounded px-2 py-0.5 text-xs font-medium border transition-colors";
      btn.style.cssText = "background:var(--background-elevated);border-color:var(--border);color:var(--foreground-muted);";
      pre.style.position = "relative";
      pre.appendChild(btn);
      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code")?.innerText ?? "";
        await navigator.clipboard.writeText(code);
        btn.textContent = "已复制!";
        setTimeout(() => { btn.textContent = "复制"; }, 1500);
      });
    });
  })();

  /* Scroll to top on page transition */
  document.addEventListener("astro:after-swap", () => window.scrollTo({ top: 0, behavior: "instant" }));
</script>
