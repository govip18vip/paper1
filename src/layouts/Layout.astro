---
// src/layouts/Layout.astro
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config";
import { getLang, hreflangLinks, HTML_LANG, UI } from "@/i18n/ui";
import MobileBottomNav from "@/components/MobileBottomNav.astro";
import StickyNav from "@/components/StickyNav.astro";
import CookieConsent from "@/components/CookieConsent.astro";
import "@/styles/global.css";
import "../styles/mobile-fixes.css";

const lang = getLang(Astro.url);
const alternates = hreflangLinks(Astro.url);

const translationsJSON = JSON.stringify(
  Object.fromEntries(Object.entries(UI).map(([l, dict]) => [l, dict]))
);

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  paginationPrev?: string;
  paginationNext?: string;
  /** Article-only meta (only emitted if ogType === "article") */
  articleTags?: string[];
  articleSection?: string;
  articleAuthorUrl?: string;
  /** Twitter creator handle (e.g. "@tanfyoo"). Falls back to SITE.twitter handle. */
  twitterCreator?: string;
  /** If true, emit robots=noindex,nofollow (e.g. for subscription confirmation pages). */
  noindex?: boolean;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  keywords,
  description = UI[lang]?.["site.desc"] ?? SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  ogType = "website",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  paginationPrev,
  paginationNext,
  articleTags = [],
  articleSection,
  articleAuthorUrl,
  twitterCreator,
  noindex = false,
} = Astro.props;

// Derive default twitter handle from SITE.twitter, e.g. https://x.com/tanfyoo → @tanfyoo
const twitterHandle = (() => {
  if (twitterCreator) return twitterCreator.startsWith("@") ? twitterCreator : "@" + twitterCreator;
  const m = SITE.twitter?.match(/\/([A-Za-z0-9_]+)\/?$/);
  return m ? "@" + m[1] : undefined;
})();

const socialImageURL = new URL(ogImage, Astro.url);
---

<!doctype html>
<html
  dir="ltr"
  lang={HTML_LANG[lang]}
  class={scrollSmooth ? "scroll-smooth" : ""}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} (中文)`} href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} (English)`} href="/en/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} (繁體)`} href="/zh-tw/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} (Español)`} href="/es/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} (Português)`} href="/pt/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />

    <!-- Preconnect to critical third-party origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://api.coingecko.com" />
    <link rel="dns-prefetch" href="https://orbit.biyijia.com" />

    <!-- Editorial type system: Fraunces (display serif) + IBM Plex Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,700;1,9..144,800&family=IBM+Plex+Mono:wght@500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,700;1,9..144,800&family=IBM+Plex+Mono:wght@500;600&display=swap" />
    </noscript>

    <!-- hreflang alternates -->
    {alternates.map(a => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <!-- x-default 固定指向根域名（中文主站），告知 Google 默认版本 -->
    <link rel="alternate" hreflang="x-default" href={Astro.url.origin + "/"} />

    <!-- Search engine verification -->
    {SITE.googleSiteVerification && <meta name="google-site-verification" content={SITE.googleSiteVerification} />}
    {SITE.bingSiteVerification && <meta name="msvalidate.01" content={SITE.bingSiteVerification} />}
    {SITE.baiduSiteVerification && <meta name="baidu-site-verification" content={SITE.baiduSiteVerification} />}
    {SITE.yandexSiteVerification && <meta name="yandex-verification" content={SITE.yandexSiteVerification} />}

    <!-- SEO meta -->
    <title>{title.includes(SITE.title) ? title : `${title} | ${SITE.title}`}</title>
    <meta name="title"       content={title.includes(SITE.title) ? title : `${title} | ${SITE.title}`} />
    <meta name="description" content={description} data-i18n="site.desc" />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author"      content={author} />
    <link rel="sitemap"      href="/sitemap-index.xml" />

    <!-- Pagination -->
    {paginationPrev && <link rel="prev" href={paginationPrev} />}
    {paginationNext && <link rel="next" href={paginationNext} />}

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:image"       content={socialImageURL} />
    <meta property="og:locale"      content={lang.replace("-", "_")} />

    <!-- Twitter -->
    <meta property="twitter:card"        content="summary_large_image" />
    <meta property="twitter:title"       content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image"       content={socialImageURL} />
    {twitterHandle && <meta property="twitter:site"    content={twitterHandle} />}
    {twitterHandle && <meta property="twitter:creator" content={twitterHandle} />}

    <!-- Article meta (only for ogType === "article") -->
    {pubDatetime && <meta property="article:published_time" content={pubDatetime.toISOString()} />}
    {modDatetime  && <meta property="article:modified_time"  content={modDatetime.toISOString()} />}
    {ogType === "article" && (
      <>
        <meta property="article:author" content={articleAuthorUrl ?? author} />
        {articleSection && <meta property="article:section" content={articleSection} />}
        {articleTags.slice(0, 6).map(tag => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- 预注入翻译字典（防止 FOUC）-->
    <script is:inline define:vars={{ translationsJSON, defaultLang: lang }}>
      try {
        window.__i18nDict = JSON.parse(translationsJSON);
        window.__i18nDefault = defaultLang;
      } catch(e) {}
    </script>

    <!-- 主题初始化（必须内联，防止深色模式闪烁）-->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem("theme");
        var dark = stored === "dark" ||
          (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.firstElementChild?.setAttribute("data-theme", dark ? "dark" : "light");
        window.theme = { themeValue: dark ? "dark" : "light" };
      })();
    </script>

    <meta name="theme-color" content="#f7931a" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0d0e14" media="(prefers-color-scheme: dark)" />
    <ClientRouter />

    <!-- Global JSON-LD: Organization + WebSite + WebPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${Astro.url.origin}/#organization`,
          "name": SITE.title,
          "url": SITE.website,
          "logo": {
            "@type": "ImageObject",
            "@id": `${Astro.url.origin}/#logo`,
            "url": `${Astro.url.origin}/favicon.svg`,
            "contentUrl": `${Astro.url.origin}/favicon.svg`,
            "width": 64,
            "height": 64,
            "caption": SITE.title,
          },
          "sameAs": [SITE.twitter, SITE.telegram].filter(Boolean),
          "description": SITE.desc,
        },
        {
          "@type": "WebSite",
          "@id": `${Astro.url.origin}/#website`,
          "url": `${Astro.url.origin}/`,
          "name": SITE.title,
          "description": SITE.desc,
          "publisher": { "@id": `${Astro.url.origin}/#organization` },
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": `${Astro.url.origin}/search?q={search_term_string}`,
            },
            "query-input": "required name=search_term_string",
          },
          "inLanguage": alternates.map(a => a.lang),
        },
        {
          "@type": "WebPage",
          "@id": `${Astro.url.origin}${Astro.url.pathname}#webpage`,
          "url": `${Astro.url.origin}${Astro.url.pathname}`,
          "isPartOf": { "@id": `${Astro.url.origin}/#website` },
          "about": { "@id": `${Astro.url.origin}/#organization` },
          "inLanguage": HTML_LANG[lang],
          ...(pubDatetime && { "datePublished": pubDatetime.toISOString() }),
          ...(modDatetime && { "dateModified": modDatetime.toISOString() }),
        },
      ],
    })} />

    <!-- Analytics: Plausible -->
    {SITE.plausibleDomain && (
      <script defer data-domain={SITE.plausibleDomain} src="https://plausible.io/js/script.js" is:inline />
    )}

    <!-- Analytics: Google Analytics 4 (gtag.js) — gated on cookie consent -->
    {import.meta.env.PUBLIC_GA_ID && (
      <Fragment>
        <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
          window.__gaId = gaId;
          if (localStorage.getItem("cookie_consent") === "declined") {
            window["ga-disable-" + gaId] = true;
          }
        </script>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}
          is:inline
        />
        <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, {
            send_page_view: true,
            anonymize_ip: true,
          });
        </script>
      </Fragment>
    )}

    <slot name="head" />
  </head>

  <body>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <!-- aria-live region for global toast announcements (copy success, etc.) -->
    <div id="a11y-live" class="sr-live" aria-live="polite" aria-atomic="true"></div>

    <slot />

    <StickyNav />
    <MobileBottomNav />
    <CookieConsent />

    <script>
      import "@/scripts/theme.ts";
    </script>

    <script>
      import "@/i18n/detect.ts";
    </script>

    <script>
      import "@/scripts/analytics.ts";
    </script>

    <script>
      import "@/scripts/keyboard.ts";
    </script>

  </body>
</html>
