---
// src/layouts/Layout.astro  — PATCH: add these changes to your existing Layout.astro
//
// Changes needed:
//  1. Import hreflangLinks from i18n/ui
//  2. Add <link rel="alternate" hreflang> tags in <head>
//  3. Load detect.ts as a module script (deferred, client-side)
//  4. Pass lang to <html lang="..."> dynamically
//
// ─────────────────────────────────────────────────────────────
// DIFF — what to ADD to your existing Layout.astro:

import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config";
import { getLang, hreflangLinks, HTML_LANG, UI } from "@/i18n/ui";
import "@/styles/global.css";

// Get server-side language (for initial render, prevents flash)
const lang = getLang(Astro.url);
const alternates = hreflangLinks(Astro.url);

// Inline translations JSON — injected into <head> so detect.ts can
// read them synchronously before first paint
const translationsJSON = JSON.stringify(
  Object.fromEntries(
    Object.entries(UI).map(([l, dict]) => [l, dict])
  )
);

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = UI[lang]["site.desc"] ?? SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.url);
---

<!doctype html>
<html
  dir="ltr"
  lang={HTML_LANG[lang]}
  class={scrollSmooth ? "scroll-smooth" : ""}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- ── hreflang alternates (SEO: multilingual) ── -->
    {alternates.map(a => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.url.origin}${Astro.url.pathname}`} />

    <!-- ── Font ── -->
    <Font
      cssVariable="--font-google-sans-code"
      preload={[{ subset: "latin", weight: 400, style: "normal" }]}
    />

    <!-- ── SEO meta ── -->
    <title>{title}</title>
    <meta name="title"       content={title} />
    <meta name="description" content={description} data-i18n="site.desc" />
    <meta name="author"      content={author} />
    <link rel="sitemap"      href="/sitemap-index.xml" />

    <!-- ── Open Graph ── -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:image"       content={socialImageURL} />
    <meta property="og:locale"      content={lang.replace("-", "_")} />

    <!-- ── Twitter ── -->
    <meta property="twitter:card"        content="summary_large_image" />
    <meta property="twitter:title"       content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image"       content={socialImageURL} />

    <!-- Article dates -->
    {pubDatetime && <meta property="article:published_time" content={pubDatetime.toISOString()} />}
    {modDatetime  && <meta property="article:modified_time"  content={modDatetime.toISOString()} />}

    <!-- ── Inline translations (for detect.ts to use synchronously) ── -->
    <!-- This prevents FOUC (Flash of Untranslated Content) -->
    <script is:inline define:vars={{ translationsJSON, defaultLang: lang }}>
      // Pre-seed translations into window so detect.ts can use immediately
      try {
        window.__i18nDict = JSON.parse(translationsJSON);
        window.__i18nDefault = defaultLang;
      } catch(e) {}
    </script>

    <!-- ── Inline theme script (no FOUC) ── -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem("theme");
        const dark = stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.firstElementChild?.setAttribute("data-theme", dark ? "dark" : "light");
        window.theme = { themeValue: dark ? "dark" : "light" };
      })();
    </script>

    <meta name="theme-color" content="" />
    <ClientRouter />

    <!-- hreflang JSON-LD for language-aware AI engines (GEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": `${Astro.url.origin}${Astro.url.pathname}`,
      "url": `${Astro.url.origin}${Astro.url.pathname}`,
      "inLanguage": alternates.map(a => a.lang),
      "availableLanguage": Object.entries(UI).map(([l]) => ({
        "@type": "Language",
        "name": l,
      })),
    })} />

    <slot name="head" />
  </head>

  <body>
    <slot />

    <!-- Load theme script -->
    <script src="../scripts/theme.ts"></script>

    <!-- Load i18n detection engine — AFTER body so DOM is available -->
    <!-- type="module" ensures it runs after HTML is parsed -->
    <script type="module" src="../i18n/detect.ts"></script>
  </body>
</html>
