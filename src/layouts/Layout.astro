---
// src/layouts/Layout.astro
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config";
import { getLang, hreflangLinks, HTML_LANG, UI } from "@/i18n/ui";
import "@/styles/global.css";
import "../styles/mobile-fixes.css";

const lang = getLang(Astro.url);
const alternates = hreflangLinks(Astro.url);

const translationsJSON = JSON.stringify(
  Object.fromEntries(Object.entries(UI).map(([l, dict]) => [l, dict]))
);

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  paginationPrev?: string;
  paginationNext?: string;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = UI[lang]?.["site.desc"] ?? SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  ogType = "website",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  paginationPrev,
  paginationNext,
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.url);
---

<!doctype html>
<html
  dir="ltr"
  lang={HTML_LANG[lang]}
  class={scrollSmooth ? "scroll-smooth" : ""}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- hreflang alternates -->
    {alternates.map(a => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.url.origin}${Astro.url.pathname}`} />

    <!-- Search engine verification -->
    {SITE.googleSiteVerification && <meta name="google-site-verification" content={SITE.googleSiteVerification} />}
    {SITE.bingSiteVerification && <meta name="msvalidate.01" content={SITE.bingSiteVerification} />}
    {SITE.baiduSiteVerification && <meta name="baidu-site-verification" content={SITE.baiduSiteVerification} />}
    {SITE.yandexSiteVerification && <meta name="yandex-verification" content={SITE.yandexSiteVerification} />}

    <!-- SEO meta -->
    <title>{title}</title>
    <meta name="title"       content={title} />
    <meta name="description" content={description} data-i18n="site.desc" />
    <meta name="author"      content={author} />
    <link rel="sitemap"      href="/sitemap-index.xml" />

    <!-- Pagination -->
    {paginationPrev && <link rel="prev" href={paginationPrev} />}
    {paginationNext && <link rel="next" href={paginationNext} />}

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:image"       content={socialImageURL} />
    <meta property="og:locale"      content={lang.replace("-", "_")} />

    <!-- Twitter -->
    <meta property="twitter:card"        content="summary_large_image" />
    <meta property="twitter:title"       content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image"       content={socialImageURL} />

    <!-- Article dates -->
    {pubDatetime && <meta property="article:published_time" content={pubDatetime.toISOString()} />}
    {modDatetime  && <meta property="article:modified_time"  content={modDatetime.toISOString()} />}

    <!-- 预注入翻译字典（防止 FOUC）-->
    <script is:inline define:vars={{ translationsJSON, defaultLang: lang }}>
      try {
        window.__i18nDict = JSON.parse(translationsJSON);
        window.__i18nDefault = defaultLang;
      } catch(e) {}
    </script>

    <!-- 主题初始化（必须内联，防止深色模式闪烁）-->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem("theme");
        var dark = stored === "dark" ||
          (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.firstElementChild?.setAttribute("data-theme", dark ? "dark" : "light");
        window.theme = { themeValue: dark ? "dark" : "light" };
      })();
    </script>

    <meta name="theme-color" content="" />
    <ClientRouter />

    <!-- hreflang JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": `${Astro.url.origin}${Astro.url.pathname}`,
      "url": `${Astro.url.origin}${Astro.url.pathname}`,
      "inLanguage": alternates.map(a => a.lang),
    })} />

    <!-- Analytics: Plausible -->
    {SITE.plausibleDomain && (
      <script defer data-domain={SITE.plausibleDomain} src="https://plausible.io/js/script.js" is:inline />
    )}

    <!-- Analytics: Google Analytics -->
    {SITE.googleAnalyticsId && (
      <Fragment>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.googleAnalyticsId}`} is:inline />
        <script is:inline define:vars={{ gaId: SITE.googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </Fragment>
    )}

    <slot name="head" />
  </head>

  <body>
    <slot />

    <script>
      import "@/scripts/theme.ts";
    </script>

    <script>
      import "@/i18n/detect.ts";
    </script>

  </body>
</html>
