---
// src/pages/search.astro
// 搜索页增强：热门关键词快捷按钮 + 搜索框突出

import "@pagefind/default-ui/css/ui.css";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import { SITE } from "@/config";
import { getLang, useTranslations, LANG_TO_PATH } from "@/i18n/ui";

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const base = LANG_TO_PATH[lang] ? `/${LANG_TO_PATH[lang]}` : "";
const backUrl = SITE.showBackButton ? `${Astro.url.pathname}` : "/";

const hotKeywords: Record<string, string[]> = {
  "zh-CN": ["比特币", "以太坊", "币安注册", "BTC价格", "ETH教程", "DeFi", "钱包安全", "新手入门", "MetaMask", "Ledger", "减半"],
  "zh-TW": ["比特幣", "以太坊", "幣安註冊", "BTC價格", "ETH教學", "DeFi", "錢包安全", "新手入門", "MetaMask", "Ledger", "減半"],
  "en":    ["Bitcoin", "Ethereum", "Binance", "BTC Price", "ETH Tutorial", "DeFi", "Wallet Security", "Beginner", "MetaMask", "Ledger", "Halving"],
  "es":    ["Bitcoin", "Ethereum", "Binance", "Precio BTC", "Tutorial ETH", "DeFi", "Seguridad Billetera", "Principiante", "MetaMask", "Ledger", "Halving"],
  "pt":    ["Bitcoin", "Ethereum", "Binance", "Preço BTC", "Tutorial ETH", "DeFi", "Segurança Carteira", "Iniciante", "MetaMask", "Ledger", "Halving"],
};
const keywords = hotKeywords[lang] || hotKeywords["zh-CN"];

const quickNav = [
  { labelKey: "search.btc",      href: base + "/price/btc" },
  { labelKey: "search.eth",      href: base + "/price/eth" },
  { labelKey: "search.exchange", href: base + "/tags/docs" },
  { labelKey: "search.beginner", href: base + "/tags/beginner" },
  { labelKey: "search.wallet",   href: base + "/tags/wallet" },
  { labelKey: "search.defi",     href: base + "/tags/defi" },
];
---

<Layout title={`${t("search.title")} | ${SITE.title}`}
  description={t("search.subtitle")}>

  <Header />

  <div class="site-outer">
    <LeftSidebar />

    <main class="main-col" style="padding:20px 16px 40px;" id="main-content">
      <div style="margin-bottom:20px;">
        <h1 style="font-size:22px;font-weight:800;color:var(--fg);margin:0 0 6px;">{t("search.title")}</h1>
        <p style="font-size:13px;color:var(--fg-muted);margin:0;">{t("search.subtitle")}</p>
      </div>

      <div style="margin-bottom:16px;">
        <div style="font-size:11px;font-weight:700;color:var(--fg-light);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px;">{t("search.hot")}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;" id="hot-keywords">
          {keywords.map(kw => (
            <button
              data-kw={kw}
              class="hot-kw-btn"
            >{kw}</button>
          ))}
        </div>
      </div>

      <div id="pagefind-search" transition:persist data-backurl={backUrl}></div>

      <div id="search-after-cta" style="display:none;margin-top:24px;">
        <BinanceBanner variant="compact" lang={lang} />
      </div>

      <!-- Recommended content when no search is active -->
      <div id="search-recommend" style="margin-top:24px;">
        <div style="font-size:14px;font-weight:700;color:var(--fg);margin-bottom:12px;display:flex;align-items:center;gap:8px;">
          <span style="width:3px;height:16px;background:var(--accent);border-radius:2px;"></span>
          {lang === "en" ? "Popular Content" : lang === "es" ? "Contenido Popular" : lang === "pt" ? "Conteúdo Popular" : "热门内容"}
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">
          {[
            { label: lang === "en" ? "Exchange Rankings" : "交易所排名", href: "/posts/zh-cn/crypto-exchange-ranking-2026-zh-cn", icon: "🏆" },
            { label: lang === "en" ? "Beginner Guide" : "新手入门指南", href: "/posts/zh-cn/crypto-beginner-guide-2026-zh-cn", icon: "📚" },
            { label: lang === "en" ? "Live Prices" : "实时行情", href: "/price", icon: "📊" },
            { label: lang === "en" ? "Fee Calculator" : "手续费计算器", href: "/tools/fee-calculator", icon: "🧮" },
            { label: lang === "en" ? "Fear & Greed" : "恐惧贪婪指数", href: "/fear-greed", icon: "😱" },
            { label: lang === "en" ? "Whale Tracker" : "巨鲸追踪", href: "/tools/whale", icon: "🐋" },
            { label: lang === "en" ? "Portfolio" : "投资组合", href: "/portfolio", icon: "💼" },
            { label: lang === "en" ? "Glossary" : "术语词典", href: "/glossary", icon: "📖" },
          ].map(item => (
            <a href={item.href}
              style="display:flex;align-items:center;gap:8px;padding:12px;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;text-decoration:none;color:var(--fg);font-size:13px;font-weight:500;transition:border-color 0.12s;">
              <span style="font-size:18px;">{item.icon}</span>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </main>

    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{t("search.quicknav")}</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {quickNav.map(item => (
            <a href={item.href} style="display:block;padding:7px 10px;background:var(--bg-elevated);border-radius:5px;text-decoration:none;color:var(--fg);font-size:13px;transition:background 0.12s;"
              onmouseover="this.style.background='var(--nav-active-bg)';this.style.color='var(--accent)';"
              onmouseout="this.style.background='var(--bg-elevated)';this.style.color='var(--fg)';">
              {t(item.labelKey)}
            </a>
          ))}
        </div>
      </div>
      <div class="rsidebar-section">
        <BinanceBanner variant="compact" lang={lang} />
      </div>
    </aside>
  </div>

  <Footer />
</Layout>

<style>
.hot-kw-btn {
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 12.5px;
  font-weight: 500;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--fg-muted);
  cursor: pointer;
  transition: all 0.12s;
}
.hot-kw-btn:hover,
.hot-kw-btn.active {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--tag-orange-bg);
}

#pagefind-search {
  --pagefind-ui-font: var(--font-app);
  --pagefind-ui-text: var(--foreground);
  --pagefind-ui-background: var(--background);
  --pagefind-ui-border: var(--border);
  --pagefind-ui-primary: var(--accent);
  --pagefind-ui-tag: var(--background);
  --pagefind-ui-border-radius: 0.375rem;
  --pagefind-ui-border-width: 1px;
  --pagefind-ui-image-border-radius: 8px;
  --pagefind-ui-image-box-ratio: 3 / 2;
}
#pagefind-search form::before { background-color: var(--foreground); }
#pagefind-search input { font-weight: 400; border: 1px solid var(--border); }
#pagefind-search input:focus-visible { outline: 1px solid var(--accent); }
#pagefind-search .pagefind-ui__result-title a {
  color: var(--accent);
  text-decoration-style: dashed;
  text-underline-offset: 4px;
}
#pagefind-search .pagefind-ui__result:last-of-type { border-bottom: 0; }
</style>

<script>
  let pagefindInstance: any = null;

  function initSearch() {
    const pageFindSearch = document.querySelector("#pagefind-search");
    if (!pageFindSearch) return;

    const params = new URLSearchParams(window.location.search);
    const onIdle = (window as any).requestIdleCallback || ((cb: any) => setTimeout(cb, 1));

    onIdle(async () => {
      // @ts-expect-error
      const { PagefindUI } = await import("@pagefind/default-ui");

      if (import.meta.env.DEV) {
        pageFindSearch.innerHTML = `
          <div style="background:var(--bg-elevated);border-radius:6px;padding:12px 16px;margin-bottom:12px;font-size:13px;color:var(--fg-muted);">
            <strong>DEV:</strong> Run <code style="background:var(--bg-card);padding:2px 6px;border-radius:3px;">pnpm run build</code> first for search to work.
          </div>`;
      }

      pagefindInstance = new PagefindUI({
        element: "#pagefind-search",
        showImages: true,
        showSubResults: true,
        showEmptyFilters: false,
        processTerm: function (term: string) {
          params.set("q", term);
          history.replaceState(history.state, "", "?" + params.toString());
          const backUrl = (pageFindSearch as HTMLElement)?.dataset?.backurl;
          if (backUrl) sessionStorage.setItem("backUrl", backUrl + "?" + params.toString());

          // 有搜索词时显示广告位，隐藏推荐内容
          const cta = document.getElementById("search-after-cta");
          const rec = document.getElementById("search-recommend");
          if (cta) cta.style.display = term.trim() ? "block" : "none";
          if (rec) rec.style.display = term.trim() ? "none" : "block";

          return term;
        },
      });

      // 热门关键词点击
      document.querySelectorAll<HTMLButtonElement>(".hot-kw-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          const kw = btn.dataset.kw || "";
          // 激活按钮高亮
          document.querySelectorAll(".hot-kw-btn").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          // 触发搜索
          const input = document.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
          if (input) {
            input.value = kw;
            input.dispatchEvent(new Event("input", { bubbles: true }));
          }
          if (pagefindInstance) pagefindInstance.triggerSearch(kw);
        });
      });

      const query = params.get("q");
      if (query) pagefindInstance.triggerSearch(query);

      // 清空重置
      const searchInput = document.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      const clearBtn = document.querySelector(".pagefind-ui__search-clear");

      function resetParam(e: Event) {
        if ((e.target as HTMLInputElement)?.value?.trim() === "") {
          history.replaceState(history.state, "", window.location.pathname);
          document.querySelectorAll(".hot-kw-btn").forEach(b => b.classList.remove("active"));
          const cta = document.getElementById("search-after-cta");
          if (cta) cta.style.display = "none";
        }
      }
      searchInput?.addEventListener("input", resetParam);
      clearBtn?.addEventListener("click", resetParam);
    });
  }

  document.addEventListener("astro:after-swap", () => {
    const pf = document.querySelector("#pagefind-search");
    if (pf && pf.querySelector("form")) return;
    initSearch();
  });
  initSearch();
</script>
