---
// src/pages/go/binance.astro
// 高转化率币安专属落地页 /go/binance
// 邀请码 B2345 · 大陆APK + 国际APK + 网页注册

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const REF   = "B2345";
const WEB   = `https://www.binance.com/en/register?ref=${REF}`;
const APK_CN  = "https://basebiance.com/binanceapkcn";
const APK_EN  = "https://basebiance.com/binanceapken/";
const LOGO  = "https://basebiance.com/content/images/2025/04/1HH5201407.png";

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "币安注册下载 — 邀请码B2345享最高折扣",
  description: "通过邀请码B2345注册币安，享受平台最高手续费折扣。提供大陆版APK、国际版APK及网页版注册入口。",
  url: `${SITE.website}go/binance`,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "首页", item: SITE.website },
      { "@type": "ListItem", position: 2, name: "币安注册", item: `${SITE.website}go/binance` },
    ],
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "币安邀请码B2345有什么优惠？",
      acceptedAnswer: { "@type": "Answer",
        text: "使用邀请码B2345注册币安，可享受平台最高可用的手续费折扣，现货交易手续费最低可至0.075%，比普通注册优惠更多。" },
    },
    {
      "@type": "Question",
      name: "国内可以下载币安APP吗？",
      acceptedAnswer: { "@type": "Answer",
        text: "可以通过本页提供的大陆版APK下载地址直接安装，无需应用商店，支持安卓手机。iOS用户需要海外Apple ID下载。" },
    },
    {
      "@type": "Question",
      name: "币安注册需要什么？",
      acceptedAnswer: { "@type": "Answer",
        text: "需要有效邮箱或手机号，以及政府颁发的身份证明（身份证或护照）完成KYC认证。完成认证后即可购买加密货币。" },
    },
    {
      "@type": "Question",
      name: "币安安全吗？",
      acceptedAnswer: { "@type": "Answer",
        text: "币安是全球交易量最大的交易所，拥有安全资产储备基金(SAFU)，并持有多国合规牌照。建议开启双重验证(2FA)提升账户安全性。" },
    },
  ],
};
---

<Layout
  title="币安注册下载 — 邀请码B2345专属折扣 | CryptoNews"
  description="通过邀请码B2345注册币安，享受最高手续费折扣。提供大陆版APK直接下载，免翻墙安装，3步完成注册开始交易。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <!-- 独立落地页：不用 site-outer 三栏，用全宽单栏 -->
  <main id="main-content" style="max-width:800px;margin:0 auto;padding:0 16px 60px;">

    <!-- ══ HERO ══ -->
    <section style="text-align:center;padding:40px 0 32px;">
      <!-- Logo + 品牌 -->
      <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:20px;">
        <img
          src={LOGO}
          alt="币安 Binance Logo"
          width="40" height="40"
          style="border-radius:8px;flex-shrink:0;"
          loading="eager"
        />
        <span style="font-size:26px;font-weight:900;color:var(--fg);letter-spacing:-0.02em;">Binance 币安</span>
      </div>

      <h1 style="font-size:clamp(22px,4vw,34px);font-weight:900;color:var(--fg);line-height:1.2;margin:0 0 12px;letter-spacing:-0.02em;">
        注册领专属优惠<br/>
        <span style="color:#F0B90B;">邀请码 B2345</span>
      </h1>
      <p style="font-size:16px;color:var(--fg-muted);line-height:1.6;margin:0 auto 28px;max-width:520px;">
        全球最大加密货币交易所，使用邀请码 <strong style="color:var(--fg);">B2345</strong> 注册可享受平台<strong style="color:var(--fg);">最高手续费折扣</strong>，现货交易手续费低至 0.075%
      </p>

      <!-- 邀请码醒目展示 -->
      <div style="display:inline-flex;align-items:center;gap:10px;background:rgba(240,185,11,0.1);border:2px dashed rgba(240,185,11,0.5);border-radius:10px;padding:12px 28px;margin-bottom:32px;">
        <span style="font-size:13px;color:var(--fg-muted);">专属邀请码</span>
        <span id="ref-code" style="font-size:26px;font-weight:900;color:#F0B90B;font-family:monospace;letter-spacing:0.1em;">{REF}</span>
        <button
          onclick="copyCode()"
          style="padding:5px 12px;background:rgba(240,185,11,0.2);border:1px solid rgba(240,185,11,0.4);border-radius:5px;font-size:12px;color:#F0B90B;cursor:pointer;font-weight:600;transition:all 0.12s;"
          id="copy-btn"
        >复制</button>
      </div>

      <!-- ══ 3个下载/注册按钮 ══ -->
      <div style="display:flex;flex-direction:column;gap:12px;max-width:420px;margin:0 auto;">

        <!-- 大陆APK（主推） -->
        <a href={APK_CN} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="display:flex;align-items:center;justify-content:space-between;padding:16px 22px;background:#F0B90B;color:#1a1200;border-radius:10px;text-decoration:none;font-weight:700;font-size:15px;transition:all 0.12s;box-shadow:0 4px 14px rgba(240,185,11,0.35);"
          onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 20px rgba(240,185,11,0.4)'"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 14px rgba(240,185,11,0.35)'"
        >
          <div style="display:flex;align-items:center;gap:10px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.39-1.32 2.76-2.54 3.99zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            <div style="text-align:left;">
              <div style="font-size:11px;opacity:0.75;font-weight:500;">安卓 APK · 国内直接下载</div>
              <div>大陆版 下载安装</div>
            </div>
          </div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- 国际APK -->
        <a href={APK_EN} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="display:flex;align-items:center;justify-content:space-between;padding:16px 22px;background:var(--bg-card);color:var(--fg);border:2px solid var(--border);border-radius:10px;text-decoration:none;font-weight:700;font-size:15px;transition:all 0.12s;"
          onmouseover="this.style.borderColor='#F0B90B';this.style.color='#F0B90B';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--fg)';this.style.transform='translateY(0)'"
        >
          <div style="display:flex;align-items:center;gap:10px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.39-1.32 2.76-2.54 3.99zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            <div style="text-align:left;">
              <div style="font-size:11px;opacity:0.6;font-weight:500;">安卓 APK · 海外/台港澳</div>
              <div>国际版 下载安装</div>
            </div>
          </div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- 网页注册 -->
        <a href={WEB} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="display:flex;align-items:center;justify-content:center;gap:8px;padding:13px 22px;background:transparent;color:var(--fg-muted);border:1px solid var(--border);border-radius:10px;text-decoration:none;font-size:14px;transition:all 0.12s;"
          onmouseover="this.style.color='var(--fg)';this.style.borderColor='var(--fg-muted)'"
          onmouseout="this.style.color='var(--fg-muted)';this.style.borderColor='var(--border)'"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          网页版注册（邀请码已自动填入）
        </a>
      </div>

      <p style="font-size:11px;color:var(--fg-light);margin:14px 0 0;line-height:1.5;">
        ⚠️ 投资有风险，加密货币价格波动较大，请谨慎决策。本站与币安存在联盟合作关系。
      </p>
    </section>

    <!-- ══ 优惠说明 ══ -->
    <section style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:28px;margin-bottom:24px;">
      <h2 style="font-size:17px;font-weight:700;color:var(--fg);margin:0 0 20px;display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:20px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
        邀请码 B2345 专属权益
      </h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        {[
          { icon: "💰", title: "最高手续费折扣", desc: "现货交易手续费低至 0.075%（标准0.1%）" },
          { icon: "🔒", title: "SAFU 安全基金", desc: "10亿美元用户资产保护基金" },
          { icon: "📊", title: "350+ 交易对", desc: "BTC、ETH、BNB等主流币全覆盖" },
          { icon: "🌍", title: "全球最大交易所", desc: "日均交易量超700亿美元，流动性最强" },
          { icon: "📱", title: "中文界面", desc: "App、网页全中文支持，客服有中文" },
          { icon: "⚡", title: "支持法币出入金", desc: "支持人民币、港币、台币多种方式" },
        ].map(item => (
          <div style="display:flex;gap:12px;align-items:flex-start;">
            <span style="font-size:20px;flex-shrink:0;line-height:1.2;">{item.icon}</span>
            <div>
              <div style="font-size:13px;font-weight:700;color:var(--fg);margin-bottom:3px;">{item.title}</div>
              <div style="font-size:12px;color:var(--fg-muted);line-height:1.5;">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ══ 注册步骤 ══ -->
    <section style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:28px;margin-bottom:24px;">
      <h2 style="font-size:17px;font-weight:700;color:var(--fg);margin:0 0 20px;display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:20px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
        3步完成注册，最快5分钟开始交易
      </h2>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { step: "1", title: "下载APP或打开网页", desc: "选择大陆版APK（无需翻墙）或网页版，点击上方按钮直接下载/注册。" },
          { step: "2", title: "填写邮箱和密码", desc: "用邮箱注册，邀请码 B2345 已自动填入（网页版）。设置强密码，开启谷歌2FA验证码。" },
          { step: "3", title: "完成实名认证(KYC)", desc: "上传身份证正反面 + 人脸识别，通常5分钟内审核通过，完成后可购买加密货币。" },
        ].map((item, i) => (
          <div style={`display:flex;gap:16px;align-items:flex-start;padding:16px 0;${i < 2 ? "border-bottom:1px solid var(--border-subtle);" : ""}`}>
            <div style="width:36px;height:36px;border-radius:50%;background:#F0B90B;color:#1a1200;font-size:16px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{item.step}</div>
            <div>
              <div style="font-size:14px;font-weight:700;color:var(--fg);margin-bottom:4px;">{item.title}</div>
              <div style="font-size:13px;color:var(--fg-muted);line-height:1.6;">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
      <!-- 底部CTA -->
      <a href={APK_CN} target="_blank" rel="noopener noreferrer nofollow sponsored"
        style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:20px;padding:14px;background:#F0B90B;color:#1a1200;border-radius:8px;text-decoration:none;font-size:15px;font-weight:700;transition:all 0.12s;"
        onmouseover="this.style.background='#ffd700'" onmouseout="this.style.background='#F0B90B'"
      >
        <img src={LOGO} alt="Binance" width="22" height="22" style="border-radius:4px;" />
        立即下载币安APP（大陆版）
      </a>
    </section>

    <!-- ══ FAQ ══ -->
    <section style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:28px;margin-bottom:24px;"
      itemscope itemtype="https://schema.org/FAQPage">
      <h2 style="font-size:17px;font-weight:700;color:var(--fg);margin:0 0 16px;display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:20px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
        常见问题
      </h2>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {[
          ["邀请码B2345有什么优惠？", "使用邀请码B2345注册，可享受平台最高可用的手续费折扣，现货交易手续费最低可至0.075%，比普通注册节省更多交易成本。"],
          ["国内可以下载币安APP吗？", "可以！本页提供大陆版APK直接下载，安卓手机无需应用商店，点击「大陆版下载安装」按钮即可。iOS用户需要海外Apple ID从App Store搜索「Binance」下载。"],
          ["国际版和大陆版APK有什么区别？", "功能基本相同，大陆版针对国内网络环境优化，访问更稳定；国际版适合台湾、香港、东南亚及海外用户。"],
          ["注册需要翻墙吗？", "APK下载不需要翻墙。注册和使用币安时，网络访问可能需要工具，建议使用大陆版APK，针对国内网络有优化。"],
          ["手续费折扣怎么使用？", "注册时确保邀请码字段填写了B2345即可，折扣自动生效。账户内持有BNB时选择用BNB抵扣手续费可进一步降低费率。"],
        ].map(([q, a]) => (
          <details itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"
            style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;">
            <summary itemprop="name" style="font-size:14px;font-weight:600;color:var(--fg);list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;">
              <span>{q}</span>
              <span style="color:var(--fg-muted);font-size:20px;flex-shrink:0;transition:transform 0.2s;" class="faq-icon">+</span>
            </summary>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text" style="font-size:13px;color:var(--fg-muted);line-height:1.7;margin:12px 0 0;">{a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- ══ 底部终极CTA ══ -->
    <section style="background:linear-gradient(135deg,#1a1200,#2a1e00);border:1px solid rgba(240,185,11,0.3);border-radius:12px;padding:32px;text-align:center;">
      <img src={LOGO} alt="Binance" width="48" height="48" style="border-radius:10px;margin-bottom:14px;" />
      <h2 style="font-size:20px;font-weight:800;color:#F0B90B;margin:0 0 8px;">现在注册，终身享受折扣</h2>
      <p style="font-size:14px;color:rgba(255,255,255,0.65);margin:0 0 24px;line-height:1.6;">
        邀请码 <strong style="color:#F0B90B;font-family:monospace;font-size:17px;">{REF}</strong> — 注册即锁定最高折扣，永久有效
      </p>
      <div style="display:flex;flex-direction:column;gap:10px;max-width:360px;margin:0 auto;">
        <a href={APK_CN} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="display:flex;align-items:center;justify-content:center;gap:8px;padding:14px;background:#F0B90B;color:#1a1200;border-radius:8px;text-decoration:none;font-size:15px;font-weight:800;transition:all 0.12s;"
          onmouseover="this.style.background='#ffd700'" onmouseout="this.style.background='#F0B90B'"
        >
          📱 大陆版APK下载
        </a>
        <a href={APK_EN} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="display:flex;align-items:center;justify-content:center;gap:8px;padding:12px;background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.85);border:1px solid rgba(255,255,255,0.15);border-radius:8px;text-decoration:none;font-size:14px;font-weight:700;transition:all 0.12s;"
          onmouseover="this.style.background='rgba(255,255,255,0.12)'" onmouseout="this.style.background='rgba(255,255,255,0.08)'"
        >
          📱 国际版APK下载
        </a>
        <a href={WEB} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="display:block;padding:10px;color:rgba(255,255,255,0.4);border:none;background:transparent;text-decoration:none;font-size:13px;transition:color 0.12s;"
          onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.4)'"
        >
          或使用网页版注册 →
        </a>
      </div>
      <p style="font-size:10.5px;color:rgba(255,255,255,0.25);margin:16px 0 0;line-height:1.5;">
        * 本站与币安存在推广合作关系，通过邀请码产生的注册可能为本站带来佣金。投资加密货币风险自负。
      </p>
    </section>

  </main>

  <Footer />
</Layout>

<script is:inline>
// 复制邀请码
function copyCode() {
  navigator.clipboard.writeText("B2345").then(() => {
    const btn = document.getElementById("copy-btn");
    if (!btn) return;
    btn.textContent = "已复制 ✓";
    btn.style.background = "rgba(0,200,150,0.2)";
    btn.style.borderColor = "rgba(0,200,150,0.4)";
    btn.style.color = "#00c896";
    setTimeout(() => {
      btn.textContent = "复制";
      btn.style.background = "rgba(240,185,11,0.2)";
      btn.style.borderColor = "rgba(240,185,11,0.4)";
      btn.style.color = "#F0B90B";
    }, 2000);
  }).catch(() => {});
}

// FAQ +/- 图标切换
document.querySelectorAll("details").forEach(d => {
  const icon = d.querySelector(".faq-icon");
  if (!icon) return;
  d.addEventListener("toggle", () => {
    icon.textContent = d.open ? "−" : "+";
  });
});
</script>
