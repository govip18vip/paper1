---
// src/pages/archives/[slug].astro
// Ghost 文章详情 — SSR（Ghost发布即可见，Vercel ISR缓存5分钟）
// 加固版：Ghost 不可用时优雅降级
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import MobileTOC from "@/components/MobileTOC.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import { SITE } from "@/config";
import { getLang, useTranslations, type Lang } from "@/i18n/ui";
import { getPostBySlug, getRelatedPosts, getTranslationSiblings, type GhostPost } from "@/utils/ghost";
import { slugifyStr } from "@/utils/slugify";

// ── 获取文章 ──────────────────────────────────────────────
const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

let post: GhostPost | null = null;
try {
  post = await getPostBySlug(slug);
} catch (e) {
  console.error("Ghost error:", e);
}
if (!post) return Astro.redirect("/404");

const lang: Lang = post.lang || "zh-CN";
const t = useTranslations(lang);

// ── 相关文章 & 翻译（容错）──────────────────────────────
let related: GhostPost[] = [];
let translations: GhostPost[] = [];
try { related = await getRelatedPosts(post, 6); } catch {}
try { if (post.translationKey) translations = await getTranslationSiblings(post.translationKey); } catch {}

// ── 标签/元数据 ──────────────────────────────────────────
const publicTags = (post.tags || []).filter(t => t.visibility === "public");
const pageTitle = post.meta_title || `${post.title} | ${SITE.title}`;
const description = post.meta_description || post.custom_excerpt || post.excerpt || "";
const ogImage = post.og_image || post.feature_image || undefined;

// ── HTML 处理：给 heading 加 id ──────────────────────────
let counter = 0;
const processedHtml = (post.html || "").replace(
  /<h([23])([^>]*)>(.*?)<\/h\1>/gi,
  (match: string, level: string, attrs: string, content: string) => {
    if (attrs.includes('id="')) return match;
    const text = content.replace(/<[^>]*>/g, "").trim();
    const id = slugifyStr(text) || `h-${counter++}`;
    return `<h${level}${attrs} id="${id}">${content}</h${level}>`;
  }
);

// ── 提取 TOC headings ────────────────────────────────────
const tocHeadings: Array<{depth:number;slug:string;text:string}> = [];
const hRe = /<h([23])[^>]*id="([^"]*)"[^>]*>(.*?)<\/h[23]>/gi;
let m;
while ((m = hRe.exec(processedHtml)) !== null) {
  tocHeadings.push({ depth: +m[1], slug: m[2], text: m[3].replace(/<[^>]*>/g, "") });
}

// ── 多语言 labels ────────────────────────────────────────
const L: Record<string, Record<Lang, string>> = {
  related: { "zh-CN":"相关文章","zh-TW":"相關文章",en:"Related",es:"Relacionados",pt:"Relacionados" },
  trans:   { "zh-CN":"其他语言版本","zh-TW":"其他語言版本",en:"Other Languages",es:"Otros Idiomas",pt:"Outros Idiomas" },
};
const flags: Record<string, string> = {"zh-CN":"🇨🇳","zh-TW":"🇹🇼","en":"🇺🇸","es":"🇪🇸","pt":"🇧🇷"};
const shortLabel: Record<string, string> = {"zh-CN":"简中","zh-TW":"繁中","en":"EN","es":"ES","pt":"PT"};

// ── Schema.org ───────────────────────────────────────────
const articleSchema = {
  "@context":"https://schema.org","@type":"NewsArticle",
  headline: post.title, description,
  image: ogImage,
  datePublished: post.published_at,
  dateModified: post.updated_at,
  author:{ "@type":"Person", name: post.primary_author?.name || SITE.author },
  publisher:{ "@type":"Organization", name: SITE.title, url: SITE.website },
  mainEntityOfPage: Astro.url.href,
  inLanguage: lang,
};
---

<Layout
  title={pageTitle}
  author={post.primary_author?.name}
  description={description}
  ogImage={ogImage}
  pubDatetime={new Date(post.published_at)}
  modDatetime={new Date(post.updated_at)}
  scrollSmooth
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <main class="main-col post-detail-col" id="main-content">

      <!-- 面包屑 -->
      <nav class="pd-breadcrumb" aria-label="breadcrumb">
        <a href={lang === "zh-CN" ? "/" : `/${lang.toLowerCase()}`}>{t("nav.home")}</a>
        <span aria-hidden="true">›</span>
        <a href="/archives">{t("footer.link.archives")}</a>
        <span aria-hidden="true">›</span>
        <span class="pd-breadcrumb-current">{post.title.length > 30 ? post.title.slice(0,30) + "…" : post.title}</span>
      </nav>

      <div class="pd-layout">
        <div class="pd-article-col">

          {/* Hero */}
          {post.feature_image && (
            <div class="pd-hero-img">
              <img src={post.feature_image} alt={post.title} width="800" height="450" loading="eager" />
            </div>
          )}

          {/* Tags */}
          {publicTags.length > 0 && (
            <div class="pd-tags">
              {publicTags.map(tag => (
                <a href={`/archives?tag=${tag.slug}&lang=${lang}`} class="pd-tag">{tag.name}</a>
              ))}
            </div>
          )}

          {/* Title */}
          <h1 class="pd-title" itemprop="headline">{post.title}</h1>

          {/* 翻译切换 */}
          {translations.length > 1 && (
            <aside class="translation-box">
              <span class="translation-label">{L.trans[lang]}</span>
              <div class="translation-links" role="list">
                {translations.map(tr => (
                  <div role="listitem">
                    {tr.id === post.id ? (
                      <span class="tlang-btn current">{flags[tr.lang||"zh-CN"]||""} {shortLabel[tr.lang||"zh-CN"]||tr.lang}</span>
                    ) : (
                      <a href={`/archives/${tr.slug}`} class="tlang-btn">{flags[tr.lang||"zh-CN"]||""} {shortLabel[tr.lang||"zh-CN"]||tr.lang}</a>
                    )}
                  </div>
                ))}
              </div>
            </aside>
          )}

          {/* Meta */}
          <div class="pd-meta">
            <span class="pd-author">{post.primary_author?.name || SITE.author}</span>
            <Datetime pubDatetime={post.published_at} modDatetime={post.updated_at > post.published_at ? post.updated_at : null} size="sm" />
            {post.reading_time > 0 && <span style="color:var(--fg-light);font-size:12px;">{post.reading_time} min</span>}
          </div>

          {/* Excerpt */}
          {post.custom_excerpt && <p class="pd-description">{post.custom_excerpt}</p>}

          <MobileTOC headings={tocHeadings} />

          {/* ★ 正文 ★ */}
          <article id="article" class="app-prose pd-prose ghost-content" itemprop="articleBody">
            <Fragment set:html={processedHtml} />
          </article>

          <div class="pd-banner-mid"><BinanceBanner variant="mid" lang={lang} /></div>
          <div class="pd-banner-article"><BinanceBanner variant="article" lang={lang} /></div>
          <hr class="pd-divider" />

          {/* 底部标签 + 分享 */}
          <div class="pd-bottom">
            <div class="pd-bottom-tags">
              <ul class="flex flex-wrap gap-2">
                {publicTags.map(tag => <Tag tag={tag.slug} tagName={tag.name} size="sm" />)}
              </ul>
            </div>
            <ShareLinks />
          </div>

          {/* 相关文章 */}
          {related.length > 0 && (
            <section style="margin-top:24px;padding-top:20px;border-top:1px solid var(--border);">
              <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin:0 0 14px;display:flex;align-items:center;gap:8px;">
                <span style="width:3px;height:18px;background:var(--accent);border-radius:2px;display:inline-block;"></span>
                {L.related[lang]}
              </h2>
              {related.map((rp, i) => (
                <a href={`/archives/${rp.slug}`}
                  style={`display:flex;gap:12px;padding:12px 0;text-decoration:none;color:var(--fg);transition:color 0.12s;${i < related.length-1 ? "border-bottom:1px solid var(--border-subtle);" : ""}`}
                  onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--fg)'"
                >
                  {rp.feature_image && <img src={rp.feature_image} alt="" loading="lazy" style="width:80px;height:56px;object-fit:cover;border-radius:0;flex-shrink:0;outline:1px solid var(--border);" />}
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:14px;font-weight:600;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{rp.title}</div>
                    <div style="font-size:11px;color:var(--fg-light);margin-top:4px;">{new Date(rp.published_at).toLocaleDateString()}</div>
                  </div>
                </a>
              ))}
            </section>
          )}
        </div>

        {/* 桌面 TOC */}
        {tocHeadings.length > 2 && (
          <aside class="pd-toc-sidebar">
            <div class="pd-toc-sticky">
              <div class="pd-toc-head"><span>{t("post.toc")}</span></div>
              <nav>
                <ul class="pd-toc-list">
                  {tocHeadings.map(h => (
                    <li class:list={["pd-toc-item", {"pd-toc-h3": h.depth===3}]}>
                      <a href={`#${h.slug}`} class="pd-toc-link">{h.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>
              <div class="pd-toc-banner"><BinanceBanner variant="compact" lang={lang} /></div>
            </div>
          </aside>
        )}
      </div>
    </main>
  </div>

  <BackToTopButton />
  <Footer />
</Layout>

<style>
/* ── Post detail page layout ────────────────────────────── */
.post-detail-col {
  padding-bottom: 40px;
}

/* ── Breadcrumb ─────────────────────────────────────────── */
.pd-breadcrumb {
  padding: 12px 20px 0;
  font-size: 13px;
  color: var(--fg-muted);
  overflow-x: auto;
  white-space: nowrap;
  scrollbar-width: none;
}
.pd-breadcrumb::-webkit-scrollbar { display: none; }
.pd-breadcrumb a {
  color: var(--fg-muted);
  text-decoration: none;
  transition: color 0.12s;
}
.pd-breadcrumb a:hover { color: var(--accent); }
.pd-breadcrumb span { margin: 0 6px; opacity: 0.5; }
.pd-breadcrumb-current { color: var(--fg); }

/* ── Layout: article + TOC sidebar ─────────────────────── */
.pd-layout {
  display: grid;
  grid-template-columns: 1fr 240px;
  gap: 32px;
  padding: 0 20px;
  align-items: start;
}

.pd-article-col {
  min-width: 0;
}

/* ── Hero image ─────────────────────────────────────────── */
.pd-hero-img {
  margin: 16px 0;
  overflow: hidden;
  border: 1px solid var(--border);
}
.pd-hero-img img {
  width: 100%;
  height: auto;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}

/* ── Tags row ───────────────────────────────────────────── */
.pd-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 12px;
}
.pd-tag {
  display: inline-block;
  padding: 3px 10px;
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  background: var(--tag-orange-bg);
  color: var(--tag-orange);
  transition: opacity 0.12s;
}
.pd-tag:hover { opacity: 0.8; }

/* ── Title ──────────────────────────────────────────────── */
.pd-title {
  font-size: clamp(1.4rem, 4vw, 2rem);
  font-weight: 800;
  line-height: 1.3;
  color: var(--fg);
  margin: 0 0 12px;
  word-break: break-word;
  letter-spacing: -0.01em;
}

/* ── Meta row ───────────────────────────────────────────── */
.pd-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12px;
  font-size: 13px;
  color: var(--fg-muted);
  padding-bottom: 14px;
  margin-bottom: 14px;
  border-bottom: 1px solid var(--border);
}
.pd-author {
  font-weight: 600;
  color: var(--fg);
}

/* ── Description ────────────────────────────────────────── */
.pd-description {
  font-size: 15px;
  line-height: 1.65;
  color: var(--fg-muted);
  margin: 0 0 18px;
  padding: 12px 16px;
  background: var(--bg-elevated);
  border-left: 3px solid var(--accent);
}

/* ── Prose overrides ────────────────────────────────────── */
.pd-prose {
  max-width: none;
  padding: 0;
}

/* ── Banners ────────────────────────────────────────────── */
.pd-banner-mid { margin: 24px 0 8px; }
.pd-banner-article { margin: 8px 0 16px; }

/* ── Divider ────────────────────────────────────────────── */
.pd-divider {
  border: none;
  border-top: 1px dashed var(--border);
  margin: 16px 0;
}

/* ── Bottom tags + share ────────────────────────────────── */
.pd-bottom {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  padding-top: 16px;
}
.pd-bottom-tags ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

/* ── Translation box ────────────────────────────────────── */
.translation-box {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  padding: 10px 14px;
  margin-bottom: 14px;
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent-blue, var(--accent));
  font-size: 13px;
}
.translation-label {
  font-weight: 600;
  color: var(--fg-muted);
  white-space: nowrap;
}
.translation-links {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.tlang-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  border: 1px solid var(--border);
  color: var(--fg-muted);
  background: var(--bg-card);
  transition: border-color 0.12s, color 0.12s;
}
.tlang-btn:hover { border-color: var(--accent); color: var(--accent); }
.tlang-btn.current {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--tag-orange-bg);
  cursor: default;
}

/* ── TOC Sidebar (desktop) ──────────────────────────────── */
.pd-toc-sidebar {
  display: block;
}
.pd-toc-sticky {
  position: sticky;
  top: 20px;
  max-height: calc(100vh - 40px);
  overflow-y: auto;
  scrollbar-width: thin;
}
.pd-toc-head {
  font-size: 13px;
  font-weight: 700;
  color: var(--fg-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 10px;
}
.pd-toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.pd-toc-item {
  margin: 0;
}
.pd-toc-h3 {
  padding-left: 14px;
}
.pd-toc-link {
  display: block;
  padding: 5px 0 5px 10px;
  font-size: 13px;
  line-height: 1.5;
  color: var(--fg-muted);
  text-decoration: none;
  transition: color 0.12s;
  border-left: 2px solid transparent;
}
.pd-toc-link:hover,
.pd-toc-link.active {
  color: var(--accent);
  border-left-color: var(--accent);
}
.pd-toc-link.active {
  font-weight: 600;
}
.pd-toc-banner {
  margin-top: 20px;
}

/* ── Ghost content cards ────────────────────────────────── */
.ghost-content :global(.kg-card) { margin: 1.5em 0; }
.ghost-content :global(.kg-image-card img) { max-width:100%;height:auto; }
.ghost-content :global(.kg-bookmark-card) { border:1px solid var(--border);overflow:hidden; }
.ghost-content :global(.kg-gallery-card) { display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:8px; }
.ghost-content :global(figcaption) { text-align:center;font-size:13px;color:var(--fg-muted);margin-top:8px; }
.ghost-content :global(.kg-callout-card) { padding:16px;background:var(--bg-elevated);border-left:3px solid var(--accent); }

/* ── Responsive ─────────────────────────────────────────── */
@media (max-width: 1100px) {
  .pd-toc-sidebar {
    display: none;
  }
  .pd-layout {
    grid-template-columns: 1fr;
    gap: 0;
  }
}

@media (max-width: 768px) {
  .pd-layout {
    padding: 0 14px;
  }
  .pd-breadcrumb {
    padding: 10px 14px 0;
  }
  .pd-title {
    font-size: clamp(1.2rem, 5vw, 1.6rem);
  }
  .pd-hero-img {
    margin: 12px -14px;
    border-left: none;
    border-right: none;
  }
  .pd-description {
    font-size: 14px;
    padding: 10px 14px;
  }
  .pd-meta {
    font-size: 12px;
    gap: 8px;
  }
  .pd-bottom {
    flex-direction: column;
  }
}

@media (max-width: 500px) {
  .pd-layout { padding: 0 10px; }
  .pd-breadcrumb { padding: 8px 10px 0; }
}
</style>

<script>
  // TOC scroll-spy — IntersectionObserver variant
  let tocObserver: IntersectionObserver | null = null;

  function initTocSpy() {
    if (tocObserver) { tocObserver.disconnect(); tocObserver = null; }

    const tocLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>(".pd-toc-link")
    );
    if (!tocLinks.length) return;

    const headingIds = tocLinks
      .map(a => a.getAttribute("href")?.slice(1))
      .filter(Boolean) as string[];
    // IDs in the HTML are URL-encoded (e.g. %E6%A0%B8...) but getElementById
    // expects the decoded string — decode before lookup.
    const headingEls = headingIds
      .map(id => document.getElementById(decodeURIComponent(id)))
      .filter(Boolean) as HTMLElement[];
    if (!headingEls.length) return;

    const visible = new Set<Element>();

    function setActive(el: Element | null) {
      if (!el) return;
      const idx = headingEls.indexOf(el as HTMLElement);
      if (idx < 0) return;
      tocLinks.forEach((link, i) => {
        link.classList.toggle("active", i === idx);
      });
      const activeLink = tocLinks[idx];
      const container = activeLink?.closest<HTMLElement>(".pd-toc-sticky");
      if (activeLink && container) {
        const linkRect = activeLink.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        if (linkRect.top < containerRect.top || linkRect.bottom > containerRect.bottom) {
          activeLink.scrollIntoView({ block: "nearest", behavior: "smooth" });
        }
      }
    }

    tocObserver = new IntersectionObserver(
      entries => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target);
          else visible.delete(e.target);
        }
        if (visible.size) {
          const first = headingEls.find(h => visible.has(h));
          setActive(first ?? null);
        } else {
          const scrollY = window.scrollY + 120;
          let last: HTMLElement | null = null;
          for (const h of headingEls) {
            if (h.getBoundingClientRect().top + window.scrollY <= scrollY) last = h;
            else break;
          }
          setActive(last);
        }
      },
      { rootMargin: "-120px 0px -40% 0px", threshold: 0 }
    );

    headingEls.forEach(el => tocObserver!.observe(el));
  }

  initTocSpy();
  document.addEventListener("astro:after-swap", initTocSpy);
  document.addEventListener("astro:before-swap", () => {
    tocObserver?.disconnect(); tocObserver = null;
  });
</script>
