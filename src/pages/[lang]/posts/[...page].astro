---
// src/pages/[lang]/posts/[...page].astro
// Non-default language article listing: /en/posts/ /zh-tw/posts/ /es/posts/ /pt/posts/
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import { SITE } from "@/config";
import {
  LANGUAGES, DEFAULT_LANG, useTranslations,
  LANG_TO_PATH, type Lang,
} from "@/i18n/ui";
import { filterPostsByLang } from "@/utils/homePage";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const nonDefaultLangs = (Object.keys(LANGUAGES) as Lang[]).filter(
    l => l !== DEFAULT_LANG
  );

  return nonDefaultLangs.flatMap(lang => {
    const langPosts = filterPostsByLang(allPosts, lang);
    return paginate(langPosts, {
      params: { lang: LANG_TO_PATH[lang] },
      props: { lang },
      pageSize: SITE.postPerPage,
    });
  });
}) satisfies GetStaticPaths;

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const { page } = Astro.props;
const base = `/${LANG_TO_PATH[lang]}`;
---

<Layout
  title={`${t("section.all")} | ${t("site.name")}`}
  description={t("site.desc")}
>
  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <div class="main-col" style="padding-bottom:40px;">
      <div style="padding:14px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href={`${base}/`}
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">
          {t("nav.home")}
        </a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">{t("section.all")}</span>
      </div>

      <div style="padding:10px 16px 0;">
        <h1 style="font-size:20px;font-weight:700;color:var(--fg);margin-bottom:4px;">
          {t("section.all")}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);">{t("site.desc.short")}</p>
      </div>

      <div style="margin-top:12px;">
        {page.data.length > 0 ? (
          <div class="alist">
            {page.data.map((data: any) => <Card {...data} size="list" variant="h3" />)}
          </div>
        ) : (
          <div style="padding:60px 16px;text-align:center;color:var(--fg-muted);">
            <p style="font-size:15px;margin-bottom:8px;">📝 No articles in this language yet.</p>
          </div>
        )}
      </div>

      <Pagination {page} {lang} />
    </div>

    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{t("section.tags")}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          {["BTC","ETH","DeFi","NFT","Wallet","Beginner"].map(tag => (
            <a href={`${base}/tags/${tag.toLowerCase()}`} class="ctag" style="text-decoration:none;">{tag}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <Footer />
</Layout>
