---
// src/pages/[lang]/posts/[...page].astro
// 非默认语言全部文章列表 — SSR，合并本地 + Ghost
export const prerender = false;

import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import UnifiedCard from "@/components/UnifiedCard.astro";
import Pagination from "@/components/Pagination.astro";
import { SITE } from "@/config";
import {
  DEFAULT_LANG, useTranslations,
  LANG_PATH_MAP, LANG_TO_PATH, type Lang,
} from "@/i18n/ui";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import {
  localToUnified,
  fetchGhostUnified,
  fetchSanityUnified,
  mergePosts,
  filterUnifiedByLang,
} from "@/utils/mergedPosts";

// ── 解析语言 ────────────────────────────────────────────
const langSeg = Astro.params.lang as string;
const lang: Lang = LANG_PATH_MAP[langSeg];
if (!lang || lang === DEFAULT_LANG) {
  return Astro.redirect("/posts");
}

const t = useTranslations(lang);
const base = `/${LANG_TO_PATH[lang]}`;

// ── 解析页码 ────────────────────────────────────────────
const pageParam = Astro.params.page;
const currentPage = pageParam ? parseInt(pageParam, 10) : 1;
if (isNaN(currentPage) || currentPage < 1) {
  return Astro.redirect(`${base}/posts`);
}

// ── 获取并合并文章 ──────────────────────────────────────
import type { UnifiedPost } from "@/utils/mergedPosts";

let localUnified: UnifiedPost[] = [];
try {
  const posts = await getCollection("blog");
  const sorted = getSortedPosts(posts);
  localUnified = sorted.map(p => localToUnified(p, getPath(p.id, p.filePath)));
} catch (e) {
  console.error("[posts] Local posts load failed:", e);
}

let ghostUnified: UnifiedPost[] = [];
try {
  ghostUnified = await fetchGhostUnified({ lang, limit: 100 });
} catch (e) {
  console.warn("[posts] Ghost unavailable");
}

let sanityUnified: UnifiedPost[] = [];
try {
  sanityUnified = await fetchSanityUnified({ lang, limit: 500 });
} catch (e) {
  console.warn("[posts] Sanity unavailable");
}

const merged = mergePosts(localUnified, ghostUnified, sanityUnified);
const allPosts = filterUnifiedByLang(merged, lang);

// ── 手动分页 ────────────────────────────────────────────
const pageSize = SITE.postPerPage;
const totalPages = Math.max(1, Math.ceil(allPosts.length / pageSize));

if (currentPage > totalPages && totalPages > 0) {
  return Astro.redirect(`${base}/posts`);
}

const start = (currentPage - 1) * pageSize;
const pagePosts = allPosts.slice(start, start + pageSize);

const basePath = `${base}/posts`;
const page = {
  data: pagePosts,
  start: start,
  end: start + pagePosts.length - 1,
  total: allPosts.length,
  size: pageSize,
  currentPage,
  lastPage: totalPages,
  url: {
    current: currentPage === 1 ? basePath : `${basePath}/${currentPage}`,
    prev: currentPage > 1 ? (currentPage === 2 ? basePath : `${basePath}/${currentPage - 1}`) : undefined,
    next: currentPage < totalPages ? `${basePath}/${currentPage + 1}` : undefined,
    first: basePath,
    last: totalPages > 1 ? `${basePath}/${totalPages}` : basePath,
  },
};
---

<Layout
  title={`${t("section.all")} | ${t("site.name")}`}
  description={t("site.desc")}
  paginationPrev={page.url.prev}
  paginationNext={page.url.next}
>
  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <div class="main-col" style="padding-bottom:40px;">
      <div style="padding:14px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href={base || "/"}
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">
          {t("nav.home")}
        </a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">{t("section.all")}</span>
      </div>

      <div style="padding:10px 16px 0;">
        <h1 style="font-size:20px;font-weight:700;color:var(--fg);margin-bottom:4px;">
          {t("section.all")}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);">{t("site.desc.short")}</p>
      </div>

      <div style="margin-top:12px;">
        {pagePosts.length > 0 ? (
          <div class="alist">
            {pagePosts.map(p => <UnifiedCard post={p} size="list" variant="h3" />)}
          </div>
        ) : (
          <div style="padding:60px 16px;text-align:center;color:var(--fg-muted);">
            <p style="font-size:15px;margin-bottom:8px;">No articles in this language yet.</p>
          </div>
        )}
      </div>

      <Pagination {page} {lang} />
    </div>

    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{t("section.tags")}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          {["BTC","ETH","DeFi","NFT","Wallet","Beginner"].map(tag => (
            <a href={`${base}/tags/${tag.toLowerCase()}`} class="ctag" style="text-decoration:none;">{tag}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <Footer />
</Layout>
