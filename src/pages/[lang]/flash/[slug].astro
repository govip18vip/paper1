---
// src/pages/[lang]/flash/[slug].astro
// 非默认语言快讯详情页，如 /en/flash/[slug]
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { sanityClient } from "@/utils/sanity";
import { SITE } from "@/config";
import type { SanityFlash } from "@/utils/sanity";
import { LANG_PATH_MAP, LANG_TO_PATH, type Lang } from "@/i18n/ui";

const { lang: langPath, slug } = Astro.params;
const lang: Lang = LANG_PATH_MAP[langPath ?? ""] ?? "en";
const basePath = `/${LANG_TO_PATH[lang]}`;

const flash = await sanityClient.fetch<SanityFlash | null>(`
  *[_type == "btgFlash" && slug.current == $slug && lang == $lang && draft != true][0] {
    _id, title, slug, content, lang, importance, tags, pubDatetime, sourceUrl, sourceName
  }
`, { slug, lang });

if (!flash) {
  return Astro.redirect("/404");
}

const importanceColor: Record<string, string> = {
  high:   "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400",
  medium: "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400",
  low:    "bg-muted text-[var(--fg-muted)]",
};
const importanceLabel: Record<string, string> = {
  high: "Breaking", medium: "Flash", low: "Update",
};

const pubDate = new Date(flash.pubDatetime).toLocaleDateString("en-US", {
  year: "numeric", month: "long", day: "numeric", hour: "2-digit", minute: "2-digit",
});
---

<Layout
  title={`${flash.title} | ${SITE.title}`}
  description={flash.content.slice(0, 160)}
>
  <Header />

  <main class="mx-auto max-w-2xl px-4 py-8">
    <nav class="mb-6 text-sm text-[var(--fg-muted)]">
      <a href={basePath} class="hover:underline">Home</a>
      <span class="mx-2">/</span>
      <a href={`${basePath}/flash`} class="hover:underline">Flash</a>
      <span class="mx-2">/</span>
      <span class="text-foreground">{flash.title.slice(0, 40)}{flash.title.length > 40 ? "…" : ""}</span>
    </nav>

    <article>
      <div class="mb-4 flex flex-wrap items-center gap-3">
        <span class={`rounded px-2 py-0.5 text-xs font-medium ${importanceColor[flash.importance] || importanceColor.low}`}>
          {importanceLabel[flash.importance] || "Flash"}
        </span>
        <time datetime={flash.pubDatetime} class="text-xs text-[var(--fg-muted)]">{pubDate}</time>
        {flash.sourceName && <span class="text-xs text-[var(--fg-muted)]">Source: {flash.sourceName}</span>}
      </div>

      <h1 class="mb-6 text-2xl font-bold leading-tight text-foreground">{flash.title}</h1>

      <div class="rounded-lg border border-border bg-[var(--bg-card)] p-6">
        <p class="text-base text-foreground leading-relaxed whitespace-pre-wrap">{flash.content}</p>
      </div>

      {(flash.tags || []).length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {(flash.tags || []).map((tag: string) => (
            <a href={`${basePath}/tags/${tag}`}
               class="rounded bg-muted px-2 py-0.5 text-xs text-[var(--fg-muted)] hover:text-accent">
              #{tag}
            </a>
          ))}
        </div>
      )}

      {flash.sourceUrl && (
        <p class="mt-6 text-xs text-[var(--fg-muted)]">
          Original source:
          <a href={flash.sourceUrl} target="_blank" rel="noopener noreferrer nofollow"
             class="text-accent hover:underline">
            {flash.sourceName || flash.sourceUrl}
          </a>
        </p>
      )}

      <div class="mt-6 rounded-lg bg-muted p-4 text-xs text-[var(--fg-muted)] border border-border">
        ⚠️ Risk disclaimer: Crypto prices are highly volatile. This is not investment advice.
      </div>

      <div class="mt-6">
        <a href={`${basePath}/flash`} class="text-sm text-accent hover:underline">← Back to Flash News</a>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
