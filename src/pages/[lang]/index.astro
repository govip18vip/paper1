---
// src/pages/[lang]/index.astro
// 非默认语言首页：/en/  /zh-tw/  /es/  /pt/
// SSR 模式，实时拉取 Sanity + Ghost 内容
export const prerender = false;

import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import Footer from "@/components/Footer.astro";
import UnifiedCard from "@/components/UnifiedCard.astro";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import {
  LANG_PATH_MAP, DEFAULT_LANG, useTranslations, hreflangLinks,
  LANG_TO_PATH, HTML_LANG, type Lang,
} from "@/i18n/ui";
import {
  localToUnified,
  fetchGhostUnified,
  fetchSanityUnified,
  mergePosts,
  filterUnifiedByLang,
  type UnifiedPost,
} from "@/utils/mergedPosts";
import { getSanityFlashes } from "@/utils/sanity";
import type { SanityFlash } from "@/utils/sanity";
import { TUTORIAL_TAGS } from "@/utils/homePage";
import getSortedPosts from "@/utils/getSortedPosts";

// 从 URL 路径段解析语言
const rawLang = Astro.params.lang ?? "";
const lang: Lang = LANG_PATH_MAP[rawLang] ?? "en";

// 如果是无效的语言路径，重定向
if (!LANG_PATH_MAP[rawLang]) {
  return Astro.redirect("/404");
}

const t = useTranslations(lang);
const alternates = hreflangLinks(Astro.url);
const siteUrl = SITE.website.replace(/\/$/, "");
const langSeg = LANG_TO_PATH[lang];
const base = `/${langSeg}`;

// ── 1. 本地 Markdown 文章 ────────────────────────────────────
let localUnified: UnifiedPost[] = [];
try {
  const posts = await getCollection("blog");
  const sorted = getSortedPosts(posts);
  localUnified = sorted.map(p => localToUnified(p, getPath(p.id, p.filePath)));
} catch (e) {
  console.error("[lang/index] Local posts load failed:", e);
}

// ── 2. Ghost CMS ─────────────────────────────────────────────
let ghostUnified: UnifiedPost[] = [];
try {
  ghostUnified = await fetchGhostUnified({ lang, limit: 30 });
} catch (e) {
  // 容错
}

// ── 3. Sanity CMS ────────────────────────────────────────────
let sanityUnified: UnifiedPost[] = [];
try {
  sanityUnified = await fetchSanityUnified({ lang, limit: 30 });
} catch (e) {
  // 容错
}

// ── 4. 合并 & 按语言过滤 ─────────────────────────────────────
const merged = filterUnifiedByLang(
  mergePosts(localUnified, ghostUnified, sanityUnified),
  lang
);

// ── 5. 快讯 ─────────────────────────────────────────────────
let recentFlashes: SanityFlash[] = [];
try {
  recentFlashes = await getSanityFlashes({ limit: 6, lang });
} catch (e) {
  // 容错
}

// ── 6. 分配区域 ──────────────────────────────────────────────
const featured = merged.filter(p => p.featured);
const heroSource = featured.length > 0 ? featured : merged;
const hero = heroSource[0] ?? null;
const restFeatured = heroSource.slice(1);

const thumbPosts = (
  restFeatured.length >= 4 ? restFeatured : merged.filter(p => p !== hero)
).slice(0, 4);

const listPosts = merged
  .filter(p => p !== hero && !thumbPosts.includes(p))
  .slice(0, 12);

const mainShown = new Set([hero, ...thumbPosts, ...listPosts].filter(Boolean));
const newsPosts = merged.filter(p => !mainShown.has(p)).slice(0, 8);
const hotPosts = merged.filter(p => !mainShown.has(p) && !newsPosts.includes(p)).slice(0, 7);
const tutorialPosts = merged.filter(p => p.tags?.some(t => TUTORIAL_TAGS.includes(t.toLowerCase()))).slice(0, 5);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  name: "Bitaigen",
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description: t("site.desc"),
  sameAs: [
    "https://x.com/tanfyoo",
    "https://t.me/AllenAmbrose",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  name: t("site.name"),
  description: t("site.desc"),
  url: siteUrl,
  publisher: { "@id": `${siteUrl}/#organization` },
  inLanguage: [HTML_LANG[lang], "en", "zh-CN", "es", "pt"],
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteUrl}/${langSeg}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
---

<Layout
  title={`${t("site.name")} — ${t("site.desc").slice(0, 60)}`}
  description={t("site.desc")}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <div class="main-col" id="main-content" data-layout="index">
      <h1 class="sr-only">{t("home.h1")}</h1>

      <!-- HERO -->
      <section class="hero-section anim-1" aria-label={t("section.latest")}>
        <div class="hero-row">
          <div>
            {hero ? (
              <UnifiedCard post={hero} size="hero" variant="h2" />
            ) : (
              <div class="hero-main" style="display:flex;align-items:center;justify-content:center;background:var(--bg-elevated);">
                <p style="color:var(--fg-muted);font-size:14px;">No featured posts yet</p>
              </div>
            )}
          </div>
          <div class="hero-grid">
            {thumbPosts.slice(0, 4).map(p => (
              <a href={p.href} class="hero-thumb" aria-label={p.title}>
                {p.ogImage ? (
                  <img src={p.ogImage} alt={p.title} loading="lazy"
                    style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.3s ease;" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-orange-900/40 to-amber-900/20 flex items-center justify-center">
                    <span class="text-3xl opacity-20">₿</span>
                  </div>
                )}
                <div class="hero-thumb-overlay" aria-hidden="true" />
                <div class="hero-thumb-title">{p.title}</div>
              </a>
            ))}
            {Array.from({ length: Math.max(0, 4 - thumbPosts.length) }).map(() => (
              <div class="hero-thumb" style="background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;opacity:0.4;">
                <span style="font-size:24px;">₿</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- LATEST ARTICLES -->
      <section aria-label={t("section.latest")} class="anim-2">
        <div class="sec-head" style="padding-top:16px;">
          <span class="sec-head-title">{t("section.latest")}</span>
          <a href={`${base}/posts/`} class="sec-head-more">{t("section.all")} →</a>
        </div>
        <div class="alist" id="main-list">
          {listPosts.length > 0 ? (
            listPosts.map(p => <UnifiedCard post={p} size="list" variant="h3" />)
          ) : (
            <div style="padding:32px;text-align:center;color:var(--fg-muted);font-size:14px;">
              No articles in this language yet.
            </div>
          )}
        </div>
        {merged.length > (1 + thumbPosts.length + listPosts.length) && (
          <div style="padding:0 16px 16px;text-align:center;">
            <a href={`${base}/posts/`} class="more-btn" style="display:inline-block;max-width:280px;">
              {t("section.more")}
            </a>
          </div>
        )}
      </section>

      <!-- FLASH SECTION -->
      {recentFlashes.length > 0 && (
        <section aria-label="Flash News" class="anim-3">
          <div class="sec-head" style="padding-top:16px;">
            <span class="sec-head-title">⚡ Flash News</span>
            <a href={`${base}/flash`} class="sec-head-more">All Flash →</a>
          </div>
          <div style="padding:0 16px 16px;display:flex;flex-direction:column;gap:10px;">
            {recentFlashes.map((f: SanityFlash) => (
              <a
                href={`${base}/flash/${f.slug.current}`}
                style="display:flex;gap:10px;align-items:flex-start;padding:10px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);transition:border-color 0.2s;"
              >
                <span style={`flex-shrink:0;margin-top:2px;font-size:10px;font-weight:600;border-radius:3px;padding:1px 6px;${f.importance === 'high' ? 'background:rgba(239,68,68,0.15);color:#ef4444;' : f.importance === 'medium' ? 'background:rgba(234,179,8,0.15);color:#ca8a04;' : 'background:var(--bg-elevated);color:var(--fg-muted);'}`}>
                  {f.importance === 'high' ? 'Breaking' : f.importance === 'medium' ? 'Flash' : 'Update'}
                </span>
                <span style="font-size:13px;color:var(--fg);line-height:1.5;flex:1;">{f.title}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ABOUT BLOCK -->
      <section id="geo-intro" style="padding:16px;margin:0 0 16px;" class="anim-4"
        itemscope itemtype="https://schema.org/AboutPage">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:20px 24px;">
          <h2 style="font-size:15px;font-weight:700;margin-bottom:16px;color:var(--fg);display:flex;align-items:center;gap:8px;">
            <span style="display:inline-block;width:3px;height:18px;background:var(--accent);border-radius:2px;flex-shrink:0;"></span>
            {t("section.about")}
          </h2>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
            <div>
              <h3 style="font-size:13px;font-weight:700;color:var(--accent);margin-bottom:6px;">{t("about.btc.title")}</h3>
              <p style="font-size:12px;color:var(--fg-muted);line-height:1.6;">{t("about.btc.desc")}</p>
            </div>
            <div>
              <h3 style="font-size:13px;font-weight:700;color:var(--accent-blue);margin-bottom:6px;">{t("about.ex.title")}</h3>
              <p style="font-size:12px;color:var(--fg-muted);line-height:1.6;">{t("about.ex.desc")}</p>
            </div>
            <div>
              <h3 style="font-size:13px;font-weight:700;color:var(--accent-green);margin-bottom:6px;">{t("about.wallet.title")}</h3>
              <p style="font-size:12px;color:var(--fg-muted);line-height:1.6;">{t("about.wallet.desc")}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- TAG CLOUD -->
      <section style="padding:0 16px 20px;" aria-label={t("section.topic")} class="anim-5">
        <div class="sec-head" style="padding-left:0;">
          <span class="sec-head-title">{t("section.topic")}</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;">
          {[
            { label: "Bitcoin", href: `${base}/tags/btc` },
            { label: "Ethereum", href: `${base}/tags/eth` },
            { label: "DeFi", href: `${base}/tags/defi` },
            { label: "NFT", href: `${base}/tags/nft` },
            { label: "Wallet", href: `${base}/tags/wallet` },
            { label: "Beginner", href: `${base}/tags/beginner` },
            { label: "Web3", href: `${base}/tags/defi` },
          ].map(tag => (
            <a href={tag.href}
              style="display:inline-block;padding:5px 12px;border-radius:20px;font-size:12.5px;font-weight:500;border:1px solid var(--border);color:var(--fg-muted);background:var(--bg-card);text-decoration:none;transition:all 0.12s;"
              onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';"
              onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--fg-muted)';">
              {tag.label}
            </a>
          ))}
          <a href={`${base}/tags`}
            style="display:inline-block;padding:5px 12px;border-radius:20px;font-size:12.5px;font-weight:600;border:1px solid var(--accent);color:var(--accent);background:var(--tag-orange-bg);text-decoration:none;">
            {t("section.topic")} →
          </a>
        </div>
      </section>

    </div>

    <!-- RIGHT SIDEBAR -->
    <aside class="rsidebar" aria-label="Sidebar">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{t("section.flash")}</div>
        {newsPosts.map(p => <UnifiedCard post={p} size="news" variant="h3" />)}
        <a href={`${base}/posts/`} class="more-btn">{t("section.more")}</a>
      </div>

      <div class="rsidebar-section">
        <div class="rsidebar-head">🔥 {t("section.hot")}</div>
        <ol>
          {hotPosts.map((p, i) => (
            <li style="display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--border-subtle);align-items:flex-start;">
              <span class:list={["hot-rank", { top: i < 3 }]}>{i + 1}</span>
              <a href={p.href}
                style="flex:1;font-size:12.5px;font-weight:500;color:var(--fg);line-height:1.5;text-decoration:none;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;transition:color 0.12s;"
                onmouseover="this.style.color='var(--accent)';"
                onmouseout="this.style.color='var(--fg)';">
                {p.title}
              </a>
            </li>
          ))}
        </ol>
      </div>

      {tutorialPosts.length > 0 && (
        <div class="rsidebar-section">
          <div class="rsidebar-head">📚 {t("section.tutorial")}</div>
          <ul style="list-style:none;padding:0;margin:0;">
            {tutorialPosts.map(p => (
              <li style="padding:8px 0;border-bottom:1px solid var(--border-subtle);">
                <a href={p.href}
                  style="display:flex;gap:8px;align-items:flex-start;text-decoration:none;color:var(--fg);font-size:12.5px;transition:color 0.12s;"
                  onmouseover="this.style.color='var(--accent)';"
                  onmouseout="this.style.color='var(--fg)';">
                  <span class="ctag-blue" style="margin-top:2px;flex-shrink:0;">Guide</span>
                  <span style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                    {p.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>

  </div>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector("[data-layout='index']");
    if (el) sessionStorage.setItem("backUrl", window.location.pathname);
  });
</script>
