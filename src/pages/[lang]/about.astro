---
// src/pages/[lang]/about.astro
// Non-default language About pages: /en/about  /zh-tw/about  /es/about  /pt/about

import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
import {
  LANGUAGES, DEFAULT_LANG, LANG_TO_PATH,
  useTranslations, type Lang,
} from "@/i18n/ui";

export const getStaticPaths = (async () => {
  const nonDefaultLangs = (Object.keys(LANGUAGES) as Lang[]).filter(
    l => l !== DEFAULT_LANG
  );
  return nonDefaultLangs.map(lang => ({
    params: { lang: LANG_TO_PATH[lang] },
    props: { lang },
  }));
}) satisfies GetStaticPaths;

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

interface AboutContent {
  title: string;
  html: string;
}

