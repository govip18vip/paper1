---
// src/pages/[lang]/price/[symbol].astro
// 非默认语言币种详情：/en/price/btc  /zh-tw/price/eth  等

// ISR: 服务端渲染，Vercel 缓存 5 分钟后台刷新
export const prerender = false;

import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import { SITE } from "@/config";
import {
  LANGUAGES, DEFAULT_LANG, LANG_TO_PATH,
  useTranslations, type Lang,
} from "@/i18n/ui";
import { MAJOR_COINS, COIN_DB } from "@/utils/coinInfo";
import { getPath } from "@/utils/getPath";

// 从 URL 参数解析 lang + symbol
const { lang: langParam, symbol } = Astro.params;
const lang = (Object.entries(LANG_TO_PATH).find(([, v]) => v === langParam)?.[0] as Lang) ?? DEFAULT_LANG;
const coinEntry = MAJOR_COINS.find(c => c.symbol.toLowerCase() === symbol);
if (!coinEntry) return Astro.redirect("/404");
const coin = COIN_DB[coinEntry.id];
if (!coin) return Astro.redirect("/404");

// 服务端预取价格
interface PriceData {
  priceUSD: number; change24h: number; high24h: number;
  low24h: number;  volume24h: number; marketCap: number;
  rank: number;    supply: number;
}
let serverPrice: PriceData | null = null;
try {
  const r = await fetch("https://orbit.biyijia.com/api/coins?per_page=60",
    { signal: AbortSignal.timeout(5000) });
  if (r.ok) {
    const coins: any[] = await r.json();
    const match = coins.find(c => c.symbol?.toUpperCase() === coin.symbol);
    if (match) {
      serverPrice = {
        priceUSD:  match.current_price ?? 0,
        change24h: match.price_change_percentage_24h_in_currency ?? 0,
        high24h:   match.high_24h ?? 0,
        low24h:    match.low_24h  ?? 0,
        volume24h: match.total_volume ?? 0,
        marketCap: match.market_cap  ?? 0,
        rank:      match.market_cap_rank ?? 0,
        supply:    match.circulating_supply ?? 0,
      };
    }
  }
} catch { /* 客户端 JS 兜底 */ }

const t = useTranslations(lang);
const base = `/${LANG_TO_PATH[lang]}`;

const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter(p => !p.data.draft && p.data.tags?.some(tag =>
    coin.tags.includes(tag.toLowerCase())
  ))
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime())
  .slice(0, 10);

const otherCoins = MAJOR_COINS.filter(c => c.id !== coinEntry.id).slice(0, 6);

const L: Record<string, Record<Lang, string>> = {
  livePrice:   { "zh-CN": "实时价格",   "zh-TW": "即時價格",   en: "Live Price",            es: "Precio en Vivo",          pt: "Preço ao Vivo" },
  priceUSD:    { "zh-CN": "价格 (USD)", "zh-TW": "價格 (USD)", en: "Price (USD)",           es: "Precio (USD)",             pt: "Preço (USD)" },
  change24h:   { "zh-CN": "24h涨跌",   "zh-TW": "24h漲跌",   en: "24h Change",            es: "Cambio 24h",               pt: "Variação 24h" },
  high24h:     { "zh-CN": "24h最高",   "zh-TW": "24h最高",   en: "24h High",              es: "Máx 24h",                  pt: "Máx 24h" },
  low24h:      { "zh-CN": "24h最低",   "zh-TW": "24h最低",   en: "24h Low",               es: "Mín 24h",                  pt: "Mín 24h" },
  vol24h:      { "zh-CN": "24h成交量", "zh-TW": "24h成交量", en: "24h Volume",            es: "Vol 24h",                  pt: "Vol 24h" },
  mcap:        { "zh-CN": "市值",      "zh-TW": "市值",      en: "Market Cap",            es: "Cap. Mercado",             pt: "Cap. Mercado" },
  supply:      { "zh-CN": "流通量",    "zh-TW": "流通量",    en: "Circulating Supply",    es: "Suministro Circulante",    pt: "Fornecimento Circulante" },
  maxSupply:   { "zh-CN": "最大供应",  "zh-TW": "最大供應",  en: "Max Supply",            es: "Suministro Máx",           pt: "Fornecimento Máx" },
  trend:       { "zh-CN": "价格走势",  "zh-TW": "價格走勢",  en: "Price Chart",           es: "Gráfico de Precio",        pt: "Gráfico de Preço" },
  projectInfo: { "zh-CN": "项目信息",  "zh-TW": "項目資訊",  en: "Project Info",          es: "Info del Proyecto",        pt: "Info do Projeto" },
  founder:     { "zh-CN": "创始人",    "zh-TW": "創始人",    en: "Founder",               es: "Fundador",                 pt: "Fundador" },
  launchDate:  { "zh-CN": "上线日期",  "zh-TW": "上線日期",  en: "Launch Date",           es: "Fecha de Lanzamiento",     pt: "Data de Lançamento" },
  consensus:   { "zh-CN": "共识机制",  "zh-TW": "共識機制",  en: "Consensus",             es: "Consenso",                 pt: "Consenso" },
  blockTime:   { "zh-CN": "出块时间",  "zh-TW": "出塊時間",  en: "Block Time",            es: "Tiempo de Bloque",         pt: "Tempo de Bloco" },
  useCase:     { "zh-CN": "使用场景",  "zh-TW": "使用場景",  en: "Use Case",              es: "Caso de Uso",              pt: "Caso de Uso" },
  desc:        { "zh-CN": "简介",      "zh-TW": "簡介",      en: "Description",           es: "Descripción",              pt: "Descrição" },
  links:       { "zh-CN": "相关链接",  "zh-TW": "相關連結",  en: "Links",                 es: "Enlaces",                  pt: "Links" },
  website:     { "zh-CN": "官网",      "zh-TW": "官網",      en: "Website",               es: "Sitio Web",                pt: "Site" },
  whitepaper:  { "zh-CN": "白皮书",    "zh-TW": "白皮書",    en: "Whitepaper",            es: "Whitepaper",               pt: "Whitepaper" },
  explorer:    { "zh-CN": "区块浏览器","zh-TW": "區塊瀏覽器",en: "Explorer",              es: "Explorador",               pt: "Explorador" },
  sourceCode:  { "zh-CN": "源代码",    "zh-TW": "原始碼",    en: "Source Code",           es: "Código Fuente",            pt: "Código Fonte" },
  news:        { "zh-CN": "相关资讯",  "zh-TW": "相關資訊",  en: "Related News",          es: "Noticias Relacionadas",    pt: "Notícias Relacionadas" },
  viewAll:     { "zh-CN": "查看全部 →","zh-TW": "查看全部 →",en: "View All →",            es: "Ver Todo →",               pt: "Ver Tudo →" },
  buyOn:       { "zh-CN": "在币安购买","zh-TW": "在幣安購買",en: "Buy on Binance",        es: "Comprar en Binance",       pt: "Comprar na Binance" },
  tvChart:     { "zh-CN": "TradingView 查看","zh-TW": "TradingView 查看",en: "TradingView ↗",        es: "TradingView ↗",            pt: "TradingView ↗" },
  tradeNow:    { "zh-CN": "立即交易",  "zh-TW": "立即交易",  en: "Trade Now",             es: "Operar Ya",                pt: "Negociar" },
  tradeOnBin:  { "zh-CN": "币安交易",  "zh-TW": "幣安交易",  en: "Binance",               es: "Binance",                  pt: "Binance" },
  tradeOnOKX:  { "zh-CN": "OKX交易",  "zh-TW": "OKX交易",  en: "OKX",                   es: "OKX",                      pt: "OKX" },
  otherCoins:  { "zh-CN": "其他币种",  "zh-TW": "其他幣種",  en: "Other Coins",           es: "Otras Monedas",            pt: "Outras Moedas" },
  updated:     { "zh-CN": "最后更新",  "zh-TW": "最後更新",  en: "Last updated",          es: "Última actualización",     pt: "Última atualização" },
  autoRefresh: { "zh-CN": "每30秒自动刷新","zh-TW": "每30秒自動刷新",en: "Auto-refreshes every 30s",es: "Se actualiza cada 30s",pt: "Atualiza a cada 30s" },
  source:      { "zh-CN": "数据来源：CryptoBubbles / Binance","zh-TW": "數據來源：CryptoBubbles / Binance",en: "Data: CryptoBubbles / Binance",es: "Datos: CryptoBubbles / Binance",pt: "Dados: CryptoBubbles / Binance" },
  quickBuy:    { "zh-CN": "快速操作",  "zh-TW": "快速操作",  en: "Quick Actions",         es: "Acciones Rápidas",         pt: "Ações Rápidas" },
  refCode:     { "zh-CN": "邀请码 B2345 · 最高折扣","zh-TW": "邀請碼 B2345 · 最高折扣",en: "Ref B2345 · Max Discount",es: "Código B2345 · Máximo descuento",pt: "Código B2345 · Máximo desconto" },
  allPrices:   { "zh-CN": "← 返回行情总览","zh-TW": "← 返回行情總覽",en: "← Back to Prices",es: "← Volver a Precios",pt: "← Voltar a Preços" },
};

const pageTitle = `${coin.name[lang]} (${coin.symbol}) ${L.livePrice[lang]}`;
---

<Layout
  title={`${pageTitle} | ${t("site.name")}`}
  description={coin.description[lang]}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://orbit.biyijia.com" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FinancialProduct",
      name: `${coin.name[lang]} (${coin.symbol})`,
      description: coin.description[lang],
      url: `${SITE.website}${LANG_TO_PATH[lang]}/price/${coin.symbol.toLowerCase()}`,
      category: "Cryptocurrency",
      provider: { "@type": "Organization", name: SITE.title },
    })} />
  </Fragment>

  <Header />
  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <main class="main-col" id="main-content">

      <!-- 面包屑 -->
      <nav style="padding:12px 16px 0;font-size:13px;color:var(--fg-muted);" aria-label="breadcrumb">
        <a href={base || "/"} style="color:var(--fg-muted);text-decoration:none;">{t("nav.home")}</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <a href={`${base}/price`} style="color:var(--fg-muted);text-decoration:none;">{L.allPrices[lang].replace("← ","")}</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">{coin.name[lang]} ({coin.symbol})</span>
      </nav>

      <!-- ══ 价格 Hero ══ -->
      <section style="padding:12px 16px 0;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:10px;overflow:hidden;">
          <div style="display:flex;align-items:center;gap:14px;padding:20px 24px 16px;border-bottom:1px solid var(--border);flex-wrap:wrap;">
            <div style={`width:48px;height:48px;border-radius:50%;background:${coin.color}22;border:2px solid ${coin.color}44;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;`}>
              <img src={`/coins/${coin.symbol.toLowerCase()}.png`} alt={coin.symbol}
                width="32" height="32" style="width:32px;height:32px;object-fit:contain;"
                onerror={`this.outerHTML='<span style="font-size:24px">${coin.emoji}</span>'`} />
            </div>
            <div style="flex:1;min-width:150px;">
              <h1 style="font-size:22px;font-weight:800;color:var(--fg);margin:0;line-height:1.2;">
                {coin.name[lang]} <span style="font-size:14px;font-weight:400;color:var(--fg-muted);">{coin.symbol}</span>
              </h1>
              <p style="font-size:12px;color:var(--fg-muted);margin:3px 0 0;">{L.source[lang]}</p>
            </div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
              <span id="rank-badge" class="ctag-blue">{serverPrice?.rank ? `#${serverPrice.rank}` : "—"}</span>
              {coin.consensus && <span class="ctag">{coin.consensus.split("(")[0].trim().slice(0,20)}</span>}
            </div>
          </div>

          <!-- 价格网格 (服务端预填充，客户端 JS 实时刷新) -->
          {(() => {
            const fmt = (n: number) => n >= 1000
              ? "$" + n.toLocaleString("en-US", { maximumFractionDigits: 0 })
              : "$" + n.toFixed(n >= 1 ? 2 : 5);
            const fmtB = (n: number) => {
              if (n >= 1e9) return "$" + (n / 1e9).toFixed(2) + "B";
              if (n >= 1e6) return "$" + (n / 1e6).toFixed(2) + "M";
              return "$" + n.toLocaleString("en-US", { maximumFractionDigits: 0 });
            };
            const fmtS = (n: number) => {
              if (n >= 1e9) return (n / 1e9).toFixed(2) + "B";
              if (n >= 1e6) return (n / 1e6).toFixed(2) + "M";
              return n.toLocaleString("en-US", { maximumFractionDigits: 0 });
            };
            const sp = serverPrice;
            const chgColor = sp ? (sp.change24h >= 0 ? "#4caf82" : "#f0b429") : "var(--fg-muted)";
            return (
              <div class="coin-price-grid">
                <div class="coin-price-cell coin-price-main">
                  <div class="coin-price-label">{L.priceUSD[lang]}</div>
                  <div id="coin-price" style="font-size:clamp(24px,5vw,32px);font-weight:800;color:var(--fg);font-variant-numeric:tabular-nums;">
                    {sp ? fmt(sp.priceUSD) : "—"}
                  </div>
                  <div id="coin-change" style={`font-size:14px;margin-top:4px;font-weight:700;color:${chgColor};`}>
                    {sp ? `${sp.change24h >= 0 ? "▲" : "▼"}${Math.abs(sp.change24h).toFixed(2)}%` : "—"}
                  </div>
                </div>
                <div class="coin-price-cell">
                  <div class="coin-price-label">{L.high24h[lang]}</div>
                  <div id="coin-high" class="coin-price-num">{sp && sp.high24h ? fmt(sp.high24h) : "—"}</div>
                  <div class="coin-price-label" style="margin-top:8px;">{L.low24h[lang]}</div>
                  <div id="coin-low" class="coin-price-num">{sp && sp.low24h ? fmt(sp.low24h) : "—"}</div>
                </div>
                <div class="coin-price-cell">
                  <div class="coin-price-label">{L.vol24h[lang]}</div>
                  <div id="coin-vol" class="coin-price-num">{sp && sp.volume24h ? fmtB(sp.volume24h) : "—"}</div>
                  <div class="coin-price-label" style="margin-top:8px;">{L.mcap[lang]}</div>
                  <div id="coin-mcap" class="coin-price-num">{sp && sp.marketCap ? fmtB(sp.marketCap) : "—"}</div>
                </div>
                <div class="coin-price-cell">
                  <div class="coin-price-label">{L.supply[lang]}</div>
                  <div id="coin-supply" class="coin-price-num">{sp && sp.supply ? fmtS(sp.supply) : "—"}</div>
                  <div class="coin-price-label" style="margin-top:8px;">{L.maxSupply[lang]}</div>
                  <div class="coin-price-num" style={`color:${coin.color};`}>{coin.maxSupply || "∞"}</div>
                </div>
              </div>
            );
          })()}

          <!-- 交易所直通 -->
          <div style="display:flex;gap:8px;padding:12px 24px;border-bottom:1px solid var(--border);flex-wrap:wrap;align-items:center;">
            <span style="font-size:11px;font-weight:700;color:var(--fg-muted);text-transform:uppercase;letter-spacing:0.05em;margin-right:2px;">{L.tradeNow[lang]}</span>
            <a href={`https://www.binance.com/trade/${coin.symbol}_USDT?layout=pro&ref=B2345&type=spot`}
              target="_blank" rel="noopener noreferrer sponsored"
              style="display:inline-flex;align-items:center;gap:5px;padding:6px 14px;background:#F0B90B;color:#111;border-radius:5px;text-decoration:none;font-size:12.5px;font-weight:800;transition:opacity 0.15s;"
              onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
              <span style="font-size:15px;line-height:1;">◈</span> {L.tradeOnBin[lang]}
            </a>
            <a href={`https://www.okx.com/trade-spot/${coin.symbol.toLowerCase()}-usdt?channelid=B2345`}
              target="_blank" rel="noopener noreferrer sponsored"
              style="display:inline-flex;align-items:center;gap:5px;padding:6px 14px;background:#1a1a1a;color:#fff;border-radius:5px;text-decoration:none;font-size:12.5px;font-weight:800;transition:opacity 0.15s;"
              onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
              {L.tradeOnOKX[lang]}
            </a>
            <span style="font-size:11px;color:var(--fg-light);margin-left:4px;">{L.refCode[lang]}</span>
          </div>

          <!-- K线图 -->
          <div style="padding:16px 24px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:8px;">
              <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                <span style="font-size:14px;font-weight:700;color:var(--fg);">{L.trend[lang]}</span>
                <a href={`https://www.tradingview.com/chart/?symbol=BINANCE:${coin.binanceSymbol}&aff_id=165160`}
                  target="_blank" rel="noopener noreferrer"
                  style="display:inline-flex;align-items:center;gap:4px;font-size:11.5px;color:#2962FF;text-decoration:none;font-weight:600;padding:3px 9px;border-radius:4px;background:rgba(41,98,255,.1);transition:background 0.15s;"
                  onmouseover="this.style.background='rgba(41,98,255,.22)'" onmouseout="this.style.background='rgba(41,98,255,.1)'">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#2962FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                  {L.tvChart[lang]}
                </a>
              </div>
              <div style="display:flex;gap:3px;" id="chart-btns">
                {[
                  {label:"1H", interval:"1m",  limit:60},
                  {label:"4H", interval:"5m",  limit:48},
                  {label:"1D", interval:"1h",  limit:24},
                  {label:"1W", interval:"4h",  limit:42},
                  {label:"1M", interval:"1d",  limit:30},
                ].map((p, i) => (
                  <button data-interval={p.interval} data-limit={String(p.limit)}
                    class:list={["chart-period-btn", { active: i === 2 }]}
                  >{p.label}</button>
                ))}
              </div>
            </div>
            <!-- OHLC 信息栏 -->
            <div id="ohlc-bar" style="display:flex;gap:12px;flex-wrap:wrap;font-size:11.5px;color:var(--fg-muted);margin-bottom:6px;min-height:18px;font-variant-numeric:tabular-nums;letter-spacing:0.01em;">
              <span>O <strong id="ohlc-o" style="color:var(--fg);">—</strong></span>
              <span>H <strong id="ohlc-h" style="color:#26a69a;">—</strong></span>
              <span>L <strong id="ohlc-l" style="color:#ef5350;">—</strong></span>
              <span>C <strong id="ohlc-c" style="color:var(--fg);">—</strong></span>
              <span style="margin-left:auto;">Vol <strong id="ohlc-v" style="color:var(--fg-muted);">—</strong></span>
            </div>
            <div id="coin-chart" style="height:340px;"></div>
          </div>

          <div style="padding:8px 24px 14px;font-size:11px;color:var(--fg-light);">
            {L.updated[lang]}：<span id="coin-updated">—</span> · {L.autoRefresh[lang]}
          </div>
        </div>
      </section>

      <div style="padding:0 16px;">
        <BinanceBanner variant="article" lang={lang} />
      </div>

      <!-- ══ 项目信息 ══ -->
      <section style="padding:0 16px 16px;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:20px 24px;">
          <h2 style="font-size:17px;font-weight:700;color:var(--fg);margin:0 0 18px;display:flex;align-items:center;gap:8px;">
            <span style={`width:3px;height:18px;background:${coin.color};border-radius:2px;display:inline-block;`}></span>
            {L.projectInfo[lang]}
          </h2>

          <div style="background:var(--bg-elevated);border-radius:6px;padding:14px 16px;margin-bottom:16px;border-left:3px solid var(--accent);">
            <div style="font-size:11px;font-weight:600;color:var(--fg-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.06em;">{L.desc[lang]}</div>
            <p style="font-size:14px;color:var(--fg);line-height:1.7;margin:0;">{coin.description[lang]}</p>
          </div>

          <div class="coin-info-grid">
            {[
              [L.founder[lang], coin.founderFull?.[lang] || coin.founder || "—"],
              [L.launchDate[lang], coin.launchDate || "—"],
              [L.consensus[lang], coin.consensus || "—"],
              [L.blockTime[lang], coin.blockTime || "—"],
              [L.maxSupply[lang], coin.maxSupply || "∞"],
              [L.useCase[lang], coin.useCase[lang]],
            ].map(([label, value]) => (
              <div class="coin-info-row">
                <span class="coin-info-label">{label}</span>
                <span class="coin-info-value">{value}</span>
              </div>
            ))}
          </div>

          <div style="margin-top:18px;padding-top:16px;border-top:1px solid var(--border);">
            <div style="font-size:12px;font-weight:700;color:var(--fg-muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.06em;">{L.links[lang]}</div>
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
              {coin.officialWebsite && (
                <a href={coin.officialWebsite} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:var(--tag-orange-bg);--btn-color:var(--accent);">
                  🌐 {L.website[lang]}
                </a>
              )}
              {coin.whitepaper && (
                <a href={coin.whitepaper} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:var(--tag-blue-bg);--btn-color:var(--accent-blue);">
                  📄 {L.whitepaper[lang]}
                </a>
              )}
              {coin.blockExplorer && (
                <a href={coin.blockExplorer} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:var(--tag-green-bg);--btn-color:var(--accent-green);">
                  🔍 {L.explorer[lang]}
                </a>
              )}
              {coin.github && (
                <a href={coin.github} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:var(--bg-elevated);--btn-color:var(--fg-muted);">
                  💻 {L.sourceCode[lang]}
                </a>
              )}
              {coin.twitter && (
                <a href={coin.twitter} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:rgba(29,155,240,.12);--btn-color:#1d9bf0;">
                  𝕏 Twitter
                </a>
              )}
              {coin.telegram && (
                <a href={coin.telegram} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:rgba(0,136,204,.12);--btn-color:#0088cc;">
                  ✈️ Telegram
                </a>
              )}
              {coin.discord && (
                <a href={coin.discord} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:rgba(88,101,242,.12);--btn-color:#5865f2;">
                  💬 Discord
                </a>
              )}
              {coin.reddit && (
                <a href={coin.reddit} target="_blank" rel="noopener noreferrer" class="coin-link-btn" style="--btn-bg:rgba(255,69,0,.1);--btn-color:#ff4500;">
                  📢 Reddit
                </a>
              )}
            </div>
          </div>
        </div>
      </section>

      <!-- ══ 相关资讯 ══ -->
      {relatedPosts.length > 0 && (
        <section style="padding:0 16px 20px;">
          <div class="sec-head" style="padding-left:0;margin-bottom:12px;">
            <span class="sec-head-title">{coin.symbol} {L.news[lang]}</span>
            <a href={`/tags/${coin.tags[0]}`} class="sec-head-more">{L.viewAll[lang]}</a>
          </div>
          <div style="background:var(--bg-card);border-radius:8px;border:1px solid var(--border);overflow:hidden;">
            {relatedPosts.map((post, i) => (
              <a href={getPath(post.id, post.filePath)}
                style={`display:flex;gap:12px;padding:12px 16px;text-decoration:none;color:var(--fg);transition:background 0.12s;${i < relatedPosts.length - 1 ? 'border-bottom:1px solid var(--border-subtle);' : ''}`}
                onmouseover="this.style.background='var(--bg-elevated)'" onmouseout="this.style.background='transparent'">
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13px;font-weight:600;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                    {post.data.title}
                  </div>
                  <div style="font-size:11px;color:var(--fg-light);margin-top:4px;">
                    {new Date(post.data.pubDatetime).toLocaleDateString(lang === "en" ? "en-US" : lang === "es" ? "es-ES" : lang === "pt" ? "pt-BR" : "zh-CN")}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <div style="padding:0 16px 20px;">
        <a href={`${base}/price`}
          style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--fg-muted)'"
        >{L.allPrices[lang]}</a>
      </div>

    </main>

    <!-- 右侧栏 -->
    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{L.quickBuy[lang]}</div>
        <a href={`https://www.binance.com/trade/${coin.symbol}_USDT?layout=pro&ref=B2345&type=spot`}
          target="_blank" rel="noopener noreferrer sponsored"
          style="display:block;padding:10px;background:#F0B90B;color:#111;border-radius:6px;text-decoration:none;font-size:13px;font-weight:800;text-align:center;margin-bottom:8px;transition:opacity 0.12s;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          ◈ Binance · {coin.symbol}/USDT →
        </a>
        <a href={`https://www.okx.com/trade-spot/${coin.symbol.toLowerCase()}-usdt?channelid=B2345`}
          target="_blank" rel="noopener noreferrer sponsored"
          style="display:block;padding:10px;background:#1a1a1a;color:#fff;border-radius:6px;text-decoration:none;font-size:13px;font-weight:800;text-align:center;margin-bottom:8px;transition:opacity 0.12s;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          OKX · {coin.symbol}/USDT →
        </a>
        <p style="font-size:11px;color:var(--fg-muted);text-align:center;margin:0;">{L.refCode[lang]}</p>
      </div>

      <div class="rsidebar-section">
        <div class="rsidebar-head">{L.otherCoins[lang]}</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {otherCoins.map(c => (
            <a href={`${base}/price/${c.symbol.toLowerCase()}`}
              style="display:flex;align-items:center;justify-content:space-between;padding:8px 10px;background:var(--bg-elevated);border-radius:5px;text-decoration:none;color:var(--fg);font-size:13px;transition:background 0.12s;"
              onmouseover="this.style.background='var(--nav-active-bg)'" onmouseout="this.style.background='var(--bg-elevated)'">
              <span style="display:flex;align-items:center;gap:6px;">
                <img src={`/coins/${c.symbol.toLowerCase()}.png`} alt={c.symbol}
                  width="18" height="18" style="width:18px;height:18px;object-fit:contain;flex-shrink:0;"
                  onerror={`this.outerHTML='<span style="color:${c.color}">${c.emoji}</span>'`} />
                {c.name[lang]}
              </span>
              <span style="color:var(--fg-muted);font-size:11px;">{c.symbol}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="rsidebar-section">
        <BinanceBanner variant="compact" lang={lang} />
      </div>
    </aside>
  </div>
  <Footer />
</Layout>

<style>
  .coin-price-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border);
  }
  .coin-price-cell {
    padding: 16px 20px;
    border-right: 1px solid var(--border);
  }
  .coin-price-cell:last-child { border-right: none; }
  .coin-price-label { font-size: 11px; color: var(--fg-muted); margin-bottom: 4px; }
  .coin-price-num { font-size: 15px; font-weight: 700; color: var(--fg); font-variant-numeric: tabular-nums; }
  .coin-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .coin-info-row {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .coin-info-label { font-size: 13px; color: var(--fg-muted); flex-shrink: 0; }
  .coin-info-value { font-size: 13px; color: var(--fg); font-weight: 500; text-align: right; line-height: 1.5; }
  .coin-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 14px;
    border-radius: 6px;
    background: var(--btn-bg);
    color: var(--btn-color);
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    transition: opacity 0.12s;
  }
  .coin-link-btn:hover { opacity: 0.75; }
  .chart-period-btn {
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    transition: all 0.12s;
  }
  .chart-period-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
  @media (max-width: 768px) {
    .coin-price-grid { grid-template-columns: 1fr 1fr; }
    .coin-info-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .coin-price-grid { grid-template-columns: 1fr; }
    .coin-price-cell { border-right: none; border-bottom: 1px solid var(--border-subtle); }
  }
</style>

<script is:inline define:vars={{ binanceSymbol: coin.binanceSymbol, coinId: coinEntry.id, coinColor: coin.color, coinSymbol: coin.symbol }}>
(function(){
  const fmt = n => {
    if (!n || isNaN(n)) return "—";
    if (n >= 1e12) return "$"+(n/1e12).toFixed(2)+"T";
    if (n >= 1e9)  return "$"+(n/1e9).toFixed(2)+"B";
    if (n >= 1e6)  return "$"+(n/1e6).toFixed(1)+"M";
    return "$"+n.toLocaleString("en-US",{maximumFractionDigits:0});
  };
  const fmtP = n => {
    if (!n || isNaN(n)) return "—";
    if (n >= 1000) return "$"+n.toLocaleString("en-US",{maximumFractionDigits: n >= 10000 ? 0 : 2});
    if (n >= 1) return "$"+n.toFixed(2);
    return "$"+n.toFixed(4);
  };
  const fmtV = n => {
    if (!n || isNaN(n)) return "—";
    if (n >= 1e9) return (n/1e9).toFixed(2)+"B";
    if (n >= 1e6) return (n/1e6).toFixed(1)+"M";
    if (n >= 1e3) return (n/1e3).toFixed(0)+"K";
    return n.toFixed(0);
  };

  // ── 5-source price fallback (Orbit → OKX → Binance → CoinCap → CoinGecko) ──
  function applyPrice(price, change) {
    const isUp = change >= 0;
    document.getElementById("coin-price").textContent = fmtP(price);
    const ce = document.getElementById("coin-change");
    ce.textContent = (isUp ? "▲ +" : "▼ ") + Math.abs(change).toFixed(2) + "%";
    ce.style.color = isUp ? "var(--accent-green)" : "var(--accent-red)";
    document.getElementById("coin-updated").textContent =
      new Date().toLocaleTimeString(undefined,{hour:"2-digit",minute:"2-digit",second:"2-digit"});
  }

  async function fetchPrice() {
    // 1. Orbit
    try {
      const r = await fetch("https://orbit.biyijia.com/api/coins?per_page=80",{signal:AbortSignal.timeout(8000)});
      if (r.ok) {
        const c = (await r.json()).find(x => x.symbol?.toUpperCase() === coinSymbol);
        if (c) {
          applyPrice(c.current_price, c.price_change_percentage_24h_in_currency ?? 0);
          document.getElementById("coin-high").textContent = fmtP(c.high_24h);
          document.getElementById("coin-low").textContent = fmtP(c.low_24h);
          document.getElementById("coin-vol").textContent = fmt(c.total_volume);
          document.getElementById("coin-mcap").textContent = fmt(c.market_cap);
          if (c.market_cap_rank) document.getElementById("rank-badge").textContent = "#" + c.market_cap_rank;
          return;
        }
      }
    } catch {}
    // 2. OKX
    try {
      const r = await fetch(`https://www.okx.com/api/v5/market/ticker?instId=${coinSymbol}-USDT`,{signal:AbortSignal.timeout(6000)});
      if (r.ok) { const d = (await r.json()).data?.[0]; if (d) { const p=parseFloat(d.last),o=parseFloat(d.open24h); applyPrice(p, o>0?(p-o)/o*100:0); return; } }
    } catch {}
    // 3. Binance
    try {
      const r = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbol=${binanceSymbol}`,{signal:AbortSignal.timeout(6000)});
      if (r.ok) { const t = await r.json(); applyPrice(parseFloat(t.lastPrice), parseFloat(t.priceChangePercent));
        document.getElementById("coin-high").textContent = fmtP(parseFloat(t.highPrice));
        document.getElementById("coin-low").textContent = fmtP(parseFloat(t.lowPrice));
        document.getElementById("coin-vol").textContent = fmt(parseFloat(t.quoteVolume)); return; }
    } catch {}
    // 4. CoinCap
    try {
      const r = await fetch("https://api.coincap.io/v2/assets?limit=100",{signal:AbortSignal.timeout(6000)});
      if (r.ok) { const a = (await r.json()).data?.find(x => x.symbol === coinSymbol); if (a) { applyPrice(parseFloat(a.priceUsd), parseFloat(a.changePercent24Hr)); return; } }
    } catch {}
    // 5. CoinGecko
    try {
      const r = await fetch(`https://api.coingecko.com/api/v3/simple/price?ids=${coinId}&vs_currencies=usd&include_24hr_change=true`,{signal:AbortSignal.timeout(8000)});
      if (r.ok) { const d = (await r.json())[coinId]; if (d) applyPrice(d.usd, d.usd_24h_change ?? 0); }
    } catch {}
  }

  async function fetchMarketData() {
    try {
      const r = await fetch(
        `https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids=${coinId}&sparkline=false`,
        { signal: AbortSignal.timeout(10000) });
      if (!r.ok) return;
      const [d] = await r.json();
      if (!d) return;
      document.getElementById("coin-mcap").textContent = fmt(d.market_cap);
      document.getElementById("coin-supply").textContent =
        d.circulating_supply ? (d.circulating_supply/1e6).toFixed(1)+"M" : "—";
      document.getElementById("rank-badge").textContent = "#"+(d.market_cap_rank||"—");
    } catch {}
  }

  // ── TradingView Lightweight Charts ───────────────────────────
  let _chart = null, _candles = null, _volume = null, _ma7 = null;
  const isDark = () => document.documentElement.getAttribute("data-theme") !== "light";
  const themeColors = () => ({
    text: isDark() ? "#9a9baa" : "#5a5a6a",
    grid: isDark() ? "rgba(255,255,255,0.04)" : "rgba(0,0,0,0.06)",
  });

  function initChart() {
    if (typeof LightweightCharts === "undefined") return false;
    const container = document.getElementById("coin-chart");
    if (!container) return false;
    const c = themeColors();
    _chart = LightweightCharts.createChart(container, {
      width: container.clientWidth, height: 340,
      layout: { background: { type: "solid", color: "transparent" }, textColor: c.text, fontSize: 11 },
      grid: { vertLines: { color: c.grid }, horzLines: { color: c.grid } },
      crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
      rightPriceScale: { borderVisible: false, scaleMargins: { top: 0.08, bottom: 0.22 } },
      timeScale: { borderVisible: false, timeVisible: true, secondsVisible: false },
      handleScroll: { mouseWheel: true, pressedMouseMove: true },
      handleScale: { axisPressedMouseMove: true, mouseWheel: true, pinch: true },
    });
    _candles = _chart.addCandlestickSeries({
      upColor: "#26a69a", downColor: "#ef5350", borderVisible: false,
      wickUpColor: "#26a69a", wickDownColor: "#ef5350",
    });
    _volume = _chart.addHistogramSeries({ priceFormat: { type: "volume" }, priceScaleId: "vol" });
    _chart.priceScale("vol").applyOptions({ scaleMargins: { top: 0.82, bottom: 0 } });
    _ma7 = _chart.addLineSeries({
      color: (coinColor || "#f7931a") + "cc", lineWidth: 1,
      priceLineVisible: false, lastValueVisible: false, crosshairMarkerVisible: false,
    });
    _chart.subscribeCrosshairMove(param => {
      if (!param.time || !_candles) return;
      const d = param.seriesData.get(_candles);
      if (!d) return;
      document.getElementById("ohlc-o").textContent = fmtP(d.open);
      document.getElementById("ohlc-h").textContent = fmtP(d.high);
      document.getElementById("ohlc-l").textContent = fmtP(d.low);
      document.getElementById("ohlc-c").textContent = fmtP(d.close);
      const v = param.seriesData.get(_volume);
      if (v) document.getElementById("ohlc-v").textContent = fmtV(v.value);
    });
    new ResizeObserver(() => {
      if (_chart && container.clientWidth > 0) _chart.applyOptions({ width: container.clientWidth });
    }).observe(container);
    return true;
  }

  async function loadChart(interval, limit) {
    if (!_chart && !initChart()) return;
    try {
      const r = await fetch(
        `https://api.binance.com/api/v3/klines?symbol=${binanceSymbol}&interval=${interval}&limit=${limit}`,
        { signal: AbortSignal.timeout(8000) });
      if (!r.ok) return;
      const raw = await r.json();
      const candles = raw.map(k => ({
        time: Math.floor(k[0]/1000),
        open: parseFloat(k[1]), high: parseFloat(k[2]),
        low:  parseFloat(k[3]), close: parseFloat(k[4]),
      }));
      const volumes = raw.map(k => ({
        time: Math.floor(k[0]/1000), value: parseFloat(k[5]),
        color: parseFloat(k[4]) >= parseFloat(k[1]) ? "#26a69a55" : "#ef535055",
      }));
      const ma7 = candles.map((c, i) => {
        if (i < 6) return null;
        return { time: c.time, value: candles.slice(i-6,i+1).reduce((s,x)=>s+x.close,0)/7 };
      }).filter(Boolean);
      _candles.setData(candles);
      _volume.setData(volumes);
      _ma7.setData(ma7);
      _chart.timeScale().fitContent();
      const last = candles[candles.length-1];
      if (last) {
        document.getElementById("ohlc-o").textContent = fmtP(last.open);
        document.getElementById("ohlc-h").textContent = fmtP(last.high);
        document.getElementById("ohlc-l").textContent = fmtP(last.low);
        document.getElementById("ohlc-c").textContent = fmtP(last.close);
        document.getElementById("ohlc-v").textContent = fmtV(volumes[volumes.length-1]?.value);
      }
    } catch(e) { console.warn("Chart error:", e); }
  }

  document.getElementById("chart-btns")?.addEventListener("click", e => {
    const btn = e.target.closest("[data-interval]");
    if (!btn) return;
    document.querySelectorAll(".chart-period-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    loadChart(btn.dataset.interval, parseInt(btn.dataset.limit));
  });

  new MutationObserver(() => {
    if (!_chart) return;
    const c = themeColors();
    _chart.applyOptions({
      layout: { textColor: c.text },
      grid: { vertLines: { color: c.grid }, horzLines: { color: c.grid } },
    });
  }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

  fetchPrice();
  fetchMarketData();
  loadChart("1h", 24);
  setInterval(fetchPrice, 30000);
  setInterval(fetchMarketData, 120000);
})();
</script>
<script src="https://unpkg.com/lightweight-charts@4.2.0/dist/lightweight-charts.standalone.production.js"></script>
