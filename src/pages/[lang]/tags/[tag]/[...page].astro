---
// src/pages/[lang]/tags/[tag]/[...page].astro
// 多语言标签聚合页（SSR）：合并本地 + Sanity 文章
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import UnifiedCard from "@/components/UnifiedCard.astro";
import { getCollection } from "astro:content";
import { SITE } from "@/config";
import { getPath } from "@/utils/getPath";
import {
  localToUnified,
  fetchSanityUnified,
  mergePosts,
  filterUnifiedByLang,
  type UnifiedPost,
} from "@/utils/mergedPosts";
import getSortedPosts from "@/utils/getSortedPosts";
import { LANG_PATH_MAP, LANG_TO_PATH, type Lang } from "@/i18n/ui";

const { lang: langPath, tag } = Astro.params;
const lang: Lang = LANG_PATH_MAP[langPath ?? ""] ?? "en";
const basePath = `/${LANG_TO_PATH[lang]}`;

// 解码标签（URL编码 → 原始字符串）
const decodedTag = decodeURIComponent(tag ?? "");

if (!decodedTag) return Astro.redirect("/404");

const PAGE_SIZE = SITE.postPerPage ?? 10;
// [...page] 参数：undefined = page 1，"2" = page 2
const rawPage = Astro.params.page;
const pageNum = rawPage ? Number(rawPage) : 1;

// ── 多语言文案 ────────────────────────────────────────────────
const L: Record<string, Record<string, string>> = {
  "zh-TW": {
    home: "首頁", tags: "標籤",
    desc: "篇關於「{tag}」的文章 — 包含行情分析、使用教程、安全指南等加密貨幣與區塊鏈內容。",
    empty: "暫無相關文章",
    prev: "← 上一頁", next: "下一頁 →",
  },
  en: {
    home: "Home", tags: "Tags",
    desc: "articles tagged \"{tag}\" — market analysis, tutorials & guides on crypto and blockchain.",
    empty: "No articles found",
    prev: "← Previous", next: "Next →",
  },
  es: {
    home: "Inicio", tags: "Etiquetas",
    desc: "artículos con la etiqueta \"{tag}\" — análisis de mercado, tutoriales y guías de cripto.",
    empty: "No hay artículos",
    prev: "← Anterior", next: "Siguiente →",
  },
  pt: {
    home: "Início", tags: "Tags",
    desc: "artigos com a tag \"{tag}\" — análise de mercado, tutoriais e guias de cripto.",
    empty: "Nenhum artigo encontrado",
    prev: "← Anterior", next: "Próxima →",
  },
};
const t = L[lang] || L["en"];

// ── 拉取本地 Markdown ─────────────────────────────────────────
let localUnified: UnifiedPost[] = [];
try {
  const posts = await getCollection("blog");
  localUnified = getSortedPosts(posts).map(p => localToUnified(p, getPath(p.id, p.filePath)));
} catch (e) {}

// ── 拉取 Sanity（指定语言，取足够多的文章）────────────────────
let sanityUnified: UnifiedPost[] = [];
try {
  sanityUnified = await fetchSanityUnified({ lang, limit: 500 });
} catch (e) {}

// ── 合并 & 语言过滤 ──────────────────────────────────────────
const merged = filterUnifiedByLang(
  mergePosts(localUnified, [], sanityUnified),
  lang
);

// ── 按标签过滤 ───────────────────────────────────────────────
const tagLower = decodedTag.toLowerCase();
const tagged = merged.filter(p =>
  (p.tags || []).some(t => t.toLowerCase() === tagLower || t === decodedTag)
);

// ── 分页 ────────────────────────────────────────────────────
const total = tagged.length;
const lastPage = Math.max(1, Math.ceil(total / PAGE_SIZE));

if (pageNum < 1 || (pageNum > lastPage && total > 0)) {
  return Astro.redirect("/404");
}

const pagePosts = tagged.slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE);
const prevUrl = pageNum > 1
  ? `${basePath}/tags/${tag}${pageNum - 1 === 1 ? "" : `/${pageNum - 1}`}`
  : null;
const nextUrl = pageNum < lastPage ? `${basePath}/tags/${tag}/${pageNum + 1}` : null;

// ── 页面描述 ─────────────────────────────────────────────────
const descTemplate = t.desc.replace("{tag}", decodedTag);
const pageDesc = `${total} ${descTemplate}`;

// ── JSON-LD：CollectionPage + BreadcrumbList + ItemList ────
const siteUrl = SITE.website.replace(/\/$/, "");
const pageUrl = `${siteUrl}${basePath}/tags/${encodeURIComponent(decodedTag)}${pageNum > 1 ? `/${pageNum}` : ""}`;

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${pageUrl}#webpage`,
  url: pageUrl,
  name: `#${decodedTag}`,
  description: pageDesc,
  isPartOf: { "@id": `${siteUrl}/#website` },
  inLanguage: lang,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: pagePosts.length,
    itemListElement: pagePosts.map((p, i) => ({
      "@type": "ListItem",
      position: (pageNum - 1) * PAGE_SIZE + i + 1,
      url: p.href?.startsWith("http") ? p.href : `${siteUrl}${p.href}`,
      name: p.title,
    })),
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: t.home, item: `${siteUrl}${basePath || "/"}` },
    { "@type": "ListItem", position: 2, name: t.tags, item: `${siteUrl}${basePath}/tags` },
    { "@type": "ListItem", position: 3, name: `#${decodedTag}`, item: pageUrl },
  ],
};
---

<Layout
  title={`${decodedTag} | ${SITE.title}`}
  description={pageDesc}
  paginationPrev={prevUrl ?? undefined}
  paginationNext={nextUrl ?? undefined}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <main class="main-col" style="padding-bottom:40px;">
      <!-- 面包屑 -->
      <div style="padding:14px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href={basePath || "/"}
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">{t.home}</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <a href={`${basePath}/tags`}
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">{t.tags}</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">#{decodedTag}</span>
      </div>

      <div style="padding:10px 16px 0;">
        <h1 style="font-size:20px;font-weight:700;color:var(--fg);margin-bottom:4px;">
          #{decodedTag}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);">{pageDesc}</p>
      </div>

      <div style="margin-top:12px;">
        {pagePosts.length === 0 ? (
          <div style="padding:60px 16px;text-align:center;color:var(--fg-muted);">
            <p style="font-size:15px;">{t.empty}</p>
          </div>
        ) : (
          <div class="alist">
            {pagePosts.map(p => <UnifiedCard post={p} size="list" variant="h3" />)}
          </div>
        )}
      </div>

      <!-- 分页 -->
      {lastPage > 1 && (
        <div style="margin-top:24px;display:flex;justify-content:center;align-items:center;gap:16px;font-size:13px;padding:0 16px;">
          {prevUrl ? (
            <a href={prevUrl} style="color:var(--accent);text-decoration:none;border:1px solid var(--border);border-radius:6px;padding:6px 14px;transition:border-color 0.12s;"
              onmouseover="this.style.borderColor='var(--accent)'"
              onmouseout="this.style.borderColor='var(--border)'">{t.prev}</a>
          ) : <span />}
          <span style="color:var(--fg-muted);">{pageNum} / {lastPage}</span>
          {nextUrl ? (
            <a href={nextUrl} style="color:var(--accent);text-decoration:none;border:1px solid var(--border);border-radius:6px;padding:6px 14px;transition:border-color 0.12s;"
              onmouseover="this.style.borderColor='var(--accent)'"
              onmouseout="this.style.borderColor='var(--border)'">{t.next}</a>
          ) : <span />}
        </div>
      )}
    </main>

    <!-- 右侧边栏 -->
    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{t.tags}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          {["BTC","ETH","DeFi","NFT","Wallet","Layer2"].map(tk => (
            <a href={`${basePath}/tags/${encodeURIComponent(tk)}`}
              class="ctag"
              style={`text-decoration:none;${tk.toLowerCase() === decodedTag.toLowerCase() ? "background:var(--accent);color:#fff;" : ""}`}>{tk}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <Footer />
</Layout>
