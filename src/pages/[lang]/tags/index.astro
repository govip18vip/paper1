---
// src/pages/[lang]/tags/index.astro
// 多语言标签索引页：/en/tags/ /zh-tw/tags/ /es/tags/ /pt/tags/
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import IconHash from "@/assets/icons/IconHash.svg";
import getUniqueTags from "@/utils/getUniqueTags";
import { SITE } from "@/config";
import {
  LANGUAGES,
  DEFAULT_LANG,
  LANG_TO_PATH,
  useTranslations,
  type Lang,
} from "@/i18n/ui";

export const getStaticPaths = (async () => {
  const nonDefaultLangs = (Object.keys(LANGUAGES) as Lang[]).filter(
    l => l !== DEFAULT_LANG
  );
  return nonDefaultLangs.map(lang => ({
    params: { lang: LANG_TO_PATH[lang] },
    props: { lang },
  }));
}) satisfies GetStaticPaths;

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const langSeg = LANG_TO_PATH[lang]; // "en" | "zh-tw" | "es" | "pt"

const pageDescMap: Record<Lang, string> = {
  "zh-CN": "浏览所有标签",
  "zh-TW": "瀏覽所有標籤",
  "en":    "Browse all tags",
  "es":    "Ver todas las etiquetas",
  "pt":    "Ver todas as tags",
};
const pageDesc = pageDescMap[lang] ?? "Browse all tags";

const posts = await getCollection("blog");
const tags = getUniqueTags(posts);
---

<Layout title={`${t("section.tags")} | ${SITE.title}`} description={pageDesc}>
  <Header />
  <main class="app-layout pb-4">
    <h1 class="text-2xl font-semibold sm:text-3xl">{t("section.tags")}</h1>
    <p class="mt-2 mb-6 italic">{pageDesc}</p>
    <ul class="flex flex-wrap gap-6">
      {tags.map(({ tag, tagName }) => (
        <li>
          <a
            href={`/${langSeg}/tags/${tag}/`}
            transition:name={`lang-${langSeg}-${tag}`}
            class="flex items-center gap-0.5 border-b-2 border-dashed border-foreground text-lg hover:-mt-0.5 hover:border-accent hover:text-accent focus-visible:border-none focus-visible:text-accent"
          >
            <IconHash class="size-5 opacity-80" />
            {tagName}
          </a>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</Layout>
