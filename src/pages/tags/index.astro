---
// src/pages/tags/index.astro
// zh-CN 标签索引页（SSR）：合并本地 + Sanity + Ghost 的所有标签
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import { getCollection } from "astro:content";
import { SITE } from "@/config";
import { getPath } from "@/utils/getPath";
import {
  localToUnified,
  fetchGhostUnified,
  fetchSanityUnified,
  mergePosts,
  filterUnifiedByLang,
} from "@/utils/mergedPosts";
import getSortedPosts from "@/utils/getSortedPosts";

let allPosts: any[] = [];
try {
  const local = await getCollection("blog");
  const localU = getSortedPosts(local).map(p => localToUnified(p, getPath(p.id, p.filePath)));
  const ghost = await fetchGhostUnified({ lang: "zh-CN", limit: 100 }).catch(() => []);
  const sanity = await fetchSanityUnified({ lang: "zh-CN", limit: 100 }).catch(() => []);
  allPosts = filterUnifiedByLang(mergePosts(localU, ghost, sanity), "zh-CN");
} catch (e) {}

// 统计每个标签的文章数（大小写不敏感合并，保留首次出现的原始大小写）
const tagCount = new Map<string, { count: number; display: string }>();
for (const p of allPosts) {
  for (const t of (p.tags || [])) {
    const key = t.toLowerCase();
    const existing = tagCount.get(key);
    if (existing) {
      existing.count++;
    } else {
      tagCount.set(key, { count: 1, display: t });
    }
  }
}

// 按文章数降序排列
const tags = Array.from(tagCount.entries())
  .sort((a, b) => b[1].count - a[1].count)
  .map(([, { display, count }]) => ({ tag: display, count }));
---

<Layout
  title={`标签 | ${SITE.title}`}
  description="Bitaigen 全部文章标签索引 — 比特币、以太坊、DeFi、NFT等加密货币主题"
>
  <Header />

  <div class="site-outer">
    <LeftSidebar />

    <main class="main-col" style="padding-bottom:40px;">
      <!-- 面包屑 -->
      <div style="padding:14px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href="/"
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">首页</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">标签</span>
      </div>

      <div style="padding:10px 16px 0;">
        <h1 style="font-size:20px;font-weight:700;color:var(--fg);margin-bottom:4px;">标签索引</h1>
        <p style="font-size:13px;color:var(--fg-muted);">共 {tags.length} 个标签，点击标签查看相关文章</p>
      </div>

      <div style="padding:16px;display:flex;flex-wrap:wrap;gap:10px;">
        {tags.map(({ tag, count }) => (
          <a
            href={`/tags/${encodeURIComponent(tag)}`}
            style="display:inline-flex;align-items:center;gap:6px;border-radius:20px;border:1px solid var(--border);background:var(--bg-card);padding:6px 14px;font-size:13px;color:var(--fg);text-decoration:none;transition:border-color 0.12s,color 0.12s;"
            onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'"
            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--fg)'"
          >
            <span>#{tag}</span>
            <span style="font-size:11px;color:var(--fg-muted);">{count}</span>
          </a>
        ))}
      </div>
    </main>

    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">热门话题</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          {tags.slice(0, 12).map(({ tag }) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="ctag" style="text-decoration:none;">{tag}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <Footer />
</Layout>
