---
// src/pages/tags/[tag]/[...page].astro
// zh-CN 标签聚合页（SSR）：合并本地 + Ghost + Sanity 文章
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import UnifiedCard from "@/components/UnifiedCard.astro";
import { getCollection } from "astro:content";
import { SITE } from "@/config";
import { getPath } from "@/utils/getPath";
import {
  localToUnified,
  fetchGhostUnified,
  fetchSanityUnified,
  mergePosts,
  filterUnifiedByLang,
  type UnifiedPost,
} from "@/utils/mergedPosts";
import getSortedPosts from "@/utils/getSortedPosts";

const { tag } = Astro.params;
const pageNum = Number(Astro.params.page ?? 1);
const PAGE_SIZE = SITE.postPerPage ?? 10;

if (!tag) return Astro.redirect("/404");

// 解码标签（URL编码 → 原始字符串）
const decodedTag = decodeURIComponent(tag);

// ── 拉取三个来源 ─────────────────────────────────────────────
let localUnified: UnifiedPost[] = [];
try {
  const posts = await getCollection("blog");
  localUnified = getSortedPosts(posts).map(p => localToUnified(p, getPath(p.id, p.filePath)));
} catch (e) {}

let ghostUnified: UnifiedPost[] = [];
try {
  ghostUnified = await fetchGhostUnified({ limit: 50 });
} catch (e) {}

let sanityUnified: UnifiedPost[] = [];
try {
  sanityUnified = await fetchSanityUnified({ limit: 500 });
} catch (e) {}

// ── 合并 & 按语言过滤（zh-CN 标签页只显示中文） ─────────────
const merged = filterUnifiedByLang(
  mergePosts(localUnified, ghostUnified, sanityUnified),
  "zh-CN"
);

// ── 按标签过滤（大小写不敏感） ──────────────────────────────
const tagLower = decodedTag.toLowerCase();
const tagged = merged.filter(p =>
  (p.tags || []).some(t => t.toLowerCase() === tagLower || t === decodedTag)
);

// ── 分页 ────────────────────────────────────────────────────
const total = tagged.length;
const lastPage = Math.max(1, Math.ceil(total / PAGE_SIZE));

if (pageNum < 1 || (pageNum > lastPage && total > 0)) {
  return Astro.redirect("/404");
}

const pagePosts = tagged.slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE);
const prevUrl = pageNum > 1 ? `/tags/${tag}/${pageNum - 1 === 1 ? "" : pageNum - 1}` : null;
const nextUrl = pageNum < lastPage ? `/tags/${tag}/${pageNum + 1}` : null;

// ── JSON-LD：CollectionPage + Breadcrumb + ItemList ───────
const siteUrl = SITE.website.replace(/\/$/, "");
const pageUrl = `${siteUrl}/tags/${encodeURIComponent(tag)}${pageNum > 1 ? `/${pageNum}` : ""}`;

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${pageUrl}#webpage`,
  name: `${decodedTag} — ${SITE.title}`,
  description: `${decodedTag}相关的全部文章`,
  url: pageUrl,
  isPartOf: { "@id": `${siteUrl}/#website` },
  inLanguage: "zh-CN",
  numberOfItems: total,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: pagePosts.length,
    itemListElement: pagePosts.map((p, i) => ({
      "@type": "ListItem",
      position: (pageNum - 1) * PAGE_SIZE + i + 1,
      url: p.href?.startsWith("http") ? p.href : `${siteUrl}${p.href}`,
      name: p.title,
    })),
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首页", item: siteUrl + "/" },
    { "@type": "ListItem", position: 2, name: "标签", item: `${siteUrl}/tags` },
    { "@type": "ListItem", position: 3, name: `#${decodedTag}`, item: pageUrl },
  ],
};
---

<Layout
  title={`${decodedTag} — 最新资讯与深度分析 | ${SITE.title}`}
  description={`${decodedTag}相关的全部 ${total} 篇文章 — 涵盖行情分析、使用教程、安全指南等加密货币与区块链专业内容。`}
  paginationPrev={prevUrl ?? undefined}
  paginationNext={nextUrl ?? undefined}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <Header />

  <div class="site-outer">
    <LeftSidebar />

    <main class="main-col" style="padding-bottom:40px;">
      <!-- 面包屑 -->
      <div style="padding:14px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href="/"
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">首页</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <a href="/tags"
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">标签</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">#{decodedTag}</span>
      </div>

      <div style="padding:10px 16px 0;">
        <h1 style="font-size:20px;font-weight:700;color:var(--fg);margin-bottom:4px;">
          #{decodedTag}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);">
          共 {total} 篇关于「{decodedTag}」的专业文章
        </p>
      </div>

      <div style="margin-top:12px;">
        {pagePosts.length === 0 ? (
          <div style="padding:60px 16px;text-align:center;color:var(--fg-muted);">
            <p style="font-size:15px;">暂无相关文章</p>
          </div>
        ) : (
          <div class="alist">
            {pagePosts.map(p => <UnifiedCard post={p} size="list" variant="h3" />)}
          </div>
        )}
      </div>

      <!-- 分页 -->
      {lastPage > 1 && (
        <div style="margin-top:24px;display:flex;justify-content:center;align-items:center;gap:16px;font-size:13px;padding:0 16px;">
          {prevUrl ? (
            <a href={prevUrl} style="color:var(--accent);text-decoration:none;border:1px solid var(--border);border-radius:6px;padding:6px 14px;transition:border-color 0.12s;"
              onmouseover="this.style.borderColor='var(--accent)'"
              onmouseout="this.style.borderColor='var(--border)'">← 上一页</a>
          ) : <span />}
          <span style="color:var(--fg-muted);">{pageNum} / {lastPage}</span>
          {nextUrl ? (
            <a href={nextUrl} style="color:var(--accent);text-decoration:none;border:1px solid var(--border);border-radius:6px;padding:6px 14px;transition:border-color 0.12s;"
              onmouseover="this.style.borderColor='var(--accent)'"
              onmouseout="this.style.borderColor='var(--border)'">下一页 →</a>
          ) : <span />}
        </div>
      )}
    </main>

    <!-- 右侧边栏：相关标签 -->
    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">相关标签</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          {["BTC","ETH","DeFi","NFT","钱包","新手入门","交易所","比特币","以太坊","Layer2"].map(t => (
            <a href={`/tags/${encodeURIComponent(t)}`}
              class="ctag"
              style={`text-decoration:none;${t.toLowerCase() === tagLower ? "background:var(--accent);color:#fff;" : ""}`}>{t}</a>
          ))}
        </div>
      </div>
      <div class="rsidebar-section" style="margin-top:16px;">
        <div class="rsidebar-head">全部标签</div>
        <a href="/tags" style="font-size:12px;color:var(--accent);text-decoration:none;display:block;margin-top:6px;">
          查看所有标签 →
        </a>
      </div>
    </aside>
  </div>

  <Footer />
</Layout>
