---
// src/pages/tools/defi.astro
// DeFi TVL Dashboard — real-time data from DefiLlama (free, no key)
export const prerender = false;
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const title = "DeFi TVL 排行榜 — 去中心化金融锁仓量实时排名";
const desc = "实时追踪DeFi协议总锁仓量(TVL)排行：Aave、Lido、Uniswap、Curve等主流协议数据，来自DefiLlama。";

// Server-side fetch from DefiLlama
let protocols: any[] = [];
try {
  const r = await fetch("https://api.llama.fi/protocols", { signal: AbortSignal.timeout(8000) });
  if (r.ok) {
    const all = await r.json();
    protocols = all
      .filter((p: any) => p.tvl > 100_000_000) // >$100M TVL
      .sort((a: any, b: any) => (b.tvl ?? 0) - (a.tvl ?? 0))
      .slice(0, 30);
  }
} catch {}

let chains: any[] = [];
try {
  const r = await fetch("https://api.llama.fi/v2/chains", { signal: AbortSignal.timeout(8000) });
  if (r.ok) {
    chains = (await r.json())
      .sort((a: any, b: any) => (b.tvl ?? 0) - (a.tvl ?? 0))
      .slice(0, 15);
  }
} catch {}

const fmtB = (n: number) => n >= 1e9 ? "$" + (n/1e9).toFixed(2) + "B" : "$" + (n/1e6).toFixed(0) + "M";
const totalTVL = protocols.reduce((s, p) => s + (p.tvl ?? 0), 0);
---

<Layout title={`${title} | ${SITE.title}`} description={desc}>
  <Header />
  <main style="max-width:900px;margin:0 auto;padding:24px 16px 60px;">
    <nav style="font-size:13px;color:var(--fg-muted);margin-bottom:16px;">
      <a href="/" style="color:var(--fg-muted);text-decoration:none;">首页</a>
      <span style="margin:0 6px;opacity:0.5;">›</span>
      <span style="color:var(--fg);">DeFi TVL</span>
    </nav>

    <h1 style="font-size:24px;font-weight:800;color:var(--fg);margin:0 0 4px;">DeFi TVL 排行榜</h1>
    <p style="font-size:13px;color:var(--fg-muted);margin:0 0 6px;">数据来源：DefiLlama · 实时更新</p>
    {totalTVL > 0 && <p style="font-size:20px;font-weight:800;color:var(--accent);margin:0 0 20px;">Total TVL: {fmtB(totalTVL)}</p>}

    <!-- Protocol Ranking -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:20px;">
      <div style="padding:14px 16px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;color:var(--fg);display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:16px;background:var(--accent);border-radius:2px;"></span>
        Top 30 DeFi 协议（按 TVL）
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:2px solid var(--border);">
            <th style="text-align:left;padding:10px 12px;color:var(--fg-muted);font-weight:600;width:30px;">#</th>
            <th style="text-align:left;padding:10px 8px;color:var(--fg-muted);font-weight:600;">协议</th>
            <th style="text-align:left;padding:10px 8px;color:var(--fg-muted);font-weight:600;">链</th>
            <th style="text-align:right;padding:10px 12px;color:var(--fg-muted);font-weight:600;">TVL</th>
            <th style="text-align:right;padding:10px 12px;color:var(--fg-muted);font-weight:600;">24h</th>
          </tr></thead>
          <tbody>
            {protocols.map((p, i) => {
              const change = p.change_1d ?? 0;
              const isUp = change >= 0;
              return (
                <tr style="border-bottom:1px solid var(--border-subtle);">
                  <td style="padding:10px 12px;color:var(--fg-muted);font-weight:600;">{i + 1}</td>
                  <td style="padding:10px 8px;">
                    <div style="display:flex;align-items:center;gap:8px;">
                      {p.logo && <img src={p.logo} alt={p.name} width="20" height="20" style="border-radius:50%;flex-shrink:0;" loading="lazy" />}
                      <div>
                        <div style="font-weight:600;color:var(--fg);">{p.name}</div>
                        <div style="font-size:11px;color:var(--fg-muted);">{p.category}</div>
                      </div>
                    </div>
                  </td>
                  <td style="padding:10px 8px;font-size:11px;color:var(--fg-muted);">{(p.chains ?? []).slice(0, 3).join(", ")}</td>
                  <td style="padding:10px 12px;text-align:right;font-weight:700;color:var(--fg);">{fmtB(p.tvl)}</td>
                  <td style={`padding:10px 12px;text-align:right;font-weight:600;color:${isUp ? 'var(--accent-green)' : 'var(--accent-red)'};`}>
                    {isUp ? "+" : ""}{change.toFixed(1)}%
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Chain TVL -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:20px;">
      <div style="padding:14px 16px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;color:var(--fg);display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:16px;background:var(--accent-green);border-radius:2px;"></span>
        按链排名 TVL
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:2px solid var(--border);">
            <th style="text-align:left;padding:10px 12px;color:var(--fg-muted);font-weight:600;width:30px;">#</th>
            <th style="text-align:left;padding:10px 8px;color:var(--fg-muted);font-weight:600;">链</th>
            <th style="text-align:right;padding:10px 12px;color:var(--fg-muted);font-weight:600;">TVL</th>
          </tr></thead>
          <tbody>
            {chains.map((c, i) => (
              <tr style="border-bottom:1px solid var(--border-subtle);">
                <td style="padding:10px 12px;color:var(--fg-muted);font-weight:600;">{i + 1}</td>
                <td style="padding:10px 8px;font-weight:600;color:var(--fg);">{c.name}</td>
                <td style="padding:10px 12px;text-align:right;font-weight:700;color:var(--fg);">{fmtB(c.tvl)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p style="font-size:11px;color:var(--fg-muted);text-align:center;">
      数据来源：<a href="https://defillama.com" target="_blank" rel="noopener noreferrer" style="color:var(--accent);">DefiLlama</a> · 开始 DeFi 交易：<a href="/go/binance" rel="sponsored" style="color:var(--accent);">币安</a> | <a href="/go/okx" rel="sponsored" style="color:var(--accent);">OKX</a>
    </p>
  </main>
  <Footer />
</Layout>
