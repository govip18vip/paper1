---
// src/pages/posts/[...page].astro
// 默认语言（zh-CN）文章列表：/posts/  /posts/2/  /posts/3/ ...
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import { SITE } from "@/config";
import { DEFAULT_LANG, useTranslations } from "@/i18n/ui";
import { filterPostsByLang } from "@/utils/homePage";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  // 只生成默认语言（zh-CN）的文章列表页
  const langPosts = filterPostsByLang(allPosts, DEFAULT_LANG);
  return paginate(langPosts, { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const lang = DEFAULT_LANG;
const t = useTranslations(lang);
const { page } = Astro.props;
---

<Layout
  title={`${t("section.all")} | ${t("site.name")}`}
  description={t("site.desc")}
>
  <Header />

  <div class="site-outer">
    <LeftSidebar />

    <div class="main-col" style="padding-bottom:40px;">
      <!-- Breadcrumb -->
      <div style="padding:14px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href="/"
          style="color:var(--fg-muted);text-decoration:none;transition:color 0.12s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-muted)'">
          {t("nav.home")}
        </a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">{t("section.all")}</span>
      </div>

      <div style="padding:10px 16px 0;">
        <h1 style="font-size:20px;font-weight:700;color:var(--fg);margin-bottom:4px;">
          {t("section.all")}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);">{t("site.desc.short")}</p>
      </div>

      <div style="margin-top:12px;">
        {page.data.length > 0 ? (
          <div class="alist">
            {page.data.map(data => <Card {...data} size="list" variant="h3" />)}
          </div>
        ) : (
          <div style="padding:60px 16px;text-align:center;color:var(--fg-muted);">
            <p style="font-size:15px;margin-bottom:8px;">📝 暂无文章</p>
          </div>
        )}
      </div>

      <Pagination {page} />
    </div>

    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{t("section.tags")}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          {["BTC","ETH","DeFi","NFT","钱包","新手入门"].map(tag => (
            <a href={`/tags/${tag.toLowerCase()}`} class="ctag" style="text-decoration:none;">{tag}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <Footer />
</Layout>
