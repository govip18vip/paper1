---
// src/pages/price/index.astro
// ─────────────────────────────────────────────────────────────
// CoinMarketCap 风格行情总览页 /price
// 使用 Binance API（无认证） + CoinGecko 补充市值
// 完整多语言支持
// ─────────────────────────────────────────────────────────────

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import { SITE } from "@/config";
import { getLang, useTranslations, type Lang } from "@/i18n/ui";
import { MAJOR_COINS, COIN_DB } from "@/utils/coinInfo";

const lang = getLang(Astro.url) as Lang;
const t = useTranslations(lang);

// 多语言标题映射
const pageTitle: Record<Lang, string> = {
  "zh-CN": "加密货币实时行情",
  "zh-TW": "加密貨幣即時行情",
  en: "Cryptocurrency Live Prices",
  es: "Precios Cripto en Vivo",
  pt: "Preços Cripto ao Vivo",
};

const pageDesc: Record<Lang, string> = {
  "zh-CN": "实时追踪 BTC、ETH 等主流加密货币价格，24h涨跌幅、市值排行 — 数据来源 Binance",
  "zh-TW": "即時追蹤 BTC、ETH 等主流加密貨幣價格，24h漲跌幅、市值排行",
  en: "Track real-time BTC, ETH and major cryptocurrency prices with 24h changes & market cap — powered by Binance",
  es: "Siga precios de BTC, ETH y criptomonedas principales en tiempo real",
  pt: "Acompanhe preços de BTC, ETH e principais criptomoedas em tempo real",
};

const labels: Record<string, Record<Lang, string>> = {
  coin:     { "zh-CN": "币种", "zh-TW": "幣種", en: "Coin", es: "Moneda", pt: "Moeda" },
  price:    { "zh-CN": "价格 (USD)", "zh-TW": "價格 (USD)", en: "Price (USD)", es: "Precio (USD)", pt: "Preço (USD)" },
  change:   { "zh-CN": "24h涨跌", "zh-TW": "24h漲跌", en: "24h Change", es: "24h Cambio", pt: "24h Variação" },
  mcap:     { "zh-CN": "市值", "zh-TW": "市值", en: "Market Cap", es: "Cap. Mercado", pt: "Cap. Mercado" },
  vol:      { "zh-CN": "24h成交量", "zh-TW": "24h成交量", en: "24h Volume", es: "Vol. 24h", pt: "Vol. 24h" },
  rank:     { "zh-CN": "排名", "zh-TW": "排名", en: "Rank", es: "Rango", pt: "Rank" },
  source:   { "zh-CN": "数据来源：Orbit / Binance · 每30秒更新", "zh-TW": "數據來源：CryptoBubbles / Binance · 每30秒更新", en: "Data: CryptoBubbles / Binance · Updates every 30s", es: "Datos: CryptoBubbles / Binance · Actualiza cada 30s", pt: "Dados: CryptoBubbles / Binance · Atualiza a cada 30s" },
  detail:   { "zh-CN": "热门币种详情", "zh-TW": "熱門幣種詳情", en: "Popular Coins", es: "Monedas Populares", pt: "Moedas Populares" },
  viewAll:  { "zh-CN": "查看详情 →", "zh-TW": "查看詳情 →", en: "View Details →", es: "Ver Detalles →", pt: "Ver Detalhes →" },
};

const siteUrl = SITE.website.replace(/\/$/, "");

const pricePageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}/price/#webpage`,
  name: pageTitle[lang],
  description: pageDesc[lang],
  url: `${siteUrl}/price`,
  inLanguage: lang,
  isPartOf: { "@id": `${siteUrl}/#website` },
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: lang === "en" ? "Home" : "首页", item: siteUrl + "/" },
      { "@type": "ListItem", position: 2, name: pageTitle[lang], item: `${siteUrl}/price` },
    ],
  },
};

// ItemList schema for price table (rich snippet for crypto prices)
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle[lang],
  numberOfItems: MAJOR_COINS.length,
  itemListElement: MAJOR_COINS.slice(0, 10).map((coin, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: `${coin.name[lang]} (${coin.symbol})`,
    url: `${siteUrl}/price/${coin.symbol.toLowerCase()}`,
  })),
};
---

<Layout
  title={`${pageTitle[lang]} | ${t("site.name")}`}
  description={pageDesc[lang]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(pricePageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <link rel="preconnect" href="https://api.binance.com" />
  </Fragment>

  <Header />
  <div class="site-outer">
    <LeftSidebar currentLang={lang} />
    <main class="main-col" id="main-content">

      <nav style="padding:12px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href="/" style="color:var(--fg-muted);text-decoration:none;">{t("nav.home")}</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">{pageTitle[lang]}</span>
      </nav>
      <div style="padding:8px 16px 0;">
        <h1 style="font-size:22px;font-weight:800;color:var(--fg);margin:0 0 4px;">
          {pageTitle[lang]}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);margin:0;">{labels.source[lang]}</p>
      </div>

      <!-- ══ 我的自选 Watchlist ══ -->
      <section id="watchlist" style="padding:12px 16px 0;display:none;">
        <div style="background:var(--bg-card);border:1px solid var(--accent);border-radius:8px;overflow:hidden;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid var(--border);">
            <span style="font-size:14px;font-weight:700;color:var(--accent);display:flex;align-items:center;gap:6px;">
              <span style="font-size:16px;">&#9733;</span>
              <span data-i18n="watchlist.title">{t("watchlist.title")}</span>
            </span>
            <span id="wl-since" style="font-size:11px;color:var(--fg-muted);display:none;"></span>
          </div>
          <div id="watchlist-rows"></div>
          <div id="watchlist-empty" style="padding:16px;text-align:center;font-size:12px;color:var(--fg-muted);display:none;" data-i18n="watchlist.empty">
            {t("watchlist.empty")}
          </div>
        </div>
      </section>

      <!-- ══ 价格表格 ══ -->
      <section style="padding:12px 16px 0;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;overflow:hidden;">
          <!-- 表头 -->
          <div class="price-table-head">
            <span style="min-width:28px;text-align:center;cursor:pointer;" title="Watchlist">&#9734;</span>
            <span style="min-width:30px;text-align:center;">#</span>
            <span style="flex:2;">{labels.coin[lang]}</span>
            <span style="flex:1;text-align:right;">{labels.price[lang]}</span>
            <span style="flex:1;text-align:right;" class="hide-mobile-sm">{labels.change[lang]}</span>
            <span style="flex:1;text-align:right;" class="hide-tablet">{labels.vol[lang]}</span>
            <span style="flex:1;text-align:right;" class="hide-tablet">{labels.mcap[lang]}</span>
            <span style="min-width:72px;text-align:right;" class="hide-mobile-sm">交易</span>
          </div>

          <!-- 币种行 -->
          <div id="price-table">
            {MAJOR_COINS.map((coin, i) => (
              <div class="price-row" data-coin={coin.id} data-symbol={coin.symbol}
                style="cursor:pointer;"
                role="link" tabindex="0"
              >
                <button class="wl-star" data-wl={coin.symbol} onclick="event.stopPropagation();" aria-label={`Toggle ${coin.symbol} watchlist`}>&#9734;</button>
                <span class="price-rank" id={`r-${coin.id}`}>{i + 1}</span>
                <div class="price-coin-info">
                  <div class="price-coin-icon" style={`background:${coin.color}22;border-color:${coin.color}44;overflow:hidden;`}>
                    <img src={`/coins/${coin.symbol.toLowerCase()}.png`} alt={coin.symbol}
                      width="20" height="20" style="width:20px;height:20px;object-fit:contain;"
                      onerror={`this.outerHTML='<span style="color:${coin.color};font-size:14px">${coin.emoji}</span>'`} />
                  </div>
                  <div style="min-width:0;">
                    <div class="price-coin-name">{coin.name[lang]}</div>
                    <div class="price-coin-sym">{coin.symbol}</div>
                  </div>
                </div>
                <div id={`p-${coin.id}`} class="price-val">—</div>
                <div id={`c-${coin.id}`} class="price-change hide-mobile-sm">—</div>
                <div id={`v-${coin.id}`} class="price-vol hide-tablet">—</div>
                <div id={`m-${coin.id}`} class="price-mcap hide-tablet">—</div>
                <div class="price-trade hide-mobile-sm" onclick="event.stopPropagation()">
                  <a href={`https://www.binance.com/trade/${coin.symbol}_USDT?layout=pro&ref=B2345&type=spot`}
                    target="_blank" rel="noopener noreferrer sponsored"
                    class="trade-btn-bin" title={`Trade ${coin.symbol} on Binance`}>B</a>
                  <a href={`https://www.okx.com/trade-spot/${coin.symbol.toLowerCase()}-usdt?channelid=B2345`}
                    target="_blank" rel="noopener noreferrer sponsored"
                    class="trade-btn-okx" title={`Trade ${coin.symbol} on OKX`}>O</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 币安横幅 -->
      <div style="padding:0 16px;">
        <BinanceBanner variant="hero" lang={lang} />
      </div>

      <!-- ══ 热门币种卡片 ══ -->
      <section style="padding:0 16px 20px;">
        <div class="sec-head" style="padding-left:0;margin-bottom:12px;">
          <span class="sec-head-title">{labels.detail[lang]}</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">
          {MAJOR_COINS.slice(0, 8).map(coin => (
            <a href={`/price/${coin.symbol.toLowerCase()}`}
              class="coin-detail-card"
              style={`--coin-color:${coin.color};`}
            >
              <div class="coin-detail-icon" style={`background:${coin.color}22;border-color:${coin.color}44;overflow:hidden;`}>
                <img src={`/coins/${coin.symbol.toLowerCase()}.png`} alt={coin.symbol}
                  width="24" height="24" style="width:24px;height:24px;object-fit:contain;"
                  onerror={`this.outerHTML='<span style="color:${coin.color};font-size:18px">${coin.emoji}</span>'`} />
              </div>
              <div style="min-width:0;">
                <div style="font-size:13px;font-weight:700;color:var(--fg);">{coin.symbol}</div>
                <div style="font-size:11px;color:var(--fg-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{coin.name[lang]}</div>
                <div style="font-size:10px;color:var(--fg-light);margin-top:2px;">{labels.viewAll[lang]}</div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- 购买教程快捷入口 -->
      <section style="padding:0 16px 20px;">
        <div class="sec-head" style="padding-left:0;margin-bottom:12px;">
          <span class="sec-head-title">{lang === "en" ? "Buying Guides" : "购买教程"}</span>
          <a href="/posts" class="sec-head-more">{lang === "en" ? "All Articles" : "全部文章"} →</a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px;">
          {[
            { label: lang === "en" ? "How to Buy BTC" : "如何购买比特币", href: lang === "en" ? "/posts/en/how-to-buy-bitcoin-2026-en" : "/posts/zh-cn/how-to-buy-btc-zh-cn" },
            { label: lang === "en" ? "How to Buy ETH" : "如何购买以太坊", href: `/posts/${lang === "en" ? "en/how-to-buy-eth-2026-en" : "zh-cn/how-to-buy-eth-zh-cn"}` },
            { label: lang === "en" ? "How to Buy SOL" : "如何购买SOL", href: `/posts/${lang === "en" ? "en/how-to-buy-sol-2026-en" : "zh-cn/how-to-buy-sol-zh-cn"}` },
            { label: lang === "en" ? "Buy USDT (P2P)" : "如何购买USDT", href: "/posts/zh-cn/how-to-buy-usdt-p2p-zh-cn" },
            { label: lang === "en" ? "Binance Guide" : "币安注册教程", href: "/posts/zh-cn/binance-register-guide-zh-cn" },
            { label: lang === "en" ? "OKX Guide" : "OKX注册教程", href: "/posts/zh-cn/okx-register-guide-zh-cn" },
          ].map(item => (
            <a href={item.href}
              style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;text-decoration:none;font-size:12.5px;font-weight:600;color:var(--fg);transition:border-color 0.12s;">
              <span style="color:var(--accent);">📖</span>
              {item.label}
            </a>
          ))}
        </div>
      </section>

    </main>

    <!-- 右侧栏 -->
    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <BinanceBanner variant="compact" lang={lang} />
      </div>
    </aside>
  </div>
  <Footer />
</Layout>

<style>
  .price-table-head {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 10px 16px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    font-size: 11px;
    font-weight: 700;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .price-row {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-subtle);
    text-decoration: none;
    color: var(--fg);
    transition: background 0.12s;
  }
  .price-row:last-child { border-bottom: none; }
  .price-row:hover { background: var(--bg-elevated); }
  .wl-star {
    min-width: 28px;
    background: none;
    border: none;
    font-size: 16px;
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.15s, transform 0.15s;
    text-align: center;
  }
  .wl-star:hover { color: var(--accent); transform: scale(1.2); }
  .price-rank {
    min-width: 30px;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    color: var(--fg-muted);
  }
  .price-coin-info {
    flex: 2;
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .price-coin-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    border: 1px solid;
  }
  .price-coin-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .price-coin-sym {
    font-size: 11px;
    color: var(--fg-muted);
  }
  .price-val {
    flex: 1;
    text-align: right;
    font-size: 13px;
    font-weight: 700;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
  }
  .price-change {
    flex: 1;
    text-align: right;
    font-size: 12px;
    font-weight: 600;
  }
  .price-vol, .price-mcap {
    flex: 1;
    text-align: right;
    font-size: 12px;
    color: var(--fg-muted);
  }
  .coin-detail-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }
  .coin-detail-card:hover {
    border-color: var(--coin-color, var(--accent));
    transform: translateY(-1px);
  }
  .coin-detail-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid;
  }

  .price-trade {
    display: flex;
    gap: 5px;
    align-items: center;
    min-width: 72px;
    justify-content: flex-end;
  }
  .trade-btn-bin, .trade-btn-okx {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 900;
    text-decoration: none;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .trade-btn-bin { background: #F0B90B; color: #111; }
  .trade-btn-okx { background: #1a1a1a; color: #fff; }
  .trade-btn-bin:hover, .trade-btn-okx:hover { opacity: 0.75; }

  @media (max-width: 768px) {
    .hide-tablet { display: none !important; }
  }
  @media (max-width: 500px) {
    .hide-mobile-sm { display: none !important; }
    .price-row { padding: 10px 12px; }
  }
</style>

<script is:inline>
(function(){
  const fmt = n => {
    if (!n || isNaN(n)) return "—";
    if (n >= 1e12) return "$" + (n/1e12).toFixed(2) + "T";
    if (n >= 1e9) return "$" + (n/1e9).toFixed(2) + "B";
    if (n >= 1e6) return "$" + (n/1e6).toFixed(1) + "M";
    return "$" + n.toLocaleString("en-US", {maximumFractionDigits:0});
  };
  const fmtP = n => {
    if (!n || isNaN(n)) return "—";
    if (n >= 1000) return "$" + n.toLocaleString("en-US", {maximumFractionDigits: n >= 10000 ? 0 : 2});
    if (n >= 1) return "$" + n.toFixed(2);
    return "$" + n.toFixed(4);
  };

  // Symbol → coinId 映射
  const symToCoinId = {
    BTC:"bitcoin", ETH:"ethereum", BNB:"binancecoin", SOL:"solana", XRP:"ripple",
    ADA:"cardano", DOGE:"dogecoin", TRX:"tron", DOT:"polkadot", LTC:"litecoin",
    LINK:"chainlink", AVAX:"avalanche-2", UNI:"uniswap", XLM:"stellar", ATOM:"cosmos",
    BCH:"bitcoin-cash", POL:"polygon", ARB:"arbitrum", OP:"optimism", SUI:"sui",
  };

  // 优先：Orbit（CoinGecko 兼容格式，含市值/排名/高低价）
  async function fetchOrbit() {
    try {
      const r = await fetch(
        "https://orbit.biyijia.com/api/coins?per_page=60",
        { signal: AbortSignal.timeout(10000) }
      );
      if (!r.ok) return null;
      const coins = await r.json();
      const map = {};
      for (const c of coins) {
        const sym = c.symbol?.toUpperCase();
        if (sym && symToCoinId[sym]) {
          map[sym] = {
            price: c.current_price,
            change: c.price_change_percentage_24h_in_currency ?? 0,
            vol: c.total_volume,
            mcap: c.market_cap,
            rank: c.market_cap_rank,
          };
        }
      }
      return Object.keys(map).length > 0 ? map : null;
    } catch { return null; }
  }

  // 备用：Binance（无市值/排名）
  async function fetchBinance() {
    const symbols = [
      "BTCUSDT","ETHUSDT","BNBUSDT","SOLUSDT","XRPUSDT",
      "ADAUSDT","DOGEUSDT","TRXUSDT","DOTUSDT","LTCUSDT",
      "LINKUSDT","AVAXUSDT","UNIUSDT","XLMUSDT","ATOMUSDT",
      "BCHUSDT","POLUSDT","ARBUSDT","OPUSDT","SUIUSDT"
    ];
    try {
      const symbolsParam = JSON.stringify(symbols);
      const r = await fetch(
        `https://api.binance.com/api/v3/ticker/24hr?symbols=${encodeURIComponent(symbolsParam)}`,
        { signal: AbortSignal.timeout(8000) }
      );
      if (!r.ok) throw new Error();
      return await r.json();
    } catch {
      try {
        const r = await fetch("https://data-api.binance.vision/api/v3/ticker/24hr",
          { signal: AbortSignal.timeout(10000) });
        if (!r.ok) return [];
        const all = await r.json();
        const set = new Set(symbols);
        return all.filter(t => set.has(t.symbol));
      } catch { return []; }
    }
  }

  // 备用市值：CoinGecko（仅 Binance 回退时使用）
  async function fetchGeckoMarketCap() {
    try {
      const ids = "bitcoin,ethereum,binancecoin,solana,ripple,cardano,dogecoin,tron,polkadot,litecoin,chainlink,avalanche-2,uniswap,stellar,cosmos,bitcoin-cash,polygon-ecosystem-token,arbitrum,optimism,sui";
      const r = await fetch(
        `https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids=${ids}&order=market_cap_desc&sparkline=false`,
        { signal: AbortSignal.timeout(10000) }
      );
      if (!r.ok) return {};
      const data = await r.json();
      const map = {};
      for (const c of data) {
        map[c.symbol.toUpperCase()] = { mcap: c.market_cap, rank: c.market_cap_rank };
      }
      return map;
    } catch { return {}; }
  }

  async function updateAll() {
    // 优先 Orbit
    const cbMap = await fetchOrbit();
    if (cbMap) {
      for (const [sym, d] of Object.entries(cbMap)) {
        const coinId = symToCoinId[sym];
        if (!coinId) continue;
        const pe = document.getElementById("p-" + coinId);
        const ce = document.getElementById("c-" + coinId);
        const ve = document.getElementById("v-" + coinId);
        const me = document.getElementById("m-" + coinId);
        const re = document.getElementById("r-" + coinId);
        if (pe) pe.textContent = fmtP(d.price);
        if (ce) {
          ce.textContent = (d.change >= 0 ? "▲ +" : "▼ ") + Math.abs(d.change).toFixed(2) + "%";
          ce.style.color = d.change >= 0 ? "var(--accent-green)" : "var(--accent-red)";
        }
        if (ve) ve.textContent = fmt(d.vol);
        if (me) me.textContent = fmt(d.mcap);
        if (re && d.rank) re.textContent = d.rank;
      }
      return;
    }

    // 回退：Binance + CoinGecko
    const [tickers, geckoMap] = await Promise.all([fetchBinance(), fetchGeckoMarketCap()]);
    for (const t of tickers) {
      const sym = t.symbol.replace("USDT", "");
      const coinId = symToCoinId[sym];
      if (!coinId) continue;
      const pe = document.getElementById("p-" + coinId);
      const ce = document.getElementById("c-" + coinId);
      const ve = document.getElementById("v-" + coinId);
      const me = document.getElementById("m-" + coinId);
      const re = document.getElementById("r-" + coinId);
      const price = parseFloat(t.lastPrice);
      const chg = parseFloat(t.priceChangePercent);
      if (pe) pe.textContent = fmtP(price);
      if (ce) {
        ce.textContent = (chg >= 0 ? "▲ +" : "▼ ") + Math.abs(chg).toFixed(2) + "%";
        ce.style.color = chg >= 0 ? "var(--accent-green)" : "var(--accent-red)";
      }
      if (ve) ve.textContent = fmt(parseFloat(t.quoteVolume));
      const gecko = geckoMap[sym];
      if (gecko) {
        if (me) me.textContent = fmt(gecko.mcap);
        if (re && gecko.rank) re.textContent = gecko.rank;
      }
    }
  }

  updateAll();
  setInterval(updateAll, 30000); // 每30秒刷新
})();
</script>

<script>
  // ── Watchlist integration ──
  import { isWatched, toggle as wlToggle, getCoins, getLastPrices, updateLastPrices, getLastVisit } from "@/scripts/watchlist";

  function initWatchlist() {
    const watchlistSection = document.getElementById("watchlist");
    const watchlistRows = document.getElementById("watchlist-rows");
    const watchlistEmpty = document.getElementById("watchlist-empty");
    if (!watchlistSection || !watchlistRows) return;

    // Star buttons
    document.querySelectorAll<HTMLButtonElement>(".wl-star").forEach(btn => {
      const sym = btn.dataset.wl ?? "";
      updateStarUI(btn, isWatched(sym));

      btn.addEventListener("click", () => {
        const added = wlToggle(sym);
        updateStarUI(btn, added);
        refreshWatchlistPanel();
      });
    });

    // Row click navigation (restored since we removed inline onclick)
    document.querySelectorAll<HTMLElement>(".price-row").forEach(row => {
      row.addEventListener("click", () => {
        const sym = row.dataset.symbol?.toLowerCase();
        if (sym) location.href = `/price/${sym}`;
      });
      row.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          const sym = row.dataset.symbol?.toLowerCase();
          if (sym) location.href = `/price/${sym}`;
        }
      });
    });

    refreshWatchlistPanel();
  }

  function updateStarUI(btn: HTMLButtonElement, watched: boolean) {
    btn.innerHTML = watched ? "&#9733;" : "&#9734;";
    btn.style.color = watched ? "var(--accent)" : "var(--fg-muted)";
  }

  function refreshWatchlistPanel() {
    const watchlistSection = document.getElementById("watchlist");
    const watchlistRows = document.getElementById("watchlist-rows");
    const watchlistEmpty = document.getElementById("watchlist-empty");
    if (!watchlistSection || !watchlistRows || !watchlistEmpty) return;

    const coins = getCoins();
    if (coins.length === 0) {
      watchlistSection.style.display = "none";
      return;
    }

    watchlistSection.style.display = "";
    const allRows = document.querySelectorAll<HTMLElement>(".price-row");
    const watchedHtml: string[] = [];

    allRows.forEach(row => {
      const sym = row.dataset.symbol ?? "";
      if (coins.includes(sym)) {
        watchedHtml.push(row.outerHTML);
      }
    });

    if (watchedHtml.length > 0) {
      watchlistRows.innerHTML = watchedHtml.join("");
      watchlistEmpty.style.display = "none";
    } else {
      watchlistRows.innerHTML = "";
      watchlistEmpty.style.display = "";
    }

    // Show price delta since last visit
    const lastPrices = getLastPrices();
    const sinceEl = document.getElementById("wl-since");
    if (sinceEl && Object.keys(lastPrices).length > 0) {
      const lastVisit = getLastVisit();
      if (lastVisit > 0) {
        const hours = Math.round((Date.now() - lastVisit) / 3600000);
        if (hours > 0) {
          sinceEl.style.display = "";
          sinceEl.textContent = hours >= 24
            ? `${Math.round(hours / 24)}d ago`
            : `${hours}h ago`;
        }
      }
    }
  }

  initWatchlist();
  document.addEventListener("astro:after-swap", initWatchlist);
</script>
