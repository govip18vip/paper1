---
// src/pages/price/eth.astro
// 以太坊实时价格专题页 — GEO + Schema.org
// 路由: /price/eth

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import { getCollection } from "astro:content";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

const relatedPosts = (await getCollection("blog")).filter(p =>
  p.data.tags?.some(t => ["eth", "ethereum", "以太坊"].includes(t.toLowerCase()))
).slice(0, 6);

const priceSchema = {
  "@context": "https://schema.org",
  "@type": "FinancialProduct",
  name: "Ethereum (ETH)",
  description: "以太坊是全球最大的智能合约平台，ETH是其原生代币，用于支付Gas费和参与DeFi生态。",
  url: `${SITE.website}price/eth`,
  category: "Cryptocurrency",
  provider: { "@type": "Organization", name: SITE.title, url: SITE.website },
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    seller: { "@type": "Organization", name: "Binance" },
  },
  additionalProperty: [
    { "@type": "PropertyValue", name: "共识机制", value: "权益证明（PoS）" },
    { "@type": "PropertyValue", name: "区块时间", value: "约12秒" },
    { "@type": "PropertyValue", name: "年化质押收益", value: "约3-5%" },
    { "@type": "PropertyValue", name: "最小质押量", value: "32 ETH" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "以太坊今天价格是多少？",
      acceptedAnswer: { "@type": "Answer",
        text: "ETH价格实时波动，请查看本页顶部的实时价格数据。" },
    },
    {
      "@type": "Question",
      name: "以太坊和比特币有什么区别？",
      acceptedAnswer: { "@type": "Answer",
        text: "比特币主要用作数字货币和价值储存；以太坊是智能合约平台，支持DeFi、NFT、Web3应用。ETH没有供应上限，但通过EIP-1559燃烧机制控制通胀。" },
    },
    {
      "@type": "Question",
      name: "什么是以太坊Gas费？",
      acceptedAnswer: { "@type": "Answer",
        text: "Gas费是在以太坊网络上执行交易或智能合约时支付给验证者的费用，以ETH计价。网络拥堵时Gas费上涨，闲时降低。可在ETH Gas Tracker查看实时Gas价格。" },
    },
    {
      "@type": "Question",
      name: "在哪里可以购买以太坊？",
      acceptedAnswer: { "@type": "Answer",
        text: "推荐在币安(Binance)购买ETH，全球最大交易所，支持人民币/港币直接购买。使用邀请码B2345注册可享最高手续费折扣。" },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首页", item: SITE.website },
    { "@type": "ListItem", position: 2, name: "行情", item: `${SITE.website}price` },
    { "@type": "ListItem", position: 3, name: "以太坊价格", item: `${SITE.website}price/eth` },
  ],
};
---

<Layout
  title="以太坊(ETH)今日实时价格 — 行情走势图 | CryptoNews"
  description="以太坊ETH最新实时价格、24小时涨跌幅、历史走势图。了解Gas费、质押收益及如何在币安购买ETH。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(priceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <link rel="preconnect" href="https://api.coingecko.com" />
  </Fragment>

  <Header />
  <div class="site-outer">
    <LeftSidebar />

    <main class="main-col" id="main-content" data-pagefind-body
      itemscope itemtype="https://schema.org/WebPage">

      <!-- 面包屑 -->
      <nav style="padding:12px 16px 0;font-size:13px;color:var(--fg-muted);" aria-label="breadcrumb">
        <a href="/" style="color:var(--fg-muted);text-decoration:none;">首页</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <a href="/price" style="color:var(--fg-muted);text-decoration:none;">行情</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">以太坊(ETH)</span>
      </nav>

      <!-- 价格 Hero -->
      <section style="padding:12px 16px 0;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;overflow:hidden;">
          <div style="display:flex;align-items:center;gap:12px;padding:20px 24px 16px;border-bottom:1px solid var(--border);">
            <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#627eea,#a8b9f8);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:900;color:#fff;flex-shrink:0;">⟠</div>
            <div>
              <h1 style="font-size:20px;font-weight:800;color:var(--fg);margin:0;line-height:1.2;">以太坊价格 <span style="font-size:13px;font-weight:400;color:var(--fg-muted);">Ethereum · ETH</span></h1>
              <p style="font-size:12px;color:var(--fg-muted);margin:3px 0 0;">实时价格 · 数据来源：CoinGecko</p>
            </div>
            <div style="margin-left:auto;display:flex;gap:8px;">
              <span class="ctag-blue">排名 #2</span>
              <span class="ctag-green">智能合约</span>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:0;border-bottom:1px solid var(--border);">
            <div style="padding:18px 24px;border-right:1px solid var(--border);">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">当前价格 (USD)</div>
              <div id="eth-price" style="font-size:28px;font-weight:800;color:var(--fg);font-variant-numeric:tabular-nums;">--</div>
              <div id="eth-change" style="font-size:13px;margin-top:4px;font-weight:600;">--</div>
            </div>
            <div style="padding:18px 16px;border-right:1px solid var(--border);">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">24h 最高</div>
              <div id="eth-high" style="font-size:16px;font-weight:700;color:var(--fg);">--</div>
              <div style="font-size:11px;color:var(--fg-muted);margin-top:4px;">24h 最低</div>
              <div id="eth-low" style="font-size:14px;font-weight:600;color:var(--fg);">--</div>
            </div>
            <div style="padding:18px 16px;border-right:1px solid var(--border);">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">市值</div>
              <div id="eth-mcap" style="font-size:15px;font-weight:700;color:var(--fg);">--</div>
              <div style="font-size:11px;color:var(--fg-muted);margin-top:4px;">24h 成交量</div>
              <div id="eth-vol" style="font-size:13px;font-weight:600;color:var(--fg);">--</div>
            </div>
            <div style="padding:18px 16px;">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">质押收益率</div>
              <div style="font-size:16px;font-weight:700;color:var(--accent-green);">~3-5% APY</div>
              <div style="font-size:11px;color:var(--fg-muted);margin-top:4px;">共识机制</div>
              <div style="font-size:13px;font-weight:700;color:#627eea;">PoS</div>
            </div>
          </div>

          <!-- 图表 -->
          <div style="padding:16px 24px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
              <span style="font-size:13px;font-weight:600;color:var(--fg);">ETH价格走势</span>
              <div style="display:flex;gap:4px;" id="eth-period-btns">
                {["1D","7D","30D"].map(p => (
                  <button data-period={p}
                    style="padding:3px 10px;border-radius:3px;font-size:11px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--fg-muted);cursor:pointer;transition:all 0.12s;"
                  >{p}</button>
                ))}
              </div>
            </div>
            <div style="position:relative;height:200px;">
              <canvas id="eth-chart"></canvas>
            </div>
          </div>
          <div style="padding:8px 24px 14px;font-size:11px;color:var(--fg-light);">
            最后更新：<span id="eth-updated">--</span> · 每60秒自动刷新
          </div>
        </div>
      </section>

      <div style="padding:0 16px;">
        <BinanceBanner variant="article" lang="zh-CN" />
      </div>

      <!-- ETH基本资料 -->
      <section style="padding:0 16px 16px;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:20px 24px;">
          <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin-bottom:16px;display:flex;align-items:center;gap:8px;">
            <span style="width:3px;height:18px;background:var(--accent-blue);border-radius:2px;display:inline-block;"></span>
            以太坊基本资料
          </h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            {[
              ["创始人", "Vitalik Buterin"],
              ["上线时间", "2015年7月30日"],
              ["共识机制", "权益证明（PoS，2022年合并后）"],
              ["区块时间", "约12秒"],
              ["最小质押", "32 ETH"],
              ["Gas代币", "ETH（Gwei计价）"],
              ["代码", "ETH"],
              ["EIP-1559", "2021年8月，Gas燃烧机制"],
            ].map(([k, v]) => (
              <div style="border-bottom:1px solid var(--border-subtle);padding:8px 0;display:flex;justify-content:space-between;gap:8px;">
                <span style="font-size:12.5px;color:var(--fg-muted);flex-shrink:0;">{k}</span>
                <span style="font-size:12.5px;color:var(--fg);font-weight:500;text-align:right;">{v}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section style="padding:0 16px 20px;" itemscope itemtype="https://schema.org/FAQPage">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:20px 24px;">
          <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin-bottom:16px;display:flex;align-items:center;gap:8px;">
            <span style="width:3px;height:18px;background:var(--accent-blue);border-radius:2px;display:inline-block;"></span>
            常见问题 FAQ
          </h2>
          <div style="display:flex;flex-direction:column;gap:10px;">
            {[
              ["以太坊和比特币有什么区别？", "比特币主要用作数字货币和价值储存；以太坊是智能合约平台，支持DeFi、NFT、Web3应用。ETH没有供应上限，但通过EIP-1559燃烧机制控制通胀。"],
              ["什么是Gas费，为什么需要支付？", "Gas费是执行以太坊网络交易时支付给验证者的费用，以ETH（Gwei）计价。网络拥堵时Gas费上涨。转账ETH或ERC-20代币都需要Gas费。"],
              ["如何质押ETH获得收益？", "持有32 ETH可直接成为验证者，年化收益约3-5%。持币量不足32 ETH可通过流动性质押协议（如Lido）参与，无最低限制。"],
              ["在哪里购买ETH最划算？", "推荐币安(Binance)，全球最大交易所，手续费低。使用邀请码 B2345 注册可享最高折扣，支持银行转账和信用卡购买。"],
            ].map(([q, a]) => (
              <details itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"
                style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:6px;padding:14px 16px;">
                <summary itemprop="name" style="font-size:14px;font-weight:600;color:var(--fg);list-style:none;display:flex;justify-content:space-between;align-items:center;cursor:pointer;">
                  <span>{q}</span>
                  <span style="color:var(--fg-muted);font-size:18px;flex-shrink:0;margin-left:8px;">+</span>
                </summary>
                <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                  <p itemprop="text" style="font-size:13px;color:var(--fg-muted);line-height:1.7;margin:10px 0 0;">{a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- 相关文章 -->
      {relatedPosts.length > 0 && (
        <section style="padding:0 16px 20px;">
          <div class="sec-head" style="padding-left:0;margin-bottom:12px;">
            <span class="sec-head-title">ETH 相关文章</span>
            <a href="/tags/eth" class="sec-head-more">查看全部 →</a>
          </div>
          <div class="alist">
            {relatedPosts.map(p => (
              <article class="alist-item">
                <div class="flex-1 min-w-0">
                  <a href={getPath(p.id, p.filePath)} style="font-size:14px;font-weight:600;color:var(--fg);text-decoration:none;line-height:1.5;display:block;transition:color 0.12s;"
                    onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--fg)'">
                    {p.data.title}
                  </a>
                  <p style="font-size:12px;color:var(--fg-muted);margin:4px 0 0;">{p.data.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}
    </main>

    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">⟠ ETH 快速操作</div>
        <a href="https://www.binance.com/en/register?ref=B2345" target="_blank" rel="noopener noreferrer sponsored"
          style="display:block;padding:10px;background:#627eea;color:#fff;border-radius:5px;text-decoration:none;font-size:13px;font-weight:700;text-align:center;margin-bottom:8px;transition:opacity 0.12s;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          在币安购买 ETH →
        </a>
        <p style="font-size:11px;color:var(--fg-muted);text-align:center;margin:0;">邀请码 B2345 · 最高折扣</p>
      </div>
      <div class="rsidebar-section">
        <div class="rsidebar-head">其他币种行情</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {[
            { name: "Bitcoin", symbol: "BTC", href: "/price/btc", emoji: "₿" },
            { name: "Binance Coin", symbol: "BNB", href: "/tags/btc", emoji: "🔶" },
            { name: "Solana", symbol: "SOL", href: "/tags/btc", emoji: "◎" },
          ].map(coin => (
            <a href={coin.href} style="display:flex;align-items:center;justify-content:space-between;padding:8px 10px;background:var(--bg-elevated);border-radius:5px;text-decoration:none;color:var(--fg);font-size:13px;transition:background 0.12s;"
              onmouseover="this.style.background='var(--nav-active-bg)'" onmouseout="this.style.background='var(--bg-elevated)'">
              <span>{coin.emoji} {coin.name}</span>
              <span style="color:var(--fg-muted);font-size:11px;">{coin.symbol}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="rsidebar-section">
        <BinanceBanner variant="compact" lang="zh-CN" />
      </div>
    </aside>
  </div>
  <Footer />
</Layout>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script is:inline>
(function(){
  const fmt = n => n >= 1e9 ? "$"+(n/1e9).toFixed(2)+"B" : n >= 1e6 ? "$"+(n/1e6).toFixed(0)+"M" : "$"+n.toLocaleString("en-US",{maximumFractionDigits:0});
  const fmtP = n => n >= 1000 ? "$"+n.toLocaleString("en-US",{maximumFractionDigits:0}) : "$"+n.toFixed(2);
  let chart = null;

  async function loadPrice(){
    try {
      const r = await fetch("https://api.coingecko.com/api/v3/coins/ethereum?localization=false&tickers=false&community_data=false&developer_data=false",{signal:AbortSignal.timeout(8000)});
      if(!r.ok) return;
      const d = await r.json();
      const mkt = d.market_data;
      const chg = mkt.price_change_percentage_24h;
      const isUp = chg >= 0;
      document.getElementById("eth-price").textContent = fmtP(mkt.current_price.usd);
      const el = document.getElementById("eth-change");
      el.textContent = (isUp ? "▲ +" : "▼ ") + chg.toFixed(2) + "%";
      el.style.color = isUp ? "var(--accent-green)" : "var(--accent-red)";
      document.getElementById("eth-high").textContent = fmtP(mkt.high_24h.usd);
      document.getElementById("eth-low").textContent  = fmtP(mkt.low_24h.usd);
      document.getElementById("eth-mcap").textContent = fmt(mkt.market_cap.usd);
      document.getElementById("eth-vol").textContent  = fmt(mkt.total_volume.usd);
      document.getElementById("eth-updated").textContent = new Date().toLocaleTimeString("zh-CN");
    } catch(e){}
  }

  async function loadChart(days=1){
    try {
      const r = await fetch(`https://api.coingecko.com/api/v3/coins/ethereum/market_chart?vs_currency=usd&days=${days}`,{signal:AbortSignal.timeout(10000)});
      if(!r.ok) return;
      const { prices } = await r.json();
      const labels = prices.map(([ts]) => { const d=new Date(ts); return days===1 ? d.toLocaleTimeString("zh-CN",{hour:"2-digit",minute:"2-digit"}) : d.toLocaleDateString("zh-CN",{month:"numeric",day:"numeric"}); });
      const data = prices.map(([,v]) => v);
      const isUp = data[data.length-1] >= data[0];
      const color = isUp ? "#00c896" : "#f04747";
      if(chart){ chart.destroy(); chart=null; }
      const ctx = document.getElementById("eth-chart").getContext("2d");
      chart = new Chart(ctx,{type:"line",data:{labels,datasets:[{data,borderColor:color,borderWidth:1.5,pointRadius:0,fill:true,backgroundColor:(ctx)=>{const g=ctx.chart.ctx.createLinearGradient(0,0,0,200);g.addColorStop(0,color+"33");g.addColorStop(1,color+"00");return g;}}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>"$"+ctx.raw.toLocaleString("en-US",{maximumFractionDigits:0})}}},scales:{x:{grid:{display:false},ticks:{maxTicksLimit:6,color:"#888",font:{size:10}}},y:{grid:{color:"rgba(128,128,128,0.1)"},ticks:{color:"#888",font:{size:10},callback:v=>"$"+(v>=1000?(v/1000).toFixed(0)+"K":v)}}}}});
    } catch(e){}
  }

  document.getElementById("eth-period-btns")?.addEventListener("click", (e) => {
    const btn = e.target.closest("[data-period]");
    if(!btn) return;
    document.querySelectorAll("#eth-period-btns [data-period]").forEach(b=>{b.style.background="transparent";b.style.color="var(--fg-muted)";b.style.borderColor="var(--border)";});
    btn.style.background="#627eea";btn.style.color="#fff";btn.style.borderColor="#627eea";
    loadChart({"1D":1,"7D":7,"30D":30}[btn.dataset.period]||1);
  });
  document.querySelector("#eth-period-btns [data-period='1D']")?.click();
  loadPrice();
  setInterval(loadPrice, 60000);
})();
</script>
