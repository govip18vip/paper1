---
// src/pages/index.astro
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { getLang, useTranslations, buildAlternates, HTML_LANG } from "@/i18n/ui";
import BinanceBanner from "@/components/BinanceBanner.astro";

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const alternates = buildAlternates(Astro.url);

const posts = await getCollection("blog");
const all = getSortedPosts(posts);
const featured = all.filter(p => p.data.featured);

const [hero, ...restFeatured] = featured.length > 0 ? featured : all;
const thumbPosts = (restFeatured.length >= 4 ? restFeatured : all.filter(p => p !== hero)).slice(0, 4);
const listPosts = all.filter(p => p !== hero && !thumbPosts.includes(p)).slice(0, 12);
const newsPosts = all.slice(0, 8);
const hotPosts = all.slice(0, 7);
const tutorialPosts = all.filter(p =>
  p.data.tags?.some(t => ["docs", "教程", "tutorial", "beginner", "新手"].includes(t.toLowerCase()))
).slice(0, 5);

const siteUrl = SITE.website.replace(/\/$/, "");

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  name: t("site.name"),
  description: t("site.desc"),
  url: siteUrl,
  inLanguage: [HTML_LANG[lang], "en", "zh-CN", "es", "pt"],
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteUrl}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
---

<Layout
  title={`${t("site.name")} — ${t("site.desc").slice(0, 60)}`}
  description={t("site.desc")}
>
  <Fragment slot="head">
    {alternates.map(a => <link rel="alternate" hreflang={a.lang.toLowerCase()} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <Header />

  <div class="site-outer">

    <!-- ══ LEFT SIDEBAR ══ -->
    <LeftSidebar />

    <!-- ══ CENTER CONTENT ══ -->
    <div class="main-col" id="main-content" data-layout="index">

      <!-- HERO SECTION -->
      <section class="hero-section anim-1" aria-label={t("section.latest")}>
        <div class="hero-row">

          <!-- Big hero post -->
          <div>
            {hero ? (
              <Card {...hero} size="hero" variant="h2" />
            ) : (
              <div class="hero-main" style="display:flex;align-items:center;justify-content:center;background:var(--bg-elevated);">
                <p style="color:var(--fg-muted);font-size:14px;">暂无精选文章</p>
              </div>
            )}
          </div>

          <!-- 2×2 thumbnail grid -->
          <div class="hero-grid">
            {thumbPosts.slice(0, 4).map(p => <Card {...p} size="thumb" variant="h3" />)}
            {Array.from({ length: Math.max(0, 4 - thumbPosts.length) }).map(() => (
              <div class="hero-thumb"
                style="background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;opacity:0.4;">
                <span style="font-size:24px;">₿</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- LATEST ARTICLES LIST -->
      <section aria-label={t("section.latest")} class="anim-2">
        <div class="sec-head" style="padding-top:16px;">
          <span class="sec-head-title">{t("section.latest")}</span>
          <a href="/posts" class="sec-head-more">{t("section.all")} →</a>
        </div>

        <div class="alist" id="main-list">
          {listPosts.map(p => <Card {...p} size="list" variant="h3" />)}
          <!-- Empty state shown by JS when all cards are hidden -->
          <div data-lang-empty style="display:none;padding:32px;text-align:center;color:var(--fg-muted);font-size:14px;">
            该语言暂无文章 · No articles in this language yet
          </div>
        </div>

        {all.length > 12 && (
          <div style="padding:0 16px 16px;text-align:center;">
            <a href="/posts" class="more-btn" style="display:inline-block;max-width:280px;">
              {t("section.more")}
            </a>
          </div>
        )}
      </section>

      <!-- GEO / ABOUT BLOCK -->
      <section id="geo-intro" aria-label={t("section.about")} class="anim-3"
        style="padding:16px;margin:0 0 16px;" itemscope itemtype="https://schema.org/AboutPage">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:20px 24px;">
          <h2 style="font-size:15px;font-weight:700;margin-bottom:16px;color:var(--fg);display:flex;align-items:center;gap:8px;">
            <span style="display:inline-block;width:3px;height:18px;background:var(--accent);border-radius:2px;flex-shrink:0;"></span>
            {t("section.about")}
          </h2>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;" id="site-about">
            <div itemscope itemtype="https://schema.org/Thing">
              <h3 style="font-size:13px;font-weight:700;color:var(--accent);margin-bottom:6px;" itemprop="name"
                data-i18n="about.btc.title">{t("about.btc.title")}</h3>
              <p style="font-size:12px;color:var(--fg-muted);line-height:1.6;" itemprop="description"
                data-i18n="about.btc.desc">{t("about.btc.desc")}</p>
            </div>
            <div itemscope itemtype="https://schema.org/Thing">
              <h3 style="font-size:13px;font-weight:700;color:var(--accent-blue);margin-bottom:6px;" itemprop="name"
                data-i18n="about.ex.title">{t("about.ex.title")}</h3>
              <p style="font-size:12px;color:var(--fg-muted);line-height:1.6;" itemprop="description"
                data-i18n="about.ex.desc">{t("about.ex.desc")}</p>
            </div>
            <div itemscope itemtype="https://schema.org/Thing">
              <h3 style="font-size:13px;font-weight:700;color:var(--accent-green);margin-bottom:6px;" itemprop="name"
                data-i18n="about.wallet.title">{t("about.wallet.title")}</h3>
              <p style="font-size:12px;color:var(--fg-muted);line-height:1.6;" itemprop="description"
                data-i18n="about.wallet.desc">{t("about.wallet.desc")}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- TAG CLOUD -->
      <section style="padding:0 16px 20px;" aria-label={t("section.topic")}>
        <div class="sec-head" style="padding-left:0;">
          <span class="sec-head-title">{t("section.topic")}</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;">
          {[
            { label: "比特币", href: "/tags/btc" },
            { label: "以太坊", href: "/tags/eth" },
            { label: "币安教程", href: "/tags/docs" },
            { label: "DeFi", href: "/tags/defi" },
            { label: "NFT", href: "/tags/nft" },
            { label: "钱包安全", href: "/tags/wallet" },
            { label: "新手入门", href: "/tags/beginner" },
            { label: "BTC行情", href: "/tags/market" },
            { label: "Web3", href: "/tags/defi" },
            { label: "Bitcoin", href: "/tags/btc" },
            { label: "Binance Guide", href: "/tags/docs" },
            { label: "区块链新闻", href: "/posts" },
          ].map(tag => (
            <a href={tag.href}
              style="display:inline-block;padding:5px 12px;border-radius:20px;font-size:12.5px;font-weight:500;border:1px solid var(--border);color:var(--fg-muted);background:var(--bg-card);text-decoration:none;transition:all 0.12s;"
              onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';"
              onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--fg-muted)';">
              {tag.label}
            </a>
          ))}
          <a href="/tags"
            style="display:inline-block;padding:5px 12px;border-radius:20px;font-size:12.5px;font-weight:600;border:1px solid var(--accent);color:var(--accent);background:var(--tag-orange-bg);text-decoration:none;">
            全部标签 →
          </a>
        </div>
      </section>

    </div>

    <!-- ══ RIGHT SIDEBAR ══ -->
    <aside class="rsidebar" aria-label="快讯与热门">

      <!-- Latest quick news -->
      <div class="rsidebar-section">
        <div class="rsidebar-head" data-i18n="section.flash">{t("section.flash")}</div>
        {newsPosts.map(p => <Card {...p} size="news" variant="h3" />)}
        <a href="/posts" class="more-btn" data-i18n="section.more">{t("section.more")}</a>
      </div>

      <!-- Hot / trending -->
      <div class="rsidebar-section">
        <div class="rsidebar-head">🔥 <span data-i18n="section.hot">{t("section.hot")}</span></div>
        <ol>
          {hotPosts.map((p, i) => (
            <li style="display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--border-subtle);align-items:flex-start;">
              <span class:list={["hot-rank", { top: i < 3 }]}>{i + 1}</span>
              <a href={getPath(p.id, p.filePath)}
                style="flex:1;font-size:12.5px;font-weight:500;color:var(--fg);line-height:1.5;text-decoration:none;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;transition:color 0.12s;"
                onmouseover="this.style.color='var(--accent)';"
                onmouseout="this.style.color='var(--fg)';">
                {p.data.title}
              </a>
            </li>
          ))}
        </ol>
      </div>

      <!-- Tutorials -->
      {tutorialPosts.length > 0 && (
        <div class="rsidebar-section">
          <div class="rsidebar-head">📚 <span data-i18n="section.tutorial">{t("section.tutorial")}</span></div>
          <ul style="list-style:none;padding:0;margin:0;">
            {tutorialPosts.map(p => (
              <li style="padding:8px 0;border-bottom:1px solid var(--border-subtle);">
                <a href={getPath(p.id, p.filePath)}
                  style="display:flex;gap:8px;align-items:flex-start;text-decoration:none;color:var(--fg);font-size:12.5px;line-height:1.5;transition:color 0.12s;"
                  onmouseover="this.style.color='var(--accent)';"
                  onmouseout="this.style.color='var(--fg)';">
                  <span class="ctag-blue" style="margin-top:2px;flex-shrink:0;">教程</span>
                  <span style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                    {p.data.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <a href="/tags/docs" class="more-btn" data-i18n="section.more">{t("section.more")}</a>
        </div>
      )}

      <!-- Quick nav -->
      <div class="rsidebar-section">
        <div class="rsidebar-head">快速导航</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
          {[
            { label: "₿ BTC",  href: "/tags/btc",    bg: "var(--tag-orange-bg)", color: "var(--accent)" },
            { label: "⚡ DeFi", href: "/tags/defi",   bg: "var(--tag-green-bg)",  color: "var(--accent-green)" },
            { label: "🔐 钱包", href: "/tags/wallet", bg: "var(--tag-blue-bg)",   color: "var(--accent-blue)" },
            { label: "📖 教程", href: "/tags/docs",   bg: "rgba(167,139,250,.12)", color: "#a78bfa" },
            { label: "📊 行情", href: "/tags/market", bg: "var(--tag-red-bg)",    color: "var(--accent-red)" },
            { label: "🗂 全部", href: "/posts",       bg: "var(--bg-elevated)",   color: "var(--fg-muted)" },
          ].map(item => (
            <a href={item.href}
              style={`display:flex;align-items:center;justify-content:center;padding:8px;border-radius:5px;font-size:11.5px;font-weight:600;text-decoration:none;background:${item.bg};color:${item.color};transition:opacity 0.12s;`}
              onmouseover="this.style.opacity='0.7';" onmouseout="this.style.opacity='1';">
              {item.label}
            </a>
          ))}
        </div>
      </div>

    </aside>

  </div>

</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector("[data-layout='index']");
    if (el) sessionStorage.setItem("backUrl", "/");
  });
</script>
