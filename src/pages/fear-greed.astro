---
// src/pages/fear-greed.astro
// Bitaigen Fear & Greed Index — self-calculated from free API data
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const title = "加密货币恐惧贪婪指数 — Bitaigen Fear & Greed Index";
const desc = "Bitaigen 自研加密货币恐惧贪婪指数：基于BTC价格波动、交易量、市场动量等多维度数据实时计算市场情绪。";
---

<Layout title={`${title} | ${SITE.title}`} description={desc}>
  <Header />
  <main style="max-width:800px;margin:0 auto;padding:24px 16px 60px;">
    <nav style="font-size:13px;color:var(--fg-muted);margin-bottom:16px;">
      <a href="/" style="color:var(--fg-muted);text-decoration:none;">首页</a>
      <span style="margin:0 6px;opacity:0.5;">›</span>
      <span style="color:var(--fg);">恐惧贪婪指数</span>
    </nav>

    <h1 style="font-size:24px;font-weight:800;color:var(--fg);margin:0 0 4px;">加密货币恐惧贪婪指数</h1>
    <p style="font-size:13px;color:var(--fg-muted);margin:0 0 24px;">基于市场数据实时计算 · 帮你判断"该贪婪还是该恐惧"</p>

    <!-- Main gauge -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:16px;padding:32px;text-align:center;margin-bottom:20px;">
      <div id="fg-gauge" style="width:200px;height:200px;margin:0 auto 16px;position:relative;">
        <canvas id="fg-canvas" width="200" height="200"></canvas>
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
          <div id="fg-score" style="font-size:48px;font-weight:900;color:var(--fg);">—</div>
          <div id="fg-label" style="font-size:16px;font-weight:700;color:var(--fg-muted);">计算中...</div>
        </div>
      </div>
      <div id="fg-desc" style="font-size:14px;color:var(--fg-muted);max-width:400px;margin:0 auto;line-height:1.6;"></div>
      <div style="font-size:11px;color:var(--fg-light);margin-top:12px;">数据来源：Binance / CoinGecko · 每5分钟更新</div>
    </div>

    <!-- Components breakdown -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:20px;">
      <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin:0 0 14px;display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:16px;background:var(--accent);border-radius:2px;"></span>
        计算维度
      </h2>
      <div id="fg-factors" style="display:flex;flex-direction:column;gap:8px;"></div>
    </div>

    <!-- Interpretation -->
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:20px;">
      <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin:0 0 14px;display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:16px;background:var(--accent);border-radius:2px;"></span>
        指数解读
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;">
        {[
          { range: "0-24", label: "极度恐惧", color: "#ef5350", desc: "市场恐慌，可能是买入机会" },
          { range: "25-44", label: "恐惧", color: "#ff9800", desc: "市场悲观，谨慎观望" },
          { range: "45-55", label: "中性", color: "#ffc107", desc: "市场平衡，无明确方向" },
          { range: "56-75", label: "贪婪", color: "#8bc34a", desc: "市场乐观，注意风险" },
          { range: "76-100", label: "极度贪婪", color: "#4caf50", desc: "市场狂热，考虑获利了结" },
        ].map(item => (
          <div style={`padding:12px;border-radius:8px;background:${item.color}11;border:1px solid ${item.color}33;`}>
            <div style={`font-size:13px;font-weight:700;color:${item.color};`}>{item.range}: {item.label}</div>
            <div style="font-size:11px;color:var(--fg-muted);margin-top:4px;">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>

    <div style="text-align:center;font-size:11px;color:var(--fg-muted);">
      免责声明：恐惧贪婪指数仅供参考，不构成投资建议。
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
(function(){
  const labels = {
    0:  {text:"极度恐惧", color:"#ef5350"},
    25: {text:"恐惧", color:"#ff9800"},
    45: {text:"中性", color:"#ffc107"},
    56: {text:"贪婪", color:"#8bc34a"},
    76: {text:"极度贪婪", color:"#4caf50"},
  };

  function getLabel(score) {
    if (score >= 76) return labels[76];
    if (score >= 56) return labels[56];
    if (score >= 45) return labels[45];
    if (score >= 25) return labels[25];
    return labels[0];
  }

  function drawGauge(score) {
    const canvas = document.getElementById("fg-canvas");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    const w = 200, h = 200, cx = w/2, cy = h/2, r = 80;
    ctx.clearRect(0,0,w,h);

    // Background arc
    ctx.beginPath();
    ctx.arc(cx, cy, r, Math.PI * 0.8, Math.PI * 2.2, false);
    ctx.strokeStyle = "var(--border)";
    ctx.lineWidth = 14;
    ctx.lineCap = "round";
    ctx.stroke();

    // Score arc
    const pct = Math.min(1, Math.max(0, score / 100));
    const endAngle = Math.PI * 0.8 + pct * Math.PI * 1.4;
    const gradient = ctx.createLinearGradient(0, h, w, 0);
    gradient.addColorStop(0, "#ef5350");
    gradient.addColorStop(0.3, "#ff9800");
    gradient.addColorStop(0.5, "#ffc107");
    gradient.addColorStop(0.7, "#8bc34a");
    gradient.addColorStop(1, "#4caf50");

    ctx.beginPath();
    ctx.arc(cx, cy, r, Math.PI * 0.8, endAngle, false);
    ctx.strokeStyle = gradient;
    ctx.lineWidth = 14;
    ctx.lineCap = "round";
    ctx.stroke();
  }

  function renderFactors(factors) {
    document.getElementById("fg-factors").innerHTML = factors.map(f =>
      `<div style="display:flex;align-items:center;gap:12px;padding:10px 12px;background:var(--bg-elevated);border-radius:8px;">
        <div style="flex:1;min-width:0;">
          <div style="font-size:13px;font-weight:600;color:var(--fg);">${f.name}</div>
          <div style="font-size:11px;color:var(--fg-muted);">${f.desc}</div>
        </div>
        <div style="font-size:16px;font-weight:800;color:${f.score>=50?'var(--accent-green)':'var(--accent-red)'};">${f.score}</div>
        <div style="width:60px;height:6px;background:var(--border);border-radius:3px;overflow:hidden;">
          <div style="height:100%;width:${f.score}%;background:${f.score>=75?'#4caf50':f.score>=50?'#8bc34a':f.score>=25?'#ff9800':'#ef5350'};border-radius:3px;"></div>
        </div>
      </div>`
    ).join("");
  }

  async function calculate() {
    const factors = [];

    // 1. BTC 24h price change → momentum score
    let btcChange = 0;
    try {
      const r = await fetch("https://api.binance.com/api/v3/ticker/24hr?symbol=BTCUSDT",{signal:AbortSignal.timeout(6000)});
      if (r.ok) { const d = await r.json(); btcChange = parseFloat(d.priceChangePercent); }
    } catch {}

    // Momentum: +5% → 90, 0% → 50, -5% → 10
    const momentumScore = Math.min(100, Math.max(0, 50 + btcChange * 8));
    factors.push({ name: "价格动量", desc: `BTC 24h: ${btcChange>=0?'+':''}${btcChange.toFixed(2)}%`, score: Math.round(momentumScore) });

    // 2. Volume change
    let volChange = 0;
    try {
      const r = await fetch("https://api.binance.com/api/v3/ticker/24hr?symbol=BTCUSDT",{signal:AbortSignal.timeout(6000)});
      if (r.ok) {
        const d = await r.json();
        const vol = parseFloat(d.quoteVolume);
        // Compare to average: >50B → bullish
        volChange = vol > 50e9 ? 70 : vol > 30e9 ? 55 : vol > 15e9 ? 40 : 25;
      }
    } catch { volChange = 50; }
    factors.push({ name: "交易量", desc: "BTC 24h 成交量水平", score: Math.round(volChange) });

    // 3. Market breadth — top10 coins up vs down
    let breadthScore = 50;
    try {
      const r = await fetch("https://orbit.biyijia.com/api/coins?per_page=20",{signal:AbortSignal.timeout(8000)});
      if (r.ok) {
        const coins = await r.json();
        const up = coins.filter(c => (c.price_change_percentage_24h_in_currency??0) > 0).length;
        breadthScore = (up / coins.length) * 100;
      }
    } catch {}
    factors.push({ name: "市场广度", desc: "主流币上涨比例", score: Math.round(breadthScore) });

    // 4. Volatility (lower = more fearful when combined with price drop)
    let volatilityScore = 50;
    try {
      const r = await fetch("https://api.binance.com/api/v3/klines?symbol=BTCUSDT&interval=1d&limit=7",{signal:AbortSignal.timeout(6000)});
      if (r.ok) {
        const klines = await r.json();
        const closes = klines.map(k => parseFloat(k[4]));
        const avg = closes.reduce((a,b) => a+b, 0) / closes.length;
        const variance = closes.reduce((a,c) => a + Math.pow(c-avg, 2), 0) / closes.length;
        const stdDev = Math.sqrt(variance);
        const volatilityPct = (stdDev / avg) * 100;
        // Low vol → neutral(50), high vol + up → greedy(75), high vol + down → fearful(25)
        volatilityScore = volatilityPct > 5 ? (btcChange > 0 ? 75 : 20) : volatilityPct > 2 ? 50 : 55;
      }
    } catch {}
    factors.push({ name: "波动率", desc: "7天 BTC 价格波动率", score: Math.round(volatilityScore) });

    // 5. BTC dominance proxy
    let domScore = 50;
    try {
      const r = await fetch("https://orbit.biyijia.com/api/coins?per_page=10",{signal:AbortSignal.timeout(8000)});
      if (r.ok) {
        const coins = await r.json();
        const btc = coins.find(c => c.symbol === "btc");
        const total = coins.reduce((s,c) => s + (c.market_cap||0), 0);
        if (btc && total) {
          const btcDom = (btc.market_cap / total) * 100;
          // High BTC dominance → fear (altcoins weak), low → greed (altcoin season)
          domScore = btcDom > 65 ? 35 : btcDom > 55 ? 45 : btcDom > 45 ? 60 : 75;
        }
      }
    } catch {}
    factors.push({ name: "BTC 主导率", desc: "比特币市值占比", score: Math.round(domScore) });

    // Calculate weighted average
    const weights = [35, 15, 20, 15, 15]; // momentum, volume, breadth, volatility, dominance
    const totalWeight = weights.reduce((a,b)=>a+b,0);
    const finalScore = Math.round(factors.reduce((s, f, i) => s + f.score * weights[i], 0) / totalWeight);

    // Render
    const label = getLabel(finalScore);
    document.getElementById("fg-score").textContent = finalScore;
    document.getElementById("fg-score").style.color = label.color;
    document.getElementById("fg-label").textContent = label.text;
    document.getElementById("fg-label").style.color = label.color;
    document.getElementById("fg-desc").textContent =
      finalScore >= 76 ? "市场极度贪婪，FOMO情绪蔓延。历史表明极端贪婪时期通常是回调风险最高的阶段，谨慎追高。" :
      finalScore >= 56 ? "市场情绪偏向乐观，资金持续流入。适度参与但注意控制仓位。" :
      finalScore >= 45 ? "市场情绪中性，多空分歧较大。观望为主，等待明确方向信号。" :
      finalScore >= 25 ? "市场偏向恐惧，部分资金离场。价值投资者可关注被低估的优质资产。" :
      "市场极度恐惧，恐慌性抛售。历史上极端恐惧往往是长期底部区域，别人恐惧我贪婪。";

    drawGauge(finalScore);
    renderFactors(factors);
  }

  calculate();
  setInterval(calculate, 300000); // Refresh every 5 min
})();
</script>
