# ═══════════════════════════════════════════════
# Bitaigen 环境变量配置
# ═══════════════════════════════════════════════
# 复制此文件为 .env 用于本地开发
# Vercel 部署时在 Dashboard → Settings → Environment Variables 中配置
#
# ⚠️ 切勿将 .env 提交到 Git！确保 .gitignore 包含 .env

# ── Ghost CMS ──────────────────────────────────
# Ghost Content API（只读，前端安全）
GHOST_URL=https://your-ghost-instance.ghost.io
GHOST_CONTENT_KEY=your_content_api_key_here

# ── Ghost Admin API（可选，仅后台脚本使用）──────
# ⚠️ Admin Key 拥有写入权限，绝对不能暴露在前端代码中
# GHOST_ADMIN_KEY=your_admin_key_id:your_admin_key_secret
