{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=30, s-maxage=60" },
        { "key": "Access-Control-Allow-Origin", "value": "https://bitaigen.com" }
      ]
    },
    {
      "source": "/rss.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "redirects": [
    {
      "comment": "── 多语言下 /coin/[symbol] 价格页只有 zh-CN，其他语言重定向回根 /coin/ ──",
      "source": "/en/coin/:symbol",
      "destination": "/coin/:symbol",
      "permanent": true
    },
    {
      "source": "/zh-tw/coin/:symbol",
      "destination": "/coin/:symbol",
      "permanent": true
    },
    {
      "source": "/es/coin/:symbol",
      "destination": "/coin/:symbol",
      "permanent": true
    },
    {
      "source": "/pt/coin/:symbol",
      "destination": "/coin/:symbol",
      "permanent": true
    },
    {
      "comment": "── 旧 slug 模式 cn-/tw-/p- 在多语言路径下 → 重定向到 zh-CN news（这些是 zh-CN-only 文章） ──",
      "source": "/en/news/cn-:rest*",
      "destination": "/news/cn-:rest*",
      "permanent": true
    },
    {
      "source": "/zh-tw/news/cn-:rest*",
      "destination": "/news/cn-:rest*",
      "permanent": true
    },
    {
      "source": "/es/news/cn-:rest*",
      "destination": "/news/cn-:rest*",
      "permanent": true
    },
    {
      "source": "/pt/news/cn-:rest*",
      "destination": "/news/cn-:rest*",
      "permanent": true
    },
    {
      "source": "/en/news/tw-:rest*",
      "destination": "/zh-tw/news/tw-:rest*",
      "permanent": true
    },
    {
      "source": "/es/news/tw-:rest*",
      "destination": "/zh-tw/news/tw-:rest*",
      "permanent": true
    },
    {
      "source": "/pt/news/tw-:rest*",
      "destination": "/zh-tw/news/tw-:rest*",
      "permanent": true
    },
    {
      "comment": "── 拼音 slug 通常是 zh-CN 原文，多语言路径下重定向回 zh-CN ──",
      "source": "/en/news/p-:rest*",
      "destination": "/news/",
      "permanent": false
    },
    {
      "source": "/es/news/p-:rest*",
      "destination": "/news/",
      "permanent": false
    },
    {
      "source": "/pt/news/p-:rest*",
      "destination": "/news/",
      "permanent": false
    },
    {
      "source": "/zh-tw/news/p-:rest*",
      "destination": "/news/",
      "permanent": false
    },
    {
      "comment": "── 多语言 flash 不存在，重定向到 zh-CN 快讯页 ──",
      "source": "/en/flash/:rest*",
      "destination": "/flash/:rest*",
      "permanent": true
    },
    {
      "source": "/zh-tw/flash/:rest*",
      "destination": "/flash/:rest*",
      "permanent": true
    },
    {
      "source": "/es/flash/:rest*",
      "destination": "/flash/:rest*",
      "permanent": true
    },
    {
      "source": "/pt/flash/:rest*",
      "destination": "/flash/:rest*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "query", "key": "x_astro_path" }],
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "query", "key": "hl" }],
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/tag/:slug",
      "destination": "/tags/:slug",
      "permanent": true
    },
    {
      "source": "/tag/:slug/:rest*",
      "destination": "/tags/:slug/:rest*",
      "permanent": true
    },
    {
      "source": "/category/:slug",
      "destination": "/tags/:slug",
      "permanent": true
    },
    {
      "source": "/category/:slug/:rest*",
      "destination": "/tags/:slug/:rest*",
      "permanent": true
    },
    {
      "source": "/page/1",
      "destination": "/archives",
      "permanent": true
    },
    {
      "source": "/page/:n",
      "destination": "/archives/page/:n",
      "permanent": true
    },
    {
      "source": "/news/page/:rest*",
      "destination": "/news",
      "permanent": true
    },
    {
      "source": "/en/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/zh-tw/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/es/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/pt/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": true
    },
    {
      "source": "/feed",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/feed.xml",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/rss",
      "destination": "/rss.xml",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/article/:slug",
      "destination": "/archives/:slug"
    },
    {
      "source": "/articles/:path*",
      "destination": "/archives/:path*"
    }
  ]
}
